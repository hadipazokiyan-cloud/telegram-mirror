 با روشن شدن چراغ‌های خیابان الکسانترینکاتو برگزار می‌شود؛ رویدادی پر از نور، موسیقی و حال‌وهوای جادویی. رژه بزرگ از ساعت ۱۶:۰۰ در میدان سنا آغاز شده و پس از عبور از خیابان‌های اصلی شهر، دوباره به همان‌جا بازمی‌گردد؛ مسیری که حدود یک ساعت طول می‌کشد و پر از شخصیت‌های شاد، حیوانات، گروه‌های رقص و حضور مهمان ویژه کریسمس خواهد بود.\n\n\r\n\r\nشهردار دانیل سازونوف این مراسم را رهبری می‌کند و همه را به تماشای روشن شدن چراغ‌ها و لذت بردن از فضای جشن دعوت کرده است. در کنار آن، خیابان کِسکوسکاتو هم به خیابان نیکوکاری تبدیل می‌شود و ایستگاه‌های خیریه و محل جمع‌آوری اسباب‌بازی برای خانواده‌های نیازمند برپا خواهد بود. 🎄✨\n"},{"text":"#فنلاند","navigationEndpoint":{"clickTrackingParams":"CEkQhPIEGAIiEwiIxIGJvqqUAxV7BRUFHZc0DA7KAQTtkXSS","commandMetadata":{"webCommandMetadata":{"url":"/hashtag/%D9%81%D9%86%D9%84%D8%A7%D9%86%D8%AF","webPageType":"WEB_PAGE_TYPE_BROWSE","rootVe":6827,"apiUrl":"/youtubei/v1/browse"}},"browseEndpoint":{"browseId":"FEhashtag","params":"6gUQCgzZgdmG2YTYp9mG2K8YAQ%3D%3D"}},"loggingDirectives":{"trackingParams":"CEkQhPIEGAIiEwiIxIGJvqqUAxV7BRUFHZc0DA4=","visibility":{"types":"12"}}},{"text":" "},{"text":"#هلسینکی","navigationEndpoint":{"clickTrackingParams":"CEgQhPIEGAQiEwiIxIGJvqqUAxV7BRUFHZc0DA7KAQTtkXSS","commandMetadata":{"webCommandMetadata":{"url":"/hashtag/%D9%87%D9%84%D8%B3%DB%8C%D9%86%DA%A9%DB%8C","webPageType":"WEB_PAGE_TYPE_BROWSE","rootVe":6827,"apiUrl":"/youtubei/v1/browse"}},"browseEndpoint":{"browseId":"FEhashtag","params":"6gUSCg7Zh9mE2LPbjNmG2qnbjBgB"}},"loggingDirectives":{"trackingParams":"CEgQhPIEGAQiEwiIxIGJvqqUAxV7BRUFHZc0DA4=","visibility":{"types":"12"}}},{"text":" "},{"text":"#مازیار_استوی","navigationEndpoint":{"clickTrackingParams":"CEcQhPIEGAYiEwiIxIGJvqqUAxV7BRUFHZc0DA7KAQTtkXSS","commandMetadata":{"webCommandMetadata":{"url":"/hashtag/%D9%85%D8%A7%D8%B2%DB%8C%D8%A7%D8%B1_%D8%A7%D8%B3%D8%AA%D9%88%DB%8C","webPageType":"WEB_PAGE_TYPE_BROWSE","rootVe":6827,"apiUrl":"/youtubei/v1/browse"}},"browseEndpoint":{"browseId":"FEhashtag"