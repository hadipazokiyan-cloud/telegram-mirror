lVideoPlayerRenderer":{"videoId":"Tb5rPPcVX4w","title":{"runs":[{"text":"داستان واقعی مهاجرت به فنلاند برای تحصیل | از فرودگاه تا دانشگاه","navigationEndpoint":{"clickTrackingParams":"CK4DELsvGAAiEwiIxIGJvqqUAxV7BRUFHZc0DA7KAQTtkXSS","commandMetadata":{"webCommandMetadata":{"url":"/watch?v=Tb5rPPcVX4w\u0026pp=0gcJCR8bAYcqIYzv","webPageType":"WEB_PAGE_TYPE_WATCH","rootVe":3832}},"watchEndpoint":{"videoId":"Tb5rPPcVX4w","playerParams":"0gcJCR8bAYcqIYzv","watchEndpointSupportedOnesieConfig":{"html5PlaybackOnesieConfig":{"commonConfig":{"url":"https://rr1---sn-p5qs7nzk.googlevideo.com/initplayback?source=youtube\u0026oeis=1\u0026c=WEB\u0026oad=3200\u0026ovd=3200\u0026oaad=11000\u0026oavd=11000\u0026ocs=700\u0026oewis=1\u0026oputc=1\u0026ofpcc=1\u0026msp=1\u0026odepv=1\u0026id=4dbe6b3cf7155f8c\u0026ip=128.24.161.82\u0026initcwndbps=5315000\u0026mt=1778270240\u0026oweuc="}}}}}}],"accessibility":{"accessibilityData":{"label":"داستان واقعی مهاجرت به فنلاند برای تحصیل | از فرودگاه تا دانشگاه 11 minutes, 19 seconds"}}},"description":{"runs":[{"text":"مهاجرت تحصیلی به فنلاند یکی از مهم‌ترین تصمیم‌های زندگی من بود. توی این ویدیو، تجربه اولین روز ورودم به کشور فنلاند رو می‌بینید؛ از لحظه‌ای که بعد رسیدن سوار قطاری شدم که منو به شهری رسوند که دانشگاه محل تحصیلم اونجا بود.\n\nاون روز، آغاز یه مسیر تازه برای زندگی دانشجویی من توی فنلاند بود. همه‌چی برام تازگی داشت؛ پر از هیجان و امید. وقتی سوار قطار شدم، نمی‌دونستم دارم به سمت دانشگاهی می‌رم که نه‌فقط علم و دانش یادم می‌ده، بلکه مسیر فکری و نگاه منو به زندگی تغییر می‌ده. اون سفر، شروع واقعی ماجراجویی تحصیلی من تو فنلاند بود، و حالا رؤیاهام دارن یکی‌یکی واقعی می‌شن. 🇫🇮🎓🚆\n\nبرای تماس با من به ایدی تلگرام زیر پیام بدید:\n"},{"text":"https://t.me/applyfinlandstudy","navigationEndpoint":{"clickTrackingParams":"CK4DELsvGAAiEwiIxIGJvqqUAxV7BRUFHZc0DA7KAQTtkXSS","commandMetadata":{"webCommandMetadata":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbGNsd2t6eURkOVNOc2V5QjZqWUIwLURJazFkQXxBQ3Jtc0tuc