oute\":\"slug\",\"children\":[\"$\",\"$L15\",null,{\"parallelRouterKey\":\"children\",\"error\":\"$undefined\",\"errorStyles\":\"$undefined\",\"errorScripts\":\"$undefined\",\"template\":[\"$\",\"$L17\",null,{}],\"templateStyles\":\"$undefined\",\"templateScripts\":\"$undefined\",\"notFound\":\"$undefined\",\"forbidden\":\"$undefined\",\"unauthorized\":\"$undefined\"}]}]]}]\n"])</script><div hidden id="S:3"><div class="Skeleton-module-scss-module__u3hcSa__skeletonText Skeleton-module-scss-module__u3hcSa__normal" aria-hidden="true"></div></div><script>$RS("S:3","P:3")</script><script>$RC("B:0","S:0")</script><div hidden id="S:2"><div><div><p class="CustomPortableTextComponents-module-scss-module__peBeZa__paragraph">رییس‌جمهوری آمریکا نوشت: «این آتش‌بس شامل توقف تمامی فعالیت‌های نظامی و همچنین تبادل هزار اسیر از هر کشور خواهد بود. این درخواست مستقیما از سوی من مطرح شد و از موافقت ولادیمیر پوتین و ولودیمیر زلنسکی با آن بسیار قدردانی می‌کنم.»</p><p class="CustomPortableTextComponents-module-scss-module__peBeZa__paragraph">ترامپ در این پست نوشت: «امیدوارم این، آغاز پایان یک جنگ بسیار طولانی، مرگبار و سخت باشد. مذاکرات برای پایان دادن به این درگیری بزرگ ــ بزرگ‌ترین درگیری از زمان جنگ جهانی دوم ــ ادامه دارد و هر روز بیش از پیش به توافق نزدیک می‌شویم.»</p></div></div></div><script>$RC("B:2","S:2")</script><div hidden id="S:4"><div class="ArticleSidebar-module-scss-module__u6S0Mq__sidebar"><div class="ArticleSidebar-module-scss-module__u6S0Mq__item"><!--$--><section class="shared-module-scss-module__jvefRG__widget "><header class="shared-module-scss-module__jvefRG__widgetHeader"><h3 class="shared-module-scss-module__jvefRG__widgetTitle">پربازدیدترین‌ها</h3></header><div class="MostViewWidget-module-scss-module__0kYkyW__list MostViewWidget-module-scss-module__0kYkyW__list--list"><article class="MostViewWidget-module-scss-module__0kYkyW__card MostViewWidget-module-scss-module__0kYkyW__card--first"><a class="MostViewWidget-module-scss-module__0kYkyW__card__link" href="/fa/202605071065"><div class="MostViewWidget-module-scss-module__0kYkyW__card__imageFeatured"><picture class="MostViewWidget-module-scss-module__0kYkyW__card__image"><source media="(min-width: 1024px)" srcSet="https://i.iranintl.com/images/rdk9umy0/production/60e181abdace2d3998267bca30ead36acaee883b-5500x3667.jpg?rect=0,2,5500,3665&amp;w=992&amp;h=661&amp;q=80&amp;fit=max&amp;auto=format"/><source media="(min-width: 768px)" srcSet="https://i.iranintl.com/images/rdk9umy0/production/60e181abdace2d3998267bca30ead36acaee883b-5500x3667.jpg?w=768&amp;h=512&amp;q=80&amp;fit=max&amp;auto=format"/><img src="https://i.iranintl.com/images/rdk9umy0/production/60e181abdace2d3998267bca30ead36acaee883b-5500x3667.jpg?w=576&amp;h=384&amp;q=80&amp;fit=max&amp;auto=format" alt="جمهوری اسلامی نهاد جدیدی برای کنترل تنگه هرمز ایجاد کرد"/></picture></div><div class="MostViewWidget-module-scss-module__0kYkyW__card__content"><div class="MostViewWidget-module-scss-module__0kYkyW__card__number">۱</div><div class="MostViewWidget-module-scss-module__0kYkyW__card__text"><div class="MostViewWidget-module-scss-module__0kYkyW__card__meta"></div><h4 class="MostViewWidget-module-scss-module__0kYkyW__card__headline">جمهوری اسلامی نهاد جدیدی برای کنترل تنگه هرمز ایجاد کرد</h4></div></div></a></article><article class="MostViewWidget-module-scss-module__0kYkyW__card MostViewWidget-module-scss-module__0kYkyW__card--list"><a class="MostViewWidget-module-scss-module__0kYkyW__card__link" href="/fa/202605072769"><div class="MostViewWidget-module-scss-module__0kYkyW__card__content"><div class="MostViewWidget-module-scss-module__0kYkyW__card__number">۲</div><div class="MostViewWidget-module-scss-module__0kYkyW__card__text"><div class="MostViewWidget-module-scss-module__0kYkyW__card__meta"></div><h4 class="MostViewWidget-module-scss-module__0kYkyW__card__headline">چین ۲ وزیر دفاع پیشین خود را به اعدام تعلیقی محکوم کرد</h4></div></div></a></article><article class="MostViewWidget-module-scss-module__0kYkyW__card MostViewWidget-module-scss-module__0kYkyW__card--list"><a class="MostViewWidget-module-scss-module__0kYkyW__card__link" href="/fa/2026050866620"><div class="MostViewWidget-module-scss-module__0kYkyW__card__content"><div class="MostViewWidget-module-scss-module__0kYkyW__card__number">۳</div><div class="MostViewWidget-module-scss-module__0kYkyW__card__text"><div class="MostViewWidget-module-scss-module__0kYkyW__card__meta"></div><h4 class="MostViewWidget-module-scss-module__0kYkyW__card__headline">ضربه سنگین به حزب کارگر در انتخابات محلی و پیروزی گسترده حزب اصلاح بریتانیا</h4></div></div></a></article><article class="MostViewWidget-module-scss-module__0kYkyW__card MostViewWidget-module-scss-module__0kYkyW__card--list"><a class="MostViewWidget-module-scss-module__0kYkyW__card__link" href="/fa/202605068830"><div class="MostViewWidget-module-scss-module__0kYkyW__card__content"><div class="MostViewWidget-module-scss-module__0kYkyW__card__number">۴</div><div class="MostViewWidget-module-scss-module__0kYkyW__card__text"><div class="MostViewWidget-module-scss-module__0kYkyW__card__meta"></div><h4 class="MostViewWidget-module-scss-module__0kYkyW__card__headline">مجری محافظه‌کار توافق احتمالی با ایران را «توافقی وحشتناک» خواند</h4></div></div></a></article><article class="MostViewWidget-module-scss-module__0kYkyW__card MostViewWidget-module-scss-module__0kYkyW__card--list"><a class="MostViewWidget-module-scss-module__0kYkyW__card__link" href="/fa/202605077265"><div class="MostViewWidget-module-scss-module__0kYkyW__card__content"><div class="MostViewWidget-module-scss-module__0kYkyW__card__number">۵</div><div class="MostViewWidget-module-scss-module__0kYkyW__card__text"><div class="MostViewWidget-module-scss-module__0kYkyW__card__meta"><span class="MostViewWidget-module-scss-module__0kYkyW__card__tag" style="color:#0084bc">تحلیل</span></div><h4 class="MostViewWidget-module-scss-module__0kYkyW__card__headline">آیا ترامپ پیروزی در جنگ ایران را با شکست عوض می‌کند؟</h4></div></div></a></article></div></section><!--/$--></div><div class="ArticleSidebar-module-scss-module__u6S0Mq__item"><!--$?--><template id="B:6"></template><div class="WidgetSkeleton-module-scss-module__vOSGOW__widgetSkeleton"><div class="WidgetSkeleton-module-scss-module__vOSGOW__widgetSkeletonHeader"><div class="Skeleton-module-scss-module__u3hcSa__skeletonText Skeleton-module-scss-module__u3hcSa__large" aria-hidden="true"></div></div><div class="WidgetSkeleton-module-scss-module__vOSGOW__widgetSkeletonList"><div class="WidgetSkeleton-module-scss-module__vOSGOW__widgetSkeletonListItem"><div class="Skeleton-module-scss-module__u3hcSa__skeletonTextContainer"><div class="Skeleton-module-scss-module__u3hcSa__skeletonText Skeleton-module-scss-module__u3hcSa__small" aria-hidden="true"></div><div class="Skeleton-module-scss-module__u3hcSa__skeletonText Skeleton-module-scss-module__u3hcSa__small" style="width:100%" aria-hidden="true"></div></div></div><div class="WidgetSkeleton-module-scss-module__vOSGOW__widgetSkeletonListItem"><div class="Skeleton-module-scss-module__u3hcSa__skeletonTextContainer"><div class="Skeleton-module-scss-module__u3hcSa__skeletonText Skeleton-module-scss-module__u3hcSa__small" aria-hidden="true"></div><div class="Skeleton-module-scss-module__u3hcSa__skeletonText Skeleton-module-scss-module__u3hcSa__small" style="width:100%" aria-hidden="true"></div></div></div><div class="WidgetSkeleton-module-scss-module__vOSGOW__widgetSkeletonListItem"><div class="Skeleton-module-scss-module__u3hcSa__skeletonTextContainer"><div class="Skeleton-module-scss-module__u3hcSa__skeletonText Skeleton-module-scss-module__u3hcSa__small" aria-hidden="true"></div><div class="Skeleton-module-scss-module__u3hcSa__skeletonText Skeleton-module-scss-module__u3hcSa__small" style="width:100%" aria-hidden="true"></div></div></div><div class="WidgetSkeleton-module-scss-module__vOSGOW__widgetSkeletonListItem"><div class="Skeleton-module-scss-module__u3hcSa__skeletonTextContainer"><div class="Skeleton