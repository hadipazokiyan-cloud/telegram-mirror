ت، بین روسیه و اوکراین آتش‌بس سه روزه برقرار خواهد شد. ترامپ ابراز امیدواری کرد این آتش‌بس، شروعی برای پایان این جنگ باشد.</p><!--$?--><template id="B:2"></template><div class="Skeleton-module-scss-module__u3hcSa__skeletonList Skeleton-module-scss-module__u3hcSa__gap-large Skeleton-module-scss-module__u3hcSa__direction-column"><div class="Skeleton-module-scss-module__u3hcSa__skeletonTextContainer"><div class="Skeleton-module-scss-module__u3hcSa__skeletonText Skeleton-module-scss-module__u3hcSa__normal" aria-hidden="true"></div><div class="Skeleton-module-scss-module__u3hcSa__skeletonText Skeleton-module-scss-module__u3hcSa__normal" aria-hidden="true"></div><div class="Skeleton-module-scss-module__u3hcSa__skeletonText Skeleton-module-scss-module__u3hcSa__normal" aria-hidden="true"></div><div class="Skeleton-module-scss-module__u3hcSa__skeletonText Skeleton-module-scss-module__u3hcSa__normal" aria-hidden="true"></div><div class="Skeleton-module-scss-module__u3hcSa__skeletonText Skeleton-module-scss-module__u3hcSa__normal" aria-hidden="true"></div></div><div class="Skeleton-module-scss-module__u3hcSa__skeletonTextContainer"><div class="Skeleton-module-scss-module__u3hcSa__skeletonText Skeleton-module-scss-module__u3hcSa__normal" aria-hidden="true"></div><div class="Skeleton-module-scss-module__u3hcSa__skeletonText Skeleton-module-scss-module__u3hcSa__normal" aria-hidden="true"></div><div class="Skeleton-module-scss-module__u3hcSa__skeletonText Skeleton-module-scss-module__u3hcSa__normal" aria-hidden="true"></div><div class="Skeleton-module-scss-module__u3hcSa__skeletonText Skeleton-module-scss-module__u3hcSa__normal" aria-hidden="true"></div><div class="Skeleton-module-scss-module__u3hcSa__skeletonText Skeleton-module-scss-module__u3hcSa__normal" aria-hidden="true"></div><div class="Skeleton-module-scss-module__u3hcSa__skeletonText Skeleton-module-scss-module__u3hcSa__normal" aria-hidden="true"></div></div><div class="Skeleton-module-scss-module__u3hcSa__skeletonTextCo