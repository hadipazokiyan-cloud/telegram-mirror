le-scss-module__u3hcSa__skeletonText Skeleton-module-scss-module__u3hcSa__normal\",\"style\":\"$undefined\",\"aria-hidden\":\"true\"}],[\"$\",\"div\",\"1\",{\"className\":\"Skeleton-module-scss-module__u3hcSa__skeletonText Skeleton-module-scss-module__u3hcSa__normal\",\"style\":\"$undefined\",\"aria-hidden\":\"true\"}],[\"$\",\"div\",\"2\",{\"className\":\"Skeleton-module-scss-module__u3hcSa__skeletonText Skeleton-module-scss-module__u3hcSa__normal\",\"style\":\"$undefined\",\"aria-hidden\":\"true\"}]]}]}]]}],[\"$\",\"div\",null,{\"className\":\"RelatedArticleSkeleton-module-scss-module__wrOvWa__skeletonBody\",\"children\":[\"$\",\"div\",null,{\"className\":\"Skeleton-module-scss-module__u3hcSa__skeletonTextContainer\",\"children\":[[\"$\",\"div\",\"0\",{\"className\":\"Skeleton-module-scss-module__u3hcSa__skeletonText Skeleton-module-scss-module__u3hcSa__normal\",\"style\":\"$undefined\",\"aria-hidden\":\"true\"}],[\"$\",\"div\",\"1\",{\"className\":\"Skeleton-module-scss-module__u3hcSa__skeletonText Skeleton-module-scss-module__u3hcSa__normal\",\"style\":\"$undefined\",\"aria-hidden\":\"true\"}],[\"$\",\"div\",\"2\",{\"className\":\"Skeleton-module-scss-module__u3hcSa__skeletonText Skeleton-module-scss-module__u3hcSa__normal\",\"style\":\"$undefined\",\"aria-hidden\":\"true\"}],[\"$\",\"div\",\"3\",{\"className\":\"Skeleton-module-scss-module__u3hcSa__skeletonText Skeleton-module-scss-module__u3hcSa__normal\",\"style\":\"$undefined\",\"aria-hidden\":\"true\"}],[\"$\",\"div\",\"4\",{\"className\":\"Skeleton-module-scss-module__u3hcSa__skeletonText Skeleton-module-scss-module__u3hcSa__normal\",\"style\":\"$undefined\",\"aria-hidden\":\"true\"}]]}]}],[\"$\",\"div\",null,{\"className\":\"RelatedArticleSkeleton-module-scss-module__wrOvWa__skeletonDivider\"}]]}]\n"])</script><script>self.__next_f.push([1,"51:T47a,data:image/png;base64,:T40e,data:image/png;base64,"])</script><script>self.__next_f.push([1,"4f:[\"$\",\"$L50\",null,{\"topicIds\":[\"67bd595d-41c2-41e8-8ba7-42f76fd9e49e\"],\"currentStoryId\":\"1f8acbda-ddf7-47ac-a450-e0dd738bd44d\",\"currentSlug\":\"202605082152\",\"language\":\"farsi\",\"initialArticles\":[{\"authors\":null,\"body\":[{\"_key\":\"7bdaa4ffa7af\",\"_type\":\"block\",\"children\":[{\"_key\":\"cac59e7969ac\",\"_type\":\"span\",\"marks\":[],\"text\":\"خبرگزاری فارس، وابسته به سپاه پاسداران جمعه ۱۸ اردیبهشت نوشت درگیری‌های پراکنده میان نیروهای مسلح جمهوری اسلامی و شناورهای آمریکایی در محدوده تنگه هرمز از ساعتی پیش آغاز شده است.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"82dc28b48a97\",\"_type\":\"block\",\"children\":[{\"_key\":\"f3fbdb26547d\",\"_type\":\"span\",\"marks\":[],\"text\":\"ساعاتی بعد، خبرگزاری تسنیم، دیگر رسانه وابسته به سپاه پاسداران، به‌نقل از یک منبع نظامی نوشت که درگیری نیروهای جمهوری اسلامی با نیروهای آمریکایی «پس از مدتی تبادل آتش، متوقف شده و فضا آرام است.»\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"f73b0af72daa\",\"_type\":\"block\",\"children\":[{\"_key\":\"4b08f6a48169\",\"_type\":\"span\",\"marks\":[],\"text\":\"این منبع نظامی که نامش فاش نشده، افزود: «با این حال، اگر مجددا آمریکایی‌ها قصد ورود به خلیج فارس را داشته باشند و یا برای شناورهای ایرانی مزاحمتی ایجاد کنند، مجددا پاسخ قاطع دریافت خواهند کرد.»\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"044481bbe115\",\"_type\":\"block\",\"children\":[{\"_key\":\"2017fca7e032\",\"_type\":\"span\",\"marks\":[],\"text\":\"او گفت: «بنابراین احتمال ورود مجدد به درگیری‌هایی از این قبیل در این منطقه همچنان وجود دارد.»\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"48f4830caeec\",\"_type\":\"block\",\"children\":[{\"_key\":\"763b7663574e\",\"_type\":\"span\",\"marks\":[],\"text\":\"هم‌زمان گزارش‌های مختلفی از شنیده شدن صدای انفجار و فعالیت پدافند هوایی در چند شهر از جمله تهران، سیرک و کنارک منتشر شد.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"872bb1ba5b77\",\"_type\":\"block\",\"children\":[{\"_key\":\"447429513808\",\"_type\":\"span\",\"marks\":[],\"text\":\"این در حالی است که مارکو روبیو، وزیر امور خارجه آمریکا، \"},{\"_key\":\"d4d83b279084\",\"_type\":\"span\",\"marks\":[\"b5c961fd1a9e\"],\"text\":\"گفت\"},{\"_key\":\"b5f09295021f\",\"_type\":\"span\",\"marks\":[],\"text\":\" باید جمعه پاسخ جمهوری اسلامی به طرح پیشنهادی صلح به واشینگتن ارائه شود.\"}],\"markDefs\":[{\"_key\":\"b5c961fd1a9e\",\"_type\":\"link\",\"href\":\"https://www.iranintl.com/fa/202605080757\"}],\"style\":\"normal\"},{\"_key\":\"a4bf6b3909f3\",\"_type\":\"inlinecontent\",\"stories\":[{\"headline\":\"وزیر امور خارجه آمریکا: کنترل جمهوری اسلامی بر تنگه هرمز را نخواهیم پذیرفت\",\"id\":\"d8aa11b1-8522-4d0d-b594-b7483b57329d\",\"image\":{\"_type\":\"image\",\"asset\":{\"_ref\":\"image-3471750a5494d00163a7a2ef27d816642bea735f-8207x5469-jpg\",\"_type\":\"reference\"}},\"language\":\"farsi\",\"publishedAt\":\"2026-05-08T14:16:33.883Z\",\"slug\":\"202605082560\",\"type\":\"story\",\"updatedAt\":null}]},{\"_key\":\"8542cf93e2d8\",\"_type\":\"block\",\"children\":[{\"_key\":\"410c2a9dbfa5\",\"_type\":\"span\",\"marks\":[],\"text\":\"او ابراز امیدواری کرد این پاسخ «جدی» باشد و بتواند مسیر ورود به یک فرآیند مذاکراتی واقعی را باز کند.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"e3802c158476\",\"_type\":\"block\",\"children\":[{\"_key\":\"b7a53bcb1296\",\"_type\":\"span\",\"marks\":[],\"text\":\"امارات متحده عربی جمعه ۱۸ اردیبهشت \"},{\"_key\":\"af0c1723d70b\",\"_type\":\"span\",\"marks\":[\"20eb40611d34\"],\"text\":\"اعلام کرد\"},{\"_key\":\"1758ba0737c0\",\"_type\":\"span\",\"marks\":[],\"text\":\" به یک حمله جدید موشکی جمهوری اسلامی پاسخ داده است؛ حمله‌ای که ساعاتی پس از اعلام تبادل آتش میان آمریکا و ایران در تنگه هرمز رخ داد و آتش‌بس شکننده یک‌ماهه را با چالش تازه‌ای روبه‌رو کرد.\"}],\"markDefs\":[{\"_key\":\"20eb40611d34\",\"_type\":\"link\",\"href\":\"https://www.iranintl.com/fa/202605081366\"}],\"style\":\"normal\"},{\"_key\":\"8f77dc89672a\",\"_type\":\"block\",\"children\":[{\"_key\":\"1c2cefb185ab\",\"_type\":\"span\",\"marks\":[],\"text\":\"وزارت دفاع امارات نیز گفت سامانه‌های پدافندی این کشور دو موشک بالستیک و سه پهپاد شلیک‌شده از سوی ایران را رهگیری کردند. \"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"3e473a9f99a5\",\"_type\":\"block\",\"children\":[{\"_key\":\"1c2cefb185ab\",\"_type\":\"span\",\"marks\":[],\"text\":\"در این حمله سه نفر زخمی شدند، اما مشخص نیست همه اهداف به‌طور کامل منهدم شده باشند. مقام‌ها از شهروندان خواستند از محل سقوط احتمالی بقایا دوری کنند.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"bf85cb74faef\",\"_type\":\"block\",\"children\":[{\"_key\":\"40274f534bf6\",\"_type\":\"span\",\"marks\":[],\"text\":\"در همین حال، ارتش آمریکا اعلام کرد حملات جمهوری اسلامی به سه ناو نیروی دریایی خود در تنگه هرمز را دفع کرده و تاسیسات نظامی ایران را که در این حملات نقش داشته‌اند، هدف قرار داده است. به‌گفته مقام‌های آمریکایی، هیچ‌یک از کشتی‌های این کشور آسیب ندیده‌اند.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"d424a20e8d8e\",\"_type\":\"inlinecontent\",\"stories\":[{\"headline\":\"ارم‌نیوز: یادداشت تفاهم تهران و واشینگتن توافقی جامع نیست و بر کاهش تنش‌ها تمرکز دارد\",\"id\":\"71689f6d-40c1-4093-ab35-2d3a465ee5f4\",\"image\":{\"_type\":\"image\",\"asset\":{\"_ref\":\"image-07c8375bf238eb643e8246660086bf9cb4bbb75a-1920x1080-png\",\"_type\":\"reference\"},\"crop\":{\"_type\":\"sanity.imageCrop\",\"bottom\":0,\"left\":0.0317845943384412,\"right\":0.01869698029744349,\"top\":0},\"hotspot\":{\"_type\":\"sanity.imageHotspot\",\"height\":0.7872716797365119,\"width\":0.869122045141938,\"x\":0.5,\"y\":0.39363583986825595}},\"language\":\"farsi\",\"publishedAt\":\"2026-05-08T11:46:36.631Z\",\"slug\":\"202605088965\",\"type\":\"story\",\"updatedAt\":null}]},{\"_key\":\"bd9141039ba9\",\"_type\":\"block\",\"children\":[{\"_key\":\"4bba260fa909\",\"_type\":\"span\",\"marks\":[],\"text\":\"واشینگتن همچنین اعلام کرد نیروهایش دو نفت‌کش ایرانی دیگر را که در تلاش برای عبور از محاصره دریایی آمریکا بودند، هدف قرار داده و از کار انداخته‌اند. آمریکا با هدف جلوگیری از تردد نفت‌کش‌های ایرانی، بندرهای این کشور را تحت محاصره قرار داده است.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"a9697488d0ab\",\"_type\":\"block\",\"children\":[{\"_key\":\"7f16650eca97\",\"_type\":\"span\",\"marks\":[],\"text\":\"هم‌زمان، گزارش‌هایی منتشر شده که نشان می‌دهد جمهوری اسلامی با ایجاد نهادی برای کنترل عبور کشتی‌ها در تنگه هرمز، در پی تثبیت نقش خود در مدیریت این آبراه است؛ اقدامی که نگرانی‌های تازه‌ای درباره آزادی کشتی‌رانی ایجاد کرده است. \"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"391c1608af9e\",\"_type\":\"block\",\"children\":[{\"_key\":\"7f16650eca97\",\"_type\":\"span\",\"marks\":[],\"text\":\"در حال حاضر صدها کشتی تجاری در خلیج فارس متوقف شده‌اند و امکان گذر از تنگه هرمز و ورود به آب‌های آزاد را ندارند.\"}],\"markDefs\":[],\"style\":\"normal\"}],\"categories\":[{\"id\":\"c4f6cf29-2688-4b26-8595-a02c0ffd0cf1\",\"slug\":\"hmlh-aamryka-w-asraeyl-bh-jmhwry-aslamy\",\"title\":\"جنگ علیه جمهوری اسلامی\",\"type\":\"supernews\"},{\"id\":\"67bd595d-41c2-41e8-8ba7-42f76fd9e49e\",\"slug\":\"iran\",\"title\":\"ایران\",\"type\":\"category\"}],\"hasTextToSpeech\":true,\"headline\":\"امارات متحده عربی از رهگیری حمله موشکی خبر داد؛ درگیری‌ها در تنگه هرمز تشدید شد\",\"id\":\"a6d21de2-3f44-4e2e-a7d8-eabf2411dffd\",\"image\":{\"alt\":null,\"asset\":{\"_ref\":\"image-e32a63befe5e567424f42439a52b270321fa2385-800x450-jpg\",\"_type\":\"reference\"},\"caption\":null,\"crop\":null,\"hotspot\":null,\"metadata\":{\"dimensions\":{\"height\":450,\"width\":800},\"lqip\":\"data:image/jpeg;base64,\"}},\"language\":\"farsi\",\"lead\":\"گزارش‌هایی از درگیری‌های پراکنده میان نیروهای مسلح جمهوری اسلامی و شناورهای آمریکایی در محدوده تنگه هرمز منتشر شده است. هم‌زمان امارات متحده عربی اعلام کرد در پی حمله موشکی و پهپادی جمهوری اسلامی سه نفر زخمی شدند.\",\"publishedAt\":\"2026-05-08T16:39:53.100Z\",\"revision\":null,\"shorthandUrl\":null,\"slug\":\"202605080952\",\"tags\":null,\"type\":\"story\",\"updatedAt\":\"2026-05-08T16:42:39Z\"},{\"authors\":null,\"body\":[{\"_key\":\"f81a9ed26c2d\",\"_type\":\"block\",\"children\":[{\"_key\":\"60a605145e5c\",\"_type\":\"span\",\"marks\":[],\"text\":\"بر اساس این گزارش‌ها، از نیمه فروردین به بعد قیمت برخی داروهای رایج بین ۳۰ تا ۱۰۰ درصد افزایش یافته و هم‌زمان، دسترسی به داروهایی مانند کلونازپام و آسنترا با اختلال جدی مواجه شده است.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"f731233245b3\",\"_type\":\"block\",\"children\":[{\"_key\":\"59ebe232fa04\",\"_type\":\"span\",\"marks\":[],\"text\":\"پیش‌تر اطلاعاتی به ایران‌اینترنشنال رسیده بود که نشان می‌داد قیمت برخی داروها، از جمله داروهای بیماران مبتلا به سرطان و انسولین یا مکمل‌های دارویی، \"},{\"_key\":\"ececfca810d1\",\"_type\":\"span\",\"marks\":[\"3d671e75da18\"],\"text\":\"تا ۳۸۰ درصد افزایش\"},{\"_key\":\"622953021cc4\",\"_type\":\"span\",\"marks\":[],\"text\":\" یافته است.\"}],\"markDefs\":[{\"_key\":\"3d671e75da18\",\"_type\":\"link\",\"href\":\"https://www.iranintl.com/202604294554\"}],\"style\":\"normal\"},{\"_key\":\"79c156171e5e\",\"_type\":\"inlinecontent\",\"stories\":[{\"headline\":\"داروهای اعصاب و پارکینسون کمیاب و گران شده‌اند\",\"id\":\"69f8e4c1-3ca0-4898-8b36-70d7f142ec01\",\"image\":{\"_type\":\"figure\",\"asset\":{\"_ref\":\"image-65390234c0325ab8aaaf9b590e08a9cd536e5f4d-842x514-jpg\",\"_type\":\"reference\"}},\"language\":\"farsi\",\"publishedAt\":\"2026-04-15T09:12:40.662Z\",\"slug\":\"202604152481\",\"type\":\"story\",\"updatedAt\":null}]},{\"_key\":\"26e32d5ae9ed\",\"_type\":\"block\",\"children\":[{\"_key\":\"377f8b8e6088\",\"_type\":\"span\",\"marks\":[\"strong\"],\"text\":\"حذف تدریجی داروهای ضروری اعصاب از سبد درمان\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"91520363c04c\",\"_type\":\"block\",\"children\":[{\"_key\":\"e7dae446b60f\",\"_type\":\"span\",\"marks\":[],\"text\":\"پیا‌م‌های رسیده نشان می‌دهند افزایش هزینه نسخه‌ها و کاهش دسترسی به دارو، باعث شده بخشی از بیماران، درمان خود را متوقف کنند.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"d55694b07fbe\",\"_type\":\"block\",\"children\":[{\"_key\":\"5e43d400adb4\",\"_type\":\"span\",\"marks\":[],\"text\":\"یک داروساز به ایران‌اینترنشنال گفت: «بعضی بیماران وقتی قیمت نسخه را می‌شنوند، دارو را برنمی‌دارند و می‌روند.»\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"19c8e5123514\",\"_type\":\"block\",\"children\":[{\"_key\":\"9ec268f3a0e9\",\"_type\":\"span\",\"marks\":[],\"text\":\"به گفته او، در هفته‌های اخیر موارد متعددی از بیمارانی مشاهده شده که به‌دلیل ناتوانی مالی، داروهای خود را حذف کرده یا مصرف آن را کاهش داده‌اند.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"169d64ba98d2\",\"_type\":\"block\",\"children\":[{\"_key\":\"b07e9dd16496\",\"_type\":\"span\",\"marks\":[],\"text\":\"یک شهروند مبتلا به افسردگی شدید که خود را «مستمری‌بگیر» معرفی کرد، به ایران‌اینترنشنال گفت با حقوق ماهانه هفت میلیون تومان، در هر نوبت دریافت نسخه باید حدود چهار میلیون تومان هزینه کند.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"0ee180cc7d8c\",\"_type\":\"block\",\"children\":[{\"_key\":\"2e8f6b9f1cab\",\"_type\":\"span\",\"marks\":[],\"text\":\"او افزود: «من باید ویتامین ب و داروی خواب برای کنترل چرخه خوابم مصرف کنم. این ویتامین‌ها تحت پوشش بیمه نیستند و فقط دو قلم داروی ارزان شامل بیمه می‌شود. ترجیح داده‌ام این روزها کلا دارو و دکتر را کنار بگذارم.»\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"946a926e3422\",\"_type\":\"block\",\"children\":[{\"_key\":\"1ea00e079447\",\"_type\":\"span\",\"marks\":[],\"text\":\"بر اساس گزارش شهروندان، قیمت یک بسته آسنترا ۵۰ در اواسط اردیبهشت به حدود یک میلیون و ۷۰۰ هزار تومان رسیده و دوز ۱۰۰ آن در بازار کمیاب است.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"5d6738e6c3c2\",\"_type\":\"block\",\"children\":[{\"_key\":\"f8b7b95141fc\",\"_type\":\"span\",\"marks\":[],\"text\":\"یک بیمار گفت با توجه به دوز مصرفی، مجبور است ماهانه حدود شش میلیون و ۸۰۰ هزار تومان برای این دارو هزینه کند.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"06b6384e17c2\",\"_type\":\"inlinecontent\",\"stories\":[{\"headline\":\"یک سرماخوردگی ساده دو میلیون تومان آب می‌خورد\",\"id\":\"5f0857dc-e72a-4eca-8595-1b7d32a7d668\",\"image\":{\"_type\":\"figure\",\"asset\":{\"_ref\":\"image-5ab0aefdfc21421a3be10df0e3393c819bf99bf4-2048x922-jpg\",\"_type\":\"reference\"},\"crop\":{\"_type\":\"sanity.imageCrop\",\"bottom\":0,\"left\":0.16956881253211617,\"right\":0.06339004106749412,\"top\":0},\"hotspot\":{\"_type\":\"sanity.imageHotspot\",\"height\":1,\"width\":0.7670411464003897,\"x\":0.553089385732311,\"y\":0.5}},\"language\":\"farsi\",\"publishedAt\":\"2026-04-20T11:57:26.858Z\",\"slug\":\"202604209331\",\"type\":\"story\",\"updatedAt\":null}]},{\"_key\":\"6ba174c72353\",\"_type\":\"block\",\"children\":[{\"_key\":\"dab7b57c4279\",\"_type\":\"span\",\"marks\":[\"strong\"],\"text\":\"سرترالین سهمیه‌ای شده است\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"043778157a34\",\"_type\":\"block\",\"children\":[{\"_key\":\"8501f71a51ce\",\"_type\":\"span\",\"marks\":[],\"text\":\"بر اساس پیام‌های شهروندان، کمبود داروهای اعصاب دیگر محدود به داروهای خاص یا بیماران بستری نیست و اکنون داروهای رایج نیز با اختلال در تامین مواجه شده‌اند.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"e25cde6c8181\",\"_type\":\"block\",\"children\":[{\"_key\":\"b003df17ee62\",\"_type\":\"span\",\"marks\":[],\"text\":\"یک مخاطب گفت قرص سرترالین، که از رایج‌ترین داروهای درمان افسردگی، اضطراب و وسواس است، در هفته‌های اخیر کمیاب شده است.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"3960d880489d\",\"_type\":\"block\",\"children\":[{\"_key\":\"298d84adf54f\",\"_type\":\"span\",\"marks\":[],\"text\":\"به گفته او، نوع خارجی این دارو در بازار موجود نیست و نمونه‌های داخلی نیز به‌صورت سهمیه‌ای عرضه می‌شوند.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"5f39229b5ee2\",\"_type\":\"block\",\"children\":[{\"_key\":\"020f0af696cf\",\"_type\":\"span\",\"marks\":[],\"text\":\"این شهروند توضیح داد: «برای نسخه ۱۰۰ عددی که مصرف یک ماهم بود، داروخانه فقط ۵۰ عدد به من تحویل داد. آن هم از نوع ایرانی که اثر نمونه‌های خارجی را ندارد.»\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"e748e971098e\",\"_type\":\"block\",\"children\":[{\"_key\":\"34e58236e049\",\"_type\":\"span\",\"marks\":[],\"text\":\"شمار دیگری از پیام‌های رسیده به ایران‌اینترنشنال نیز نشان می‌دهد کمبود داروهای مرتبط با اعصاب و روان باعث شده بیماران ناچار به تغییر برند دارویی شوند؛ اقدامی که به گفته بیماران، می‌تواند اثربخشی درمان را کاهش دهد.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"31a76ff19fbb\",\"_type\":\"block\",\"children\":[{\"_key\":\"8addfce64eb3\",\"_type\":\"span\",\"marks\":[],\"text\":\"یک بیمار در این زمینه گفت در طول درمان نباید برند دارو عوض شود، اما الان خیلی‌ها مجبورند این کار را انجام دهند.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"b72eb4fe4888\",\"_type\":\"block\",\"children\":[{\"_key\":\"310ac0349b40\",\"_type\":\"span\",\"marks\":[],\"text\":\"او توضیح داد به توصیه متخصص، حتما باید دارویش را از یک برند خارجی تهیه می‌کرد اما تاکنون سه ماه است که کپسول خارجی‌اش پیدا نمی‌شود و به ناچار، کپسول ایرانی می‌خرید.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"05821c11f014\",\"_type\":\"block\",\"children\":[{\"_key\":\"00c5367aee73\",\"_type\":\"span\",\"marks\":[],\"text\":\"این شهروند ادامه داد: «اما الان یک هفته است که همان هم پیدا نمی‌شود و فقط شکل قرصش را توانستم پیدا کنم که عوارض بیشتری دارد، اما مجبورم مصرف کنم.»\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"8010de0f395e\",\"_type\":\"block\",\"children\":[{\"_key\":\"7c4aa407a69a\",\"_type\":\"span\",\"marks\":[],\"text\":\"علی جعفریان، جانشین وزیر بهداشت، درمان و آموزش پزشکی، هشتم اردیبهشت «کمبود جدی» دارو را رد کرده و افزایش قیمت دارو را متاثر از تورم عمومی و نوسان بهای ارز آزاد خوانده بود.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"afaed41d69fb\",\"_type\":\"block\",\"children\":[{\"_key\":\"f1526b2c84c9\",\"_type\":\"span\",\"marks\":[],\"text\":\"او با اشاره به حذف ارز ترجیحی در سال ۱۴۰۴، گفته بود حدود ۷۰ درصد از قیمت تمام‌شده دارو به نرخ ارز آزاد وابسته است که اثر مستقیمی بر بازار دارویی دارد.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"001a344d2a6e\",\"_type\":\"figure\",\"asset\":{\"_ref\":\"image-33a17e690b9a7cd3c824eaaf10b1d9e553c2babe-1537x1023-png\",\"_type\":\"reference\"},\"sources\":{\"mobile\":{\"url\":\"https://i.iranintl.com/images/rdk9umy0/production/33a17e690b9a7cd3c824eaaf10b1d9e553c2babe-1537x1023.png?rect=2,0,1535,1023\u0026w=576\u0026h=384\u0026q=80\u0026fit=max\u0026auto=format\",\"aspectRatio\":\"3x2\",\"orientation\":\"landscape\"},\"tablet\":{\"url\":\"https://i.iranintl.com/images/rdk9umy0/production/33a17e690b9a7cd3c824eaaf10b1d9e553c2babe-1537x1023.png?rect=2,0,1535,1023\u0026w=768\u0026h=512\u0026q=80\u0026fit=max\u0026auto=format\",\"aspectRatio\":\"3x2\",\"orientation\":\"landscape\"},\"desktop\":{\"url\":\"https://i.iranintl.com/images/rdk9umy0/production/33a17e690b9a7cd3c824eaaf10b1d9e553c2babe-1537x1023.png?rect=2,0,1535,1023\u0026w=992\u0026h=661\u0026q=80\u0026fit=max\u0026auto=format\",\"aspectRatio\":\"3x2\",\"orientation\":\"landscape\"}}},{\"_key\":\"7e1cfccf556b\",\"_type\":\"block\",\"children\":[{\"_key\":\"8fe270c47cd9\",\"_type\":\"span\",\"marks\":[\"strong\"],\"text\":\"از تشدید افسردگی تا پیامدهای اجتماعی\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"0824fd05ea48\",\"_type\":\"block\",\"children\":[{\"_key\":\"9b6ae81e9c3b\",\"_type\":\"span\",\"marks\":[],\"text\":\"گزارش‌های رسیده نشان می‌دهند کمبود داروهای اعصاب علاوه بر اختلال در زندگی فردی، پیامدهای اجتماعی نیز به همراه داشته است.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"e4effc9f5dae\",\"_type\":\"block\",\"children\":[{\"_key\":\"10f7731cc1f4\",\"_type\":\"span\",\"marks\":[],\"text\":\"به‌گفته یک شهروند، مردی حدود ۵۰ ساله به دلیل اضطراب شدید توانایی تکلم خود را از دست داده و گفته با این حجم از فشار، تنها انگیزه‌اش از ادامه زندگی، تامین حداقل نیازهای خانواده‌اش است.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"4ddc955daf94\",\"_type\":\"block\",\"children\":[{\"_key\":\"bf18ac0e250a\",\"_type\":\"span\",\"marks\":[],\"text\":\"در نمونه‌ای دیگر، همکاران یک فرد شاغل در بخش خدماتی گفتند او به دلیل قطع دارو و هزینه بالای درمان، دچار تنش‌های شدید رفتاری شده و در محیط کار حتی درگیری‌های متعدد فیزیکی با کارکنان و مراجعان داشته است.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"935a186e429e\",\"_type\":\"block\",\"children\":[{\"_key\":\"fb199952e070\",\"_type\":\"span\",\"marks\":[],\"text\":\"به گفته فرد راوی، این شهروند تنها ۱۵ میلیون تومان حقوق می‌گیرد و با توجه به ویزیت یک میلیون تومانی و هزینه چند میلیونی دارو، دیگر به پزشک هم مراجعه نکرده است.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"ab91522b79f2\",\"_type\":\"block\",\"children\":[{\"_key\":\"ee5b415945a8\",\"_type\":\"span\",\"marks\":[],\"text\":\"برخی از گزارش‌ها نیز حاکی از نگرانی درباره وضعیت بیماران با اختلالات شدیدتر است.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"82254b60a6f2\",\"_type\":\"block\",\"children\":[{\"_key\":\"d6f8d49c5f06\",\"_type\":\"span\",\"marks\":[],\"text\":\"یک شهروند با اشاره به نامشخص بودن وضعیت داروهایی مانند رسپریدون و سایر داروهای ضد سایکوز گفت: «ما با افسردگی و اضطراب می‌سازیم، اما بیمارانی با مشکلات روانی حاد که بستری هستند و ممکن است به خود یا دیگران آسیب بزنند، چه می‌کنند؟»\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"8970f146e262\",\"_type\":\"block\",\"children\":[{\"_key\":\"d7171e42c6bb\",\"_type\":\"span\",\"marks\":[],\"text\":\"شهروندی نیز با اشاره به گسترش افسردگی و اضطراب در کشور، به کنایه گفت: «می‌دانم که قبلا هم بعضی‌ها به شوخی این را گفته‌اند، اما جدی فکر می‌کنم باید در آب لوله‌کشی شهرها آسنترا بریزند.»\"}],\"markDefs\":[],\"style\":\"normal\"}],\"categories\":[{\"id\":\"67bd595d-41c2-41e8-8ba7-42f76fd9e49e\",\"slug\":\"iran\",\"title\":\"ایران\",\"type\":\"category\"},{\"id\":\"8dc4aa1d-cc2c-45c4-9c0b-75f7b5dd53d3\",\"slug\":\"aqtsad\",\"title\":\"اقتصاد\",\"type\":\"supernews\"}],\"hasTextToSpeech\":true,\"headline\":\"برخی بیماران با گرانی و کمبود داروهای اعصاب، درمان را متوقف کرده‌اند\",\"id\":\"d7c45816-a24a-42c7-ae0c-392755d5e8bf\",\"image\":{\"alt\":null,\"asset\":{\"_ref\":\"image-4ca9796474ce6146e0ac61078a9a0acda5da684f-1537x1023-png\",\"_type\":\"reference\"},\"caption\":null,\"crop\":null,\"hotspot\":null,\"metadata\":{\"dimensions\":{\"height\":1023,\"width\":1537},\"lqip\":\"$51\"}},\"language\":\"farsi\",\"lead\":\"گزارش‌های رسیده به ایران‌اینترنشنال، حاکی از افزایش قیمت و همچنین کمبود داروهای اعصاب در هفته‌های اخیر است؛ وضعیتی که به گفته شهروندان و کارکنان داروخانه‌ها، بسیاری از بیماران را ناچار به حذف یا تغییر روند درمان کرده است.\",\"publishedAt\":\"2026-05-08T16:25:53.887Z\",\"revision\":null,\"shorthandUrl\":null,\"slug\":\"202605087975\",\"tags\":[{\"color\":\"#2300bc\",\"id\":\"705e189f-3134-48c9-aa90-7785892fbe87\",\"slug\":\"rwayt-shma\",\"title\":\"روایت شما\"}],\"type\":\"story\",\"updatedAt\":\"2026-05-08T16:27:12Z\"},{\"authors\":null,\"body\":[{\"_key\":\"932c9cb27c6b\",\"_type\":\"block\",\"children\":[{\"_key\":\"f0c3166bca62\",\"_type\":\"span\",\"marks\":[],\"text\":\"صدر جمعه ۱۸ اردیبهشت خواستار آن شد که گروه‌های مسلح یا در قالب تشکیلاتی با عنوان «سربازان شعائر دینی» زیر نظر هیات حج سازماندهی شوند یا به «نهادهای امدادرسان و بشردوستانه» تبدیل شوند.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"b0d7184f4bdb\",\"_type\":\"block\",\"children\":[{\"_key\":\"91783b580d21\",\"_type\":\"span\",\"marks\":[],\"text\":\"صدر همچنین بر حفظ استقلال عراق و دوری از هرگونه دخالت خارجی «نه شرقی و نه غربی» تاکید کرد و گفت دولت آینده باید خواسته‌های مردم عراق را برآورده کند.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"c3226620fe1f\",\"_type\":\"block\",\"children\":[{\"_key\":\"4d17d5866253\",\"_type\":\"span\",\"marks\":[],\"text\":\"او ادامه داد: «هیچ فردی از جریان صدر را در کابینه وزارتی نمی‌پذیریم و هیچ وزیری نماینده ما نخواهد بود.»\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"8e7df0651681\",\"_type\":\"block\",\"children\":[{\"_key\":\"4233e4042375\",\"_type\":\"span\",\"marks\":[\"strong\"],\"text\":\"گمانه‌زنی‌ها درباره کابینه آینده عراق\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"0b646e3930fc\",\"_type\":\"block\",\"children\":[{\"_key\":\"800a5b6bdd42\",\"_type\":\"span\",\"marks\":[],\"text\":\"در روزهای اخیر، گمانه‌زنی‌ها درباره ترکیب دولت آینده عراق بالا گرفته است.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"415b5d22ae96\",\"_type\":\"block\",\"children\":[{\"_key\":\"46903b89e48c\",\"_type\":\"span\",\"marks\":[],\"text\":\"۷ اردیبهشت، ائتلاف احزاب سیاسی شیعه عراق، «چارچوب هماهنگی»، اعلام کرد که علی الزیدی را به‌عنوان نامزد خود برای سمت نخست‌وزیری معرفی کرده است.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"bfd62835ac98\",\"_type\":\"inlinecontent\",\"stories\":[{\"headline\":\"شبه‌نظامیان وابسته به جمهوری اسلامی در عراق زیر فشار اسرائیل از خلع سلاح سخن می‌گویند\",\"id\":\"17b901d1-cc79-47f2-8a26-719287a612f8\",\"image\":{\"_type\":\"figure\",\"asset\":{\"_ref\":\"image-0d37dbf705d682207c3d2bd5fed87108c37e3360-992x558-png\",\"_type\":\"reference\"}},\"language\":\"farsi\",\"publishedAt\":\"2025-12-21T01:46:11.184Z\",\"slug\":\"202512213686\",\"type\":\"story\",\"updatedAt\":null}]},{\"_key\":\"b830013d88e9\",\"_type\":\"block\",\"children\":[{\"_key\":\"322354a56157\",\"_type\":\"span\",\"marks\":[],\"text\":\"پس از این اعلام، نمایندگان شیعه به رویترز گفتند که رییس‌جمهور عراق، نزار آمیدی، از الزیدی، دعوت کرد تا دولت را تشکیل دهد.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"4dc694f4bcfa\",\"_type\":\"block\",\"children\":[{\"_key\":\"56b9a0047de3\",\"_type\":\"span\",\"marks\":[],\"text\":\"بر اساس قانون اساسی عراق، الزیدی ۳۰ روز فرصت دارد تا کابینه خود را تشکیل دهد و آن را برای تایید به پارلمان معرفی کند.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"9d202caf5fa3\",\"_type\":\"block\",\"children\":[{\"_key\":\"800a5b6bdd42\",\"_type\":\"span\",\"marks\":[],\"text\":\"یک مقام ارشد وزارت امور خارجه آمریکا  \"},{\"_key\":\"d2dbb255db46\",\"_type\":\"span\",\"marks\":[\"78906673c606\"],\"text\":\"۱۶ اردیبهشت، اعلام کرد\"},{\"_key\":\"00f585fae144\",\"_type\":\"span\",\"marks\":[],\"text\":\" واشینگتن از نخست‌وزیر عراق انتظار دارد برای محدود کردن نفوذ گروه‌های مسلح نزدیک به جمهوری اسلامی، «اقدام‌های عملی» انجام دهد.\"}],\"markDefs\":[{\"_key\":\"78906673c606\",\"_type\":\"link\",\"href\":\"https://www.iranintl.com/fa/202605065648\"}],\"style\":\"normal\"},{\"_key\":\"bf98bcdb4469\",\"_type\":\"block\",\"children\":[{\"_key\":\"b0cccec47fa1\",\"_type\":\"span\",\"marks\":[],\"text\":\"این مقام آمریکایی که نامش فاش نشده، گفت آمریکا خواهان پایان دادن به «مرز مبهم» میان دولت عراق و گروه‌های مسلح شیعه مورد حمایت جمهوری اسلامی است.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"1bec4454721a\",\"_type\":\"block\",\"children\":[{\"_key\":\"d84a78e14937\",\"_type\":\"span\",\"marks\":[],\"text\":\"به گفته او، ازسرگیری کامل حمایت‌های آمریکا از عراق، از جمله انتقال منابع مالی حاصل از فروش نفت و کمک‌های امنیتی، منوط به اقدام‌هایی مانند اخراج «شبه‌نظامیان تروریستی» از نهادهای دولتی، قطع بودجه این گروه‌ها و توقف پرداخت حقوق به نیروهای وابسته به آن‌ها است.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"535acb327b0c\",\"_type\":\"inlinecontent\",\"stories\":[{\"headline\":\"آمریکا چهار گروه نیابتی جمهوری اسلامی در عراق را تروریستی اعلام کرد\",\"id\":\"977ea23d-fe7b-4a82-8845-2d00624371c2\",\"image\":{\"_type\":\"figure\",\"asset\":{\"_ref\":\"image-2d5a4c697db7525eb41464115bbc3673c0443f85-800x566-png\",\"_type\":\"reference\"},\"crop\":{\"_type\":\"sanity.imageCrop\",\"bottom\":0,\"left\":0,\"right\":0,\"top\":0.07125727989037342},\"hotspot\":{\"_type\":\"sanity.imageHotspot\",\"height\":0.9287427201096266,\"width\":1,\"x\":0.5,\"y\":0.5356286399451867}},\"language\":\"farsi\",\"publishedAt\":\"2025-09-17T13:21:39.279Z\",\"slug\":\"202509177719\",\"type\":\"story\",\"updatedAt\":null}]},{\"_key\":\"44e9b9d9a8f0\",\"_type\":\"block\",\"children\":[{\"_key\":\"c74ce1c1fa4b\",\"_type\":\"span\",\"marks\":[],\"text\":\"این مقام آمریکایی تاکید کرد: «این‌ها اقدام‌های عملی هستند که می‌توانند به ما نشان دهند ذهنیت جدیدی در عراق شکل گرفته است.»\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"57dbe4176688\",\"_type\":\"block\",\"children\":[{\"_key\":\"0015dce9d6be\",\"_type\":\"span\",\"marks\":[\"strong\"],\"text\":\"ترامپ: دولت جدید عراق باید «عاری از تروریسم» باشد\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"7147fa030755\",\"_type\":\"block\",\"children\":[{\"_key\":\"0ec83b6f4aa1\",\"_type\":\"span\",\"marks\":[],\"text\":\"الزیدی پس از معرفی شدن به‌عنوان گزینه نخست‌وزیری عراق، تماس تبریکی از ترامپ دریافت کرد.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"4d1641830732\",\"_type\":\"block\",\"children\":[{\"_key\":\"0015dce9d6be\",\"_type\":\"span\",\"marks\":[],\"text\":\"ترامپ در پیام خود ابراز امیدواری کرد دولت جدید عراق «عاری از تروریسم» باشد و فصل تازه‌ای در روابط بغداد و واشینگتن آغاز شود.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"42cc82715ad5\",\"_type\":\"block\",\"children\":[{\"_key\":\"e0cc8d02736d\",\"_type\":\"span\",\"marks\":[],\"text\":\"در ماه‌های اخیر، گروه‌های مسلح در عراق، سفارت آمریکا در بغداد، تاسیسات دیپلماتیک و لجستیکی آمریکا در فرودگاه بغداد و همچنین میدان‌های نفتی متعلق به شرکت‌های خارجی را هدف قرار داده‌اند.\"}],\"markDefs\":[],\"style\":\"normal\"}],\"categories\":[{\"id\":\"67bd595d-41c2-41e8-8ba7-42f76fd9e49e\",\"slug\":\"iran\",\"title\":\"ایران\",\"type\":\"category\"}],\"hasTextToSpeech\":true,\"headline\":\"مقتدی صدر: گروه‌های مسلح نباید در دولت آینده عراق حضور داشته باشند\",\"id\":\"46d86d5b-8fea-4eaf-bb1a-e3d041f81f45\",\"image\":{\"alt\":null,\"asset\":{\"_ref\":\"image-4ae00dc5ebf58ab4094b574210fb2940aeafff6b-1192x1018-jpg\",\"_type\":\"reference\"},\"caption\":null,\"crop\":{\"_type\":\"sanity.imageCrop\",\"bottom\":0.2604034871201803,\"left\":0,\"right\":0,\"top\":0},\"hotspot\":{\"_type\":\"sanity.imageHotspot\",\"height\":0.5179767597926067,\"width\":0.5315470574231577,\"x\":0.5,\"y\":0.3697982564399098},\"metadata\":{\"dimensions\":{\"height\":1018,\"width\":1192},\"lqip\":\"data:image/jpeg;base64,\"}},\"language\":\"farsi\",\"lead\":\"مقتدی صدر، رهبر جریان صدر، در پیامی خطاب به علی الزیدی، نخست‌وزیر مکلف به تشکیل دولت جدید در عراق، تاکید کرد «افراد یا جریان‌های دارای شاخه مسلح» نباید در کابینه آینده این کشور حضور داشته باشند.\",\"publishedAt\":\"2026-05-08T14:58:43.237Z\",\"revision\":null,\"shorthandUrl\":null,\"slug\":\"202605084373\",\"tags\":null,\"type\":\"story\",\"updatedAt\":\"2026-05-08T14:58:53Z\"},{\"authors\":null,\"body\":[{\"_key\":\"b5e09364c211\",\"_type\":\"block\",\"children\":[{\"_key\":\"5b785776c9c9\",\"_type\":\"span\",\"marks\":[],\"text\":\"روبیو که به ایتالیا سفر کرده، جمعه ۱۸ اردیبهشت هشدار داد اگر تهران به کشتی‌های نیروی دریایی آمریکا حمله کند نیروهای جمهوری اسلامی نابود خواهند شد.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"ad247b7d27be\",\"_type\":\"block\",\"children\":[{\"_key\":\"54f6605da5f4\",\"_type\":\"span\",\"marks\":[],\"text\":\"روبیو در پایان یک سفر دو روزه برای ترمیم روابط در رم و واتیکان به پرسش‌های خبرنگاران پاسخ می‌داد؛ سفری که پس از اختلافات شدید درباره جنگ آمریکا و اسرائیل علیه جمهوری اسلامی و انتقادهای دونالد ترامپ، رییس‌جمهوری آمریکا، از پاپ لئو چهاردهم انجام شد.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"ff5b96f3c507\",\"_type\":\"block\",\"children\":[{\"_key\":\"ad0947541269\",\"_type\":\"span\",\"marks\":[],\"text\":\"از او درباره گزارش‌های یک شرکت داده‌های کشتی‌رانی پرسیده شد که گفته بود جمهوری اسلامی یک نهاد دولتی جدید ایجاد کرده است تا عبور کشتی‌ها از این تنگه را بررسی و مشمول مالیات کند.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"c2b46b9adba9\",\"_type\":\"block\",\"children\":[{\"_key\":\"6127c8188d0c\",\"_type\":\"span\",\"marks\":[],\"text\":\"روبیو پرسید: «آیا جهان قرار است بپذیرد که ایران اکنون یک آبراه بین‌المللی را کنترل کند؟ جهان برای انجام چه کاری آماده است؟»\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"a47bfda5a163\",\"_type\":\"block\",\"children\":[{\"_key\":\"1947e5d37739\",\"_type\":\"span\",\"marks\":[],\"text\":\"پیشتر رسانه‌های بین‌المللی \"},{\"_key\":\"80f13cf3859a\",\"_type\":\"span\",\"marks\":[\"7a136dfab523\"],\"text\":\"به نقل از داده‌های کشتی‌رانی گزارش دادند\"},{\"_key\":\"49ce5fc83f53\",\"_type\":\"span\",\"marks\":[],\"text\":\" که جمهوری اسلامی نهاد جدیدی را برای کنترل کشتی‌رانی در تنگه هرمز ایجاد کرده است.\"}],\"markDefs\":[{\"_key\":\"7a136dfab523\",\"_type\":\"link\",\"href\":\"https://www.iranintl.com/fa/202605071065\"}],\"style\":\"normal\"},{\"_key\":\"8043f13c00dd\",\"_type\":\"block\",\"children\":[{\"_key\":\"313fdfe9bd5b\",\"_type\":\"span\",\"marks\":[],\"text\":\"آسوشیتدپرس پنج‌شنبه ۱۷ اردیبهشت به‌نقل از شرکت داده‌های کشتی‌رانی«لوییدز لیست اینتلیجنس» گزارش داد که این نهاد که «سازمان تنگه خلیج فارس» نام دارد و «خود را به‌عنوان تنها مرجع معتبر برای صدور مجوز عبور کشتی‌ها در تنگه هرمز» معرفی می‌کند.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"b8d56b12bf39\",\"_type\":\"block\",\"children\":[{\"_key\":\"86236984c581\",\"_type\":\"span\",\"marks\":[\"strong\"],\"text\":\"هشدار درباره حمله به نیروی دریایی این کشور\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"5e1cc4a9f0c9\",\"_type\":\"block\",\"children\":[{\"_key\":\"313fdfe9bd5b\",\"_type\":\"span\",\"marks\":[],\"text\":\"روبیو همچنین به تهران درباره حمله به دارایی‌های دریایی آمریکا در منطقه هشدار داد.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"5106902fa131\",\"_type\":\"block\",\"children\":[{\"_key\":\"313fdfe9bd5b\",\"_type\":\"span\",\"marks\":[],\"text\":\" ایالات متحده اعلام کرد که سه حمله علیه کشتی‌های نیروی دریایی در تنگه هرمز را خنثی کرده است.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"5e969fa355d4\",\"_type\":\"block\",\"children\":[{\"_key\":\"ad357a5257fb\",\"_type\":\"span\",\"marks\":[],\"text\":\"او گفت: «خط قرمز روشن است. اگر آمریکایی‌ها را تهدید کنند، منفجر خواهند شد.»\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"00ee738b9561\",\"_type\":\"block\",\"children\":[{\"_key\":\"ba7c707d44b6\",\"_type\":\"span\",\"marks\":[],\"text\":\"وزیر امور خارجه آمریکا در ادامه تاکید کرد که حملات ۱۷ اردیبهشت ارتباطی با عملیات «خشم حماسی» نداشته است.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"28a0cadbe11b\",\"_type\":\"block\",\"children\":[{\"_key\":\"edd154bcbf26\",\"_type\":\"span\",\"marks\":[],\"text\":\"روبیو گفت که قرار است جمعه ۱۸ اردیبهشت پاسخ جمهوری اسلامی به طرح پیشنهادی صلح به واشینگتن ارائه شود.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"22ec9e1b6f9c\",\"_type\":\"block\",\"children\":[{\"_key\":\"5aff5c1ab8bc\",\"_type\":\"span\",\"marks\":[],\"text\":\"او ابراز امیدواری کرد این پاسخ «جدی» باشد و بتواند مسیر ورود به یک فرآیند مذاکراتی واقعی را باز کند.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"6bfbafd112ef\",\"_type\":\"block\",\"children\":[{\"_key\":\"74da19bf994e\",\"_type\":\"span\",\"marks\":[\"strong\"],\"text\":\"دیدار با پاپ و انتقاد از حزب‌الله\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"cb8b7578ef52\",\"_type\":\"block\",\"children\":[{\"_key\":\"8f838969f1df\",\"_type\":\"span\",\"marks\":[],\"text\":\"روبیو همچنین به دیدار خود با پاپ لئو در ۱۷ اردیبهشت اشاره کرد و گفت این دیدار «بسیار مثبت» بوده است.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"00dbca47365a\",\"_type\":\"block\",\"children\":[{\"_key\":\"36e027c26196\",\"_type\":\"span\",\"marks\":[],\"text\":\"واتیکان پنج‌شنبه ۱۷اردیبهشت در بیانیه‌ای پس از نخستین دیدار میان پاپ لئو و یکی از اعضای کابینه ترامپ در نزدیک به یک سال گذشته، اعلام کرد که لئو و روبیو «تعهد مشترک خود را برای تقویت روابط دوجانبه خوب» تجدید کردند.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"ed072d82e004\",\"_type\":\"inlinecontent\",\"stories\":[{\"headline\":\"پاپ لئو و روبیو بر تقویت روابط واتیکان و واشینگتن تاکید کردند\",\"id\":\"87e382fd-cd96-41ba-9c35-2c61d73b3b87\",\"image\":{\"_type\":\"image\",\"asset\":{\"_ref\":\"image-f19a95da3bd0db9d3ef7af3232c96fb7c3fb0e43-7087x4725-jpg\",\"_type\":\"reference\"}},\"language\":\"farsi\",\"publishedAt\":\"2026-05-07T19:23:19.724Z\",\"slug\":\"202605072756\",\"type\":\"story\",\"updatedAt\":null}]},{\"_key\":\"5abb82838109\",\"_type\":\"block\",\"children\":[{\"_key\":\"cc6ec55acc36\",\"_type\":\"span\",\"marks\":[],\"text\":\"لئو، نخستین پاپ آمریکایی، پس از آنکه به \"},{\"_key\":\"035658b923ba\",\"_type\":\"span\",\"marks\":[\"159e96a7e7c5\"],\"text\":\"منتقدی جدی\"},{\"_key\":\"c3946ec68e90\",\"_type\":\"span\",\"marks\":[],\"text\":\" در زمینه جنگ آمریکا و اسرائیل علیه جمهوری اسلامی و نیز سیاست‌های سخت‌گیرانه ضدمهاجرتی دولت ترامپ تبدیل شد، انتقادهای ترامپ را برانگیخت و این انتقادها واکنش منفی رهبران مسیحی از طیف‌های مختلف سیاسی را در پی داشت.\"}],\"markDefs\":[{\"_key\":\"159e96a7e7c5\",\"_type\":\"link\",\"href\":\"https://www.iranintl.com/202604101687\"}],\"style\":\"normal\"},{\"_key\":\"1eea2b14515c\",\"_type\":\"block\",\"children\":[{\"_key\":\"5b785776c9c9\",\"_type\":\"span\",\"marks\":[],\"text\":\"وزیر امور خارجه آمریکا در خصوص مذاکرات با دولت لبنان نیز گفت: «ما می‌خواهیم دولت مشروع لبنان قوی باشد و حزب‌الله مانعی برای این امر است.»\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"bda893ef0e8d\",\"_type\":\"block\",\"children\":[{\"_key\":\"930bee962aec\",\"_type\":\"span\",\"marks\":[],\"text\":\"روبیو ادامه داد: «حزب‌الله کاملا یک نیروی نیابتی جمهوری اسلامی است و بدون آنها وجود نخواهد داشت.»\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"554b33c413e3\",\"_type\":\"block\",\"children\":[{\"_key\":\"7c8844ce876f\",\"_type\":\"span\",\"marks\":[],\"text\":\"روبیو افزود: «ما در تلاشیم تا تامین مالی حزب‌الله را متوقف کنیم.»\"}],\"markDefs\":[],\"style\":\"normal\"}],\"categories\":[{\"id\":\"c4f6cf29-2688-4b26-8595-a02c0ffd0cf1\",\"slug\":\"hmlh-aamryka-w-asraeyl-bh-jmhwry-aslamy\",\"title\":\"جنگ علیه جمهوری اسلامی\",\"type\":\"supernews\"},{\"id\":\"67bd595d-41c2-41e8-8ba7-42f76fd9e49e\",\"slug\":\"iran\",\"title\":\"ایران\",\"type\":\"category\"}],\"hasTextToSpeech\":true,\"headline\":\"وزیر امور خارجه آمریکا: کنترل جمهوری اسلامی بر تنگه هرمز را نخواهیم پذیرفت\",\"id\":\"d8aa11b1-8522-4d0d-b594-b7483b57329d\",\"image\":{\"alt\":null,\"asset\":{\"_ref\":\"image-3471750a5494d00163a7a2ef27d816642bea735f-8207x5469-jpg\",\"_type\":\"reference\"},\"caption\":null,\"crop\":null,\"hotspot\":null,\"metadata\":{\"dimensions\":{\"height\":5469,\"width\":8207},\"lqip\":\"data:image/jpeg;base64,\"}},\"language\":\"farsi\",\"lead\":\"مارکو روبیو، وزیر امور خارجه ایالات متحده، اعلام کرد که این کشور کنترل جمهوری اسلامی بر تنگه هرمز را نخواهد پذیرفت. او همچنین گفت که همه کشورها موافقند که داشتن سلاح هسته‌ای از سوی جمهوری اسلامی «غیرقابل قبول است.»\",\"publishedAt\":\"2026-05-08T14:16:33.883Z\",\"revision\":null,\"shorthandUrl\":null,\"slug\":\"202605082560\",\"tags\":null,\"type\":\"story\",\"updatedAt\":\"2026-05-08T14:16:37Z\"},{\"authors\":null,\"body\":[{\"_key\":\"51fcc931a653\",\"_type\":\"block\",\"children\":[{\"_key\":\"38c9b2150cec\",\"_type\":\"span\",\"marks\":[],\"text\":\"بر اساس گزارشی که ارم‌نیوز جمعه ۱۸ اردیبهشت منتشر کرد، در فرمول مطرح‌شده برای تفاهم میان تهران و واشینگتن، اولویت با توقف درگیری‌ها، رسیدگی به بحران تنگه هرمز و آغاز یک مسیر مذاکراتی کوتاه‌مدت است و موضوعاتی مانند برنامه هسته‌ای حکومت ایران، توان موشکی و نفوذ منطقه‌ای جمهوری اسلامی، به مراحل بعدی منتقل شده‌اند.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"fd90768e8d86\",\"_type\":\"block\",\"children\":[{\"_key\":\"bac4ab280d73\",\"_type\":\"span\",\"marks\":[],\"text\":\"منابع دیپلماتیک منطقه‌ای به ارم‌نیوز گفته‌اند این طرح پس از دو تحول همزمان در ساعات اخیر شکل گرفته است. از جمله این تحولات، توقف موقت عملیات «پروژه آزادی» از سوی دونالد ترامپ، رییس‌جمهوری آمریکا، برای اسکورت کشتی‌ها در تنگه هرمز بوده است.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"150f5e70bf48\",\"_type\":\"inlinevideo\",\"video\":{\"id\":\"ott_4b245868cc8045c48494c822f4ecfdbb\",\"youtubeId\":null,\"outlet\":\"iitv\"}},{\"_key\":\"aac9e9e23202\",\"_type\":\"block\",\"children\":[{\"_key\":\"d93348295b8a\",\"_type\":\"span\",\"marks\":[],\"text\":\"به گفته این منابع، تمرکز واشینگتن بر موضوعات فوری و قابل سنجش در کوتاه‌مدت، از جمله امنیت کشتیرانی و توقف درگیری‌ها، باعث شده است اسرائیل در ساز و کار اجرایی مرحله نخست نقشی نداشته باشد. \"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"3f1e2838ee42\",\"_type\":\"block\",\"children\":[{\"_key\":\"d93348295b8a\",\"_type\":\"span\",\"marks\":[],\"text\":\"با این حال، هماهنگی‌های سیاسی و امنیتی میان آمریکا و اسرائیل همچنان ادامه دارد.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"f98d3200afe7\",\"_type\":\"block\",\"children\":[{\"_key\":\"2c63664a7756\",\"_type\":\"span\",\"marks\":[],\"text\":\"گیلا گاملیل، وزیر علوم و فناوری اسرائیل، ۱۷ اردیبهشت \"},{\"_key\":\"2ac9aa3193b7\",\"_type\":\"span\",\"marks\":[\"949b88fde575\"],\"text\":\"گفت\"},{\"_key\":\"7a56ebf1317d\",\"_type\":\"span\",\"marks\":[],\"text\":\" که بنیامین نتانیاهو، نخست‌وزیر اسرائیل، و ترامپ درباره مذاکرات با جمهوری اسلامی به طور مداوم گفت‌وگو می‌کنند و موضوع هسته‌ای از اهداف مشترک دو طرف است.\"}],\"markDefs\":[{\"_key\":\"949b88fde575\",\"_type\":\"link\",\"href\":\"https://www.iranintl.com/fa/202605077471\"}],\"style\":\"normal\"},{\"_key\":\"75e6411b7048\",\"_type\":\"block\",\"children\":[{\"_key\":\"aa94a97bb34a\",\"_type\":\"span\",\"marks\":[],\"text\":\"رسانه‌های اسرائیلی نیز تایید کردند نتانیاهو در جریان این روند قرار دارد و گفته است این تحولات برای او غافلگیرکننده نبوده و هماهنگی‌ها با واشینگتن به‌صورت مستمر ادامه دارد.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"2bdfac0433a8\",\"_type\":\"inlinecontent\",\"stories\":[{\"headline\":\"نتانیاهو: برای تهدیدکنندگان اسرائیل هیچ مصونیتی وجود ندارد\",\"id\":\"c23fd02d-7f54-42a8-9077-dd433a844dfe\",\"image\":{\"_type\":\"image\",\"asset\":{\"_ref\":\"image-06bb6466cc08a7eb98a9db8732f4006ae1050662-960x640-jpg\",\"_type\":\"reference\"},\"crop\":{\"_type\":\"sanity.imageCrop\",\"bottom\":0.011160853170884,\"left\":0.05540560380789945,\"right\":0,\"top\":0},\"hotspot\":{\"_type\":\"sanity.imageHotspot\",\"height\":0.988839146829116,\"width\":0.9445943961921005,\"x\":0.5277028019039497,\"y\":0.494419573414558}},\"language\":\"farsi\",\"publishedAt\":\"2026-05-07T14:10:45.083Z\",\"slug\":\"202605071913\",\"type\":\"story\",\"updatedAt\":null}]},{\"_key\":\"93164338e4a5\",\"_type\":\"block\",\"children\":[{\"_key\":\"24cae7739f42\",\"_type\":\"span\",\"marks\":[],\"text\":\"در این چارچوب، واشینگتن تلاش دارد مرحله نخست را بر پایه اقداماتی تنظیم کند که در کوتاه‌مدت قابل اجرا و ارزیابی باشند و سپس موضوعات پیچیده‌تر را به مذاکرات بعدی منتقل کند. رویکردی که جایگاه اسرائیل را در سطح هماهنگی‌های راهبردی حفظ کرده اما آن را از متن اجرای اولیه کنار گذاشته است.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"0291caef1a95\",\"_type\":\"block\",\"children\":[{\"_key\":\"e0e974627e23\",\"_type\":\"span\",\"marks\":[],\"text\":\"در این میان، برخی تحلیلگران معتقدند اسرائیل همچنان بر لزوم اعمال شروط سخت‌گیرانه‌تر در موضوعاتی مانند غنی‌سازی، برنامه موشکی و ساز و کار اجرای توافق تاکید دارد.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"935849186fd3\",\"_type\":\"block\",\"children\":[{\"_key\":\"42eed1c776be\",\"_type\":\"span\",\"marks\":[],\"text\":\"واکنش بازارهای جهانی به احتمال کاهش تنش سریع بوده است. \"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"a519d0d4c8c6\",\"_type\":\"block\",\"children\":[{\"_key\":\"42eed1c776be\",\"_type\":\"span\",\"marks\":[],\"text\":\"گزارش‌ها حاکی از کاهش قیمت نفت و افزایش شاخص‌های سهام در پی کاهش نگرانی‌ها از اختلال در تردد از تنگه هرمز است.\"}],\"markDefs\":[],\"style\":\"normal\"}],\"categories\":[{\"id\":\"c4f6cf29-2688-4b26-8595-a02c0ffd0cf1\",\"slug\":\"hmlh-aamryka-w-asraeyl-bh-jmhwry-aslamy\",\"title\":\"جنگ علیه جمهوری اسلامی\",\"type\":\"supernews\"},{\"id\":\"67bd595d-41c2-41e8-8ba7-42f76fd9e49e\",\"slug\":\"iran\",\"title\":\"ایران\",\"type\":\"category\"},{\"id\":\"aaab5f90-9af2-487e-a259-d2b2ec9a09dd\",\"slug\":\"world\",\"title\":\"جهان\",\"type\":\"category\"}],\"hasTextToSpeech\":true,\"headline\":\"ارم‌نیوز: یادداشت تفاهم تهران و واشینگتن توافقی جامع نیست و بر کاهش تنش‌ها تمرکز دارد\",\"id\":\"71689f6d-40c1-4093-ab35-2d3a465ee5f4\",\"image\":{\"alt\":null,\"asset\":{\"_ref\":\"image-07c8375bf238eb643e8246660086bf9cb4bbb75a-1920x1080-png\",\"_type\":\"reference\"},\"caption\":null,\"crop\":{\"_type\":\"sanity.imageCrop\",\"bottom\":0,\"left\":0.0317845943384412,\"right\":0.01869698029744349,\"top\":0},\"hotspot\":{\"_type\":\"sanity.imageHotspot\",\"height\":0.7872716797365119,\"width\":0.869122045141938,\"x\":0.5,\"y\":0.39363583986825595},\"metadata\":{\"dimensions\":{\"height\":1080,\"width\":1920},\"lqip\":\"$52\"}},\"language\":\"farsi\",\"lead\":\"رسانه مستقر در امارات متحده عربی نوشت که چارچوب تفاهم‌نامه مطرح‌شده میان آمریکا و جمهوری اسلامی، بیشتر یک توافق محدود برای مهار تنش است که بر توقف درگیری‌ها، بازگشایی تنگه هرمز و آغاز مذاکرات کوتاه‌مدت تمرکز دارد و مسائل کلیدی، به مراحل بعدی موکول شده‌اند.\",\"publishedAt\":\"2026-05-08T11:46:36.631Z\",\"revision\":null,\"shorthandUrl\":null,\"slug\":\"202605088965\",\"tags\":null,\"type\":\"story\",\"updatedAt\":\"2026-05-08T11:46:46Z\"}],\"allowSlugTitleChange\":true,\"translations\":{\"sectionTitle\":\"مطالب بیشتر\",\"loadMore\":\"بارگذاری بیشتر\",\"loading\":\"در حال بارگذاری...\",\"currentArticle\":\"این مقاله\",\"share\":\"common.share\"}}]\n"])</script><script>(function(){function c(){var b=a.contentDocument||a.contentWindow.document;if(b){var d=b.createElement('script');d.innerHTML="window.__CF$cv$params={r:'9f8b12b26a89aefe',t:'MTc3ODI3MDY2MQ=='};var a=document.createElement('script');a.src='/cdn-cgi/challenge-platform/scripts/jsd/main.js';document.getElementsByTagName('head')[0].appendChild(a);";b.getElementsByTagName('head')[0].appendChild(d)}}if(document.body){var a=document.createElement('iframe');a.height=1;a.width=1;a.style.position='absolute';a.style.top=0;a.style.left=0;a.style.border='none';a.style.visibility='hidden';document.body.appendChild(a);if('loading'!==document.readyState)c();else if(window.addEventListener)document.addEventListener('DOMContentLoaded',c);else{var e=document.onreadystatechange||function(){};document.onreadystatechange=function(b){e(b);'loading'!==document.readyState&&(document.onreadystatechange=e,c())}}}})();</script></body></html>