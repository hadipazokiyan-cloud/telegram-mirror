Ntm5zeBm2tyBT2ZCw","params":"EgVwb3N0c8oEAhgC8gYJCgdKAKIBAggB"}},"content":{"horizontalListRenderer":{"items":[{"postRenderer":{"postId":"UgkxPhttGZZczYP7usBLNBHDbwZ9cFNEZ6bp","authorText":{"runs":[{"text":" مازیار در اروپا","navigationEndpoint":{"clickTrackingParams":"CDwQxKEDGAAiEwi065CjvqqUAxWtIC8IHa10B5jKAQT4afeC","commandMetadata":{"webCommandMetadata":{"url":"/@MaziarEurope","webPageType":"WEB_PAGE_TYPE_CHANNEL","rootVe":3611,"apiUrl":"/youtubei/v1/browse"}},"browseEndpoint":{"browseId":"UCFDmWINtm5zeBm2tyBT2ZCw","canonicalBaseUrl":"/@MaziarEurope"}}}],"accessibility":{"accessibilityData":{"label":" مازیار در اروپا"}}},"authorThumbnail":{"thumbnails":[{"url":"//yt3.googleusercontent.com/9-bU_B2hhbaCkHvihBMiCClEaBLYurGTFr0vDfUiUcxKERkXE0vy-Z58FqHNm0EVfqHvenODfQ=s32-c-k-c0x00ffffff-no-rj-mo","width":32,"height":32},{"url":"//yt3.googleusercontent.com/9-bU_B2hhbaCkHvihBMiCClEaBLYurGTFr0vDfUiUcxKERkXE0vy-Z58FqHNm0EVfqHvenODfQ=s48-c-k-c0x00ffffff-no-rj-mo","width":48,"height":48},{"url":"//yt3.googleusercontent.com/9-bU_B2hhbaCkHvihBMiCClEaBLYurGTFr0vDfUiUcxKERkXE0vy-Z58FqHNm0EVfqHvenODfQ=s76-c-k-c0x00ffffff-no-rj-mo","width":76,"height":76}],"accessibility":{"accessibilityData":{"label":" مازیار در اروپا"}}},"authorEndpoint":{"clickTrackingParams":"CDwQxKEDGAAiEwi065CjvqqUAxWtIC8IHa10B5jKAQT4afeC","commandMetadata":{"webCommandMetadata":{"url":"/@MaziarEurope","webPageType":"WEB_PAGE_TYPE_CHANNEL","rootVe":3611,"apiUrl":"/youtubei/v1/browse"}},"browseEndpoint":{"browseId":"UCFDmWINtm5zeBm2tyBT2ZCw","canonicalBaseUrl":"/@MaziarEurope"}},"contentText":{"runs":[{"text":"مراسم افتتاحیه کریسمس در هلسینکی دیروز برای هفتاد و هفتمین بار با روشن شدن چراغ‌های خیابان الکسانترینکاتو برگزار می‌شود؛ رویدادی پر از نور، موسیقی و حال‌وهوای جادویی. رژه بزرگ از ساعت ۱۶:۰۰ در میدان سنا آغاز شده و پس از عبور از خیابان‌های اصلی شهر، دوباره به همان‌جا بازمی‌گردد؛ مسیری که حدود یک ساعت طول می‌کشد و پر از شخصیت‌های شاد، حیوانات، گروه‌های رقص و حضور مهمان ویژه کریسمس خواهد بود.\n\n\r\n\r\nشهردار دانیل سازونوف این مراسم را رهبری می‌کند و همه را به تماشای روشن شدن چراغ‌ها و لذت بردن از فضای جشن دعوت کرده است. در کنار آن، خیابان کِسکوسکاتو هم به خیابان نیکوکاری تبدیل می‌شود و ایستگاه‌های خیریه و محل جمع‌آوری اسباب‌بازی برای خانواده‌های نیازمند برپا خواهد بود. 🎄✨\n"},{"text":"#فنلاند","navigationEndpoint":{"clickTrackingParams":"CEkQhPIEGAIiEwi065CjvqqUAxWtIC8IHa10B5jKAQT4afeC","commandMetadata":{"webCommandMetadata":{"url":"/hashtag/%D9%81%D9%86%D9%84%D8%A7%D9%86%D8%AF","webPageType":"WEB_PAGE_TYPE_BROWSE","rootVe":6827,"apiUrl":"/youtubei/v1/browse"}},"browseEndpoint":{"browseId":"FEhashtag","params":"6gUQCgzZgdmG2YTYp9mG2K8YAQ%3D%3D"}},"loggingDirectives":{"trackingParams":"CEkQhPIEGAIiEwi065CjvqqUAxWtIC8IHa10B5g=","visibility":{"types":"12"}}},{"text":" "},{"text":"#هلسینکی","navigationEndpoint":{"clickTrackingParams":"CEgQhPIEGAQiEwi065CjvqqUAxWtIC8IHa10B5jKAQT4afeC","commandMetadata":{"webCommandMetadata":{"url":"/hashtag/%D9%87%D9%84%D8%B3%DB%8C%D9%86%DA%A9%DB%8C","webPageType":"WEB_PAGE_TYPE_BROWSE","rootVe":6827,"apiUrl":"/youtubei/v1/browse"}},"browseEndpoint":{"browseId":"FEhashtag","params":"6gUSCg7Zh9mE2LPbjNmG2qnbjBgB"}},"loggingDirectives":{"trackingParams":"CEgQhPIEGAQiEwi065CjvqqUAxWtIC8IHa10B5g=","visibility":{"types":"12"}}},{"text":" "},{"text":"#مازیار_استوی","navigationEndpoint":{"clickTrackingParams":"CEcQhPIEGAYiEwi065CjvqqUAxWtIC8IHa10B5jKAQT4afeC","commandMetadata":{"webCommandMetadata":{"url":"/hashtag/%D9%85%D8%A7%D8%B2%DB%8C%D8%A7%D8%B1_%D8%A7%D8%B3%D8%AA%D9%88%DB%8C","webPageType":"WEB_PAGE_TYPE_BROWSE","rootVe":6827,"apiUrl":"/youtubei/v1/browse"}},"browseEndpoint":{"browseId":"FEhashtag","params":"6gUbChfZhdin2LLbjNin2LFf2KfYs9iq2YjbjBgB"}},"loggingDirectives":{"trackingParams":"CEcQhPIEGAYiEwi065CjvqqUAxWtIC8IHa10B5g=","visibility":{"types":"12"}}}]},"backstageAttachment":{"backstageImageRenderer":{"image":{"thumbnails":[{"url":"https://yt3.ggpht.com/u_6EIUo1c9vruTELINHVi_Sieu8lgFLpHJ5prkX3mOgBB3IeNzTTspL50QUOioRvpRgoFGso