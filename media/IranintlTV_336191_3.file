_skeletonText Skeleton-module-scss-module__u3hcSa__normal\",\"style\":\"$undefined\",\"aria-hidden\":\"true\"}],[\"$\",\"div\",\"3\",{\"className\":\"Skeleton-module-scss-module__u3hcSa__skeletonText Skeleton-module-scss-module__u3hcSa__normal\",\"style\":\"$undefined\",\"aria-hidden\":\"true\"}],[\"$\",\"div\",\"4\",{\"className\":\"Skeleton-module-scss-module__u3hcSa__skeletonText Skeleton-module-scss-module__u3hcSa__normal\",\"style\":\"$undefined\",\"aria-hidden\":\"true\"}]]}]}],[\"$\",\"div\",null,{\"className\":\"RelatedArticleSkeleton-module-scss-module__wrOvWa__skeletonDivider\"}]]}]\n"])</script><script>self.__next_f.push([1,"67:T40e,data:image/png;base64,"])</script><script>self.__next_f.push([1,"65:[\"$\",\"$L66\",null,{\"topicIds\":[\"c4f6cf29-2688-4b26-8595-a02c0ffd0cf1\",\"1608cb32-c6e9-46e9-a68b-7f87c2d1cd80\",\"01eb8e6c-cbd7-4635-9101-554fa3be4b3a\"],\"currentStoryId\":\"1b094a1d-ffb4-4778-a021-530b7e1fdf4f\",\"currentSlug\":\"202605082923\",\"language\":\"farsi\",\"initialArticles\":[{\"authors\":null,\"body\":[{\"_key\":\"7bdaa4ffa7af\",\"_type\":\"block\",\"children\":[{\"_key\":\"cac59e7969ac\",\"_type\":\"span\",\"marks\":[],\"text\":\"خبرگزاری فارس، وابسته به سپاه پاسداران جمعه ۱۸ اردیبهشت نوشت درگیری‌های پراکنده میان نیروهای مسلح جمهوری اسلامی و شناورهای آمریکایی در محدوده تنگه هرمز از ساعتی پیش آغاز شده است.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"82dc28b48a97\",\"_type\":\"block\",\"children\":[{\"_key\":\"f3fbdb26547d\",\"_type\":\"span\",\"marks\":[],\"text\":\"ساعاتی بعد، خبرگزاری تسنیم، دیگر رسانه وابسته به سپاه پاسداران، به‌نقل از یک منبع نظامی نوشت که درگیری نیروهای جمهوری اسلامی با نیروهای آمریکایی «پس از مدتی تبادل آتش، متوقف شده و فضا آرام است.»\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"f73b0af72daa\",\"_type\":\"block\",\"children\":[{\"_key\":\"4b08f6a48169\",\"_type\":\"span\",\"marks\":[],\"text\":\"این منبع نظامی که نامش فاش نشده، افزود: «با این حال، اگر مجددا آمریکایی‌ها قصد ورود به خلیج فارس را داشته باشند و یا برای شناورهای ایرانی مزاحمتی ایجاد کنند، مجددا پاسخ قاطع دریافت خواهند کرد.»\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"044481bbe115\",\"_type\":\"block\",\"children\":[{\"_key\":\"2017fca7e032\",\"_type\":\"span\",\"marks\":[],\"text\":\"او گفت: «بنابراین احتمال ورود مجدد به درگیری‌هایی از این قبیل در این منطقه همچنان وجود دارد.»\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"48f4830caeec\",\"_type\":\"block\",\"children\":[{\"_key\":\"763b7663574e\",\"_type\":\"span\",\"marks\":[],\"text\":\"هم‌زمان گزارش‌های مختلفی از شنیده شدن صدای انفجار و فعالیت پدافند هوایی در چند شهر از جمله تهران، سیرک و کنارک منتشر شد.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"872bb1ba5b77\",\"_type\":\"block\",\"children\":[{\"_key\":\"447429513808\",\"_type\":\"span\",\"marks\":[],\"text\":\"این در حالی است که مارکو روبیو، وزیر امور خارجه آمریکا، \"},{\"_key\":\"d4d83b279084\",\"_type\":\"span\",\"marks\":[\"b5c961fd1a9e\"],\"text\":\"گفت\"},{\"_key\":\"b5f09295021f\",\"_type\":\"span\",\"marks\":[],\"text\":\" باید جمعه پاسخ جمهوری اسلامی به طرح پیشنهادی صلح به واشینگتن ارائه شود.\"}],\"markDefs\":[{\"_key\":\"b5c961fd1a9e\",\"_type\":\"link\",\"href\":\"https://www.iranintl.com/fa/202605080757\"}],\"style\":\"normal\"},{\"_key\":\"a4bf6b3909f3\",\"_type\":\"inlinecontent\",\"stories\":[{\"headline\":\"وزیر امور خارجه آمریکا: کنترل جمهوری اسلامی بر تنگه هرمز را نخواهیم پذیرفت\",\"id\":\"d8aa11b1-8522-4d0d-b594-b7483b57329d\",\"image\":{\"_type\":\"image\",\"asset\":{\"_ref\":\"image-3471750a5494d00163a7a2ef27d816642bea735f-8207x5469-jpg\",\"_type\":\"reference\"}},\"language\":\"farsi\",\"publishedAt\":\"2026-05-08T14:16:33.883Z\",\"slug\":\"202605082560\",\"type\":\"story\",\"updatedAt\":null}]},{\"_key\":\"8542cf93e2d8\",\"_type\":\"block\",\"children\":[{\"_key\":\"410c2a9dbfa5\",\"_type\":\"span\",\"marks\":[],\"text\":\"او ابراز امیدواری کرد این پاسخ «جدی» باشد و بتواند مسیر ورود به یک فرآیند مذاکراتی واقعی را باز کند.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"e3802c158476\",\"_type\":\"block\",\"children\":[{\"_key\":\"b7a53bcb1296\",\"_type\":\"span\",\"marks\":[],\"text\":\"امارات متحده عربی جمعه ۱۸ اردیبهشت \"},{\"_key\":\"af0c1723d70b\",\"_type\":\"span\",\"marks\":[\"20eb40611d34\"],\"text\":\"اعلام کرد\"},{\"_key\":\"1758ba0737c0\",\"_type\":\"span\",\"marks\":[],\"text\":\" به یک حمله جدید موشکی جمهوری اسلامی پاسخ داده است؛ حمله‌ای که ساعاتی پس از اعلام تبادل آتش میان آمریکا و ایران در تنگه هرمز رخ داد و آتش‌بس شکننده یک‌ماهه را با چالش تازه‌ای روبه‌رو کرد.\"}],\"markDefs\":[{\"_key\":\"20eb40611d34\",\"_type\":\"link\",\"href\":\"https://www.iranintl.com/fa/202605081366\"}],\"style\":\"normal\"},{\"_key\":\"8f77dc89672a\",\"_type\":\"block\",\"children\":[{\"_key\":\"1c2cefb185ab\",\"_type\":\"span\",\"marks\":[],\"text\":\"وزارت دفاع امارات نیز گفت سامانه‌های پدافندی این کشور دو موشک بالستیک و سه پهپاد شلیک‌شده از سوی ایران را رهگیری کردند. \"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"3e473a9f99a5\",\"_type\":\"block\",\"children\":[{\"_key\":\"1c2cefb185ab\",\"_type\":\"span\",\"marks\":[],\"text\":\"در این حمله سه نفر زخمی شدند، اما مشخص نیست همه اهداف به‌طور کامل منهدم شده باشند. مقام‌ها از شهروندان خواستند از محل سقوط احتمالی بقایا دوری کنند.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"bf85cb74faef\",\"_type\":\"block\",\"children\":[{\"_key\":\"40274f534bf6\",\"_type\":\"span\",\"marks\":[],\"text\":\"در همین حال، ارتش آمریکا اعلام کرد حملات جمهوری اسلامی به سه ناو نیروی دریایی خود در تنگه هرمز را دفع کرده و تاسیسات نظامی ایران را که در این حملات نقش داشته‌اند، هدف قرار داده است. به‌گفته مقام‌های آمریکایی، هیچ‌یک از کشتی‌های این کشور آسیب ندیده‌اند.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"d424a20e8d8e\",\"_type\":\"inlinecontent\",\"stories\":[{\"headline\":\"ارم‌نیوز: یادداشت تفاهم تهران و واشینگتن توافقی جامع نیست و بر کاهش تنش‌ها تمرکز دارد\",\"id\":\"71689f6d-40c1-4093-ab35-2d3a465ee5f4\",\"image\":{\"_type\":\"image\",\"asset\":{\"_ref\":\"image-07c8375bf238eb643e8246660086bf9cb4bbb75a-1920x1080-png\",\"_type\":\"reference\"},\"crop\":{\"_type\":\"sanity.imageCrop\",\"bottom\":0,\"left\":0.0317845943384412,\"right\":0.01869698029744349,\"top\":0},\"hotspot\":{\"_type\":\"sanity.imageHotspot\",\"height\":0.7872716797365119,\"width\":0.869122045141938,\"x\":0.5,\"y\":0.39363583986825595}},\"language\":\"farsi\",\"publishedAt\":\"2026-05-08T11:46:36.631Z\",\"slug\":\"202605088965\",\"type\":\"story\",\"updatedAt\":null}]},{\"_key\":\"bd9141039ba9\",\"_type\":\"block\",\"children\":[{\"_key\":\"4bba260fa909\",\"_type\":\"span\",\"marks\":[],\"text\":\"واشینگتن همچنین اعلام کرد نیروهایش دو نفت‌کش ایرانی دیگر را که در تلاش برای عبور از محاصره دریایی آمریکا بودند، هدف قرار داده و از کار انداخته‌اند. آمریکا با هدف جلوگیری از تردد نفت‌کش‌های ایرانی، بندرهای این کشور را تحت محاصره قرار داده است.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"a9697488d0ab\",\"_type\":\"block\",\"children\":[{\"_key\":\"7f16650eca97\",\"_type\":\"span\",\"marks\":[],\"text\":\"هم‌زمان، گزارش‌هایی منتشر شده که نشان می‌دهد جمهوری اسلامی با ایجاد نهادی برای کنترل عبور کشتی‌ها در تنگه هرمز، در پی تثبیت نقش خود در مدیریت این آبراه است؛ اقدامی که نگرانی‌های تازه‌ای درباره آزادی کشتی‌رانی ایجاد کرده است. \"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"391c1608af9e\",\"_type\":\"block\",\"children\":[{\"_key\":\"7f16650eca97\",\"_type\":\"span\",\"marks\":[],\"text\":\"در حال حاضر صدها کشتی تجاری در خلیج فارس متوقف شده‌اند و امکان گذر از تنگه هرمز و ورود به آب‌های آزاد را ندارند.\"}],\"markDefs\":[],\"style\":\"normal\"}],\"categories\":[{\"id\":\"c4f6cf29-2688-4b26-8595-a02c0ffd0cf1\",\"slug\":\"hmlh-aamryka-w-asraeyl-bh-jmhwry-aslamy\",\"title\":\"جنگ علیه جمهوری اسلامی\",\"type\":\"supernews\"},{\"id\":\"67bd595d-41c2-41e8-8ba7-42f76fd9e49e\",\"slug\":\"iran\",\"title\":\"ایران\",\"type\":\"category\"}],\"hasTextToSpeech\":true,\"headline\":\"امارات متحده عربی از رهگیری حمله موشکی خبر داد؛ درگیری‌ها در تنگه هرمز تشدید شد\",\"id\":\"a6d21de2-3f44-4e2e-a7d8-eabf2411dffd\",\"image\":{\"alt\":null,\"asset\":{\"_ref\":\"image-e32a63befe5e567424f42439a52b270321fa2385-800x450-jpg\",\"_type\":\"reference\"},\"caption\":null,\"crop\":null,\"hotspot\":null,\"metadata\":{\"dimensions\":{\"height\":450,\"width\":800},\"lqip\":\"data:image/jpeg;base64,\"}},\"language\":\"farsi\",\"lead\":\"گزارش‌هایی از درگیری‌های پراکنده میان نیروهای مسلح جمهوری اسلامی و شناورهای آمریکایی در محدوده تنگه هرمز منتشر شده است. هم‌زمان امارات متحده عربی اعلام کرد در پی حمله موشکی و پهپادی جمهوری اسلامی سه نفر زخمی شدند.\",\"publishedAt\":\"2026-05-08T16:39:53.100Z\",\"revision\":null,\"shorthandUrl\":null,\"slug\":\"202605080952\",\"tags\":null,\"type\":\"story\",\"updatedAt\":\"2026-05-08T16:42:39Z\"},{\"authors\":null,\"body\":[{\"_key\":\"b5e09364c211\",\"_type\":\"block\",\"children\":[{\"_key\":\"5b785776c9c9\",\"_type\":\"span\",\"marks\":[],\"text\":\"روبیو که به ایتالیا سفر کرده، جمعه ۱۸ اردیبهشت هشدار داد اگر تهران به کشتی‌های نیروی دریایی آمریکا حمله کند نیروهای جمهوری اسلامی نابود خواهند شد.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"ad247b7d27be\",\"_type\":\"block\",\"children\":[{\"_key\":\"54f6605da5f4\",\"_type\":\"span\",\"marks\":[],\"text\":\"روبیو در پایان یک سفر دو روزه برای ترمیم روابط در رم و واتیکان به پرسش‌های خبرنگاران پاسخ می‌داد؛ سفری که پس از اختلافات شدید درباره جنگ آمریکا و اسرائیل علیه جمهوری اسلامی و انتقادهای دونالد ترامپ، رییس‌جمهوری آمریکا، از پاپ لئو چهاردهم انجام شد.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"ff5b96f3c507\",\"_type\":\"block\",\"children\":[{\"_key\":\"ad0947541269\",\"_type\":\"span\",\"marks\":[],\"text\":\"از او درباره گزارش‌های یک شرکت داده‌های کشتی‌رانی پرسیده شد که گفته بود جمهوری اسلامی یک نهاد دولتی جدید ایجاد کرده است تا عبور کشتی‌ها از این تنگه را بررسی و مشمول مالیات کند.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"c2b46b9adba9\",\"_type\":\"block\",\"children\":[{\"_key\":\"6127c8188d0c\",\"_type\":\"span\",\"marks\":[],\"text\":\"روبیو پرسید: «آیا جهان قرار است بپذیرد که ایران اکنون یک آبراه بین‌المللی را کنترل کند؟ جهان برای انجام چه کاری آماده است؟»\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"a47bfda5a163\",\"_type\":\"block\",\"children\":[{\"_key\":\"1947e5d37739\",\"_type\":\"span\",\"marks\":[],\"text\":\"پیشتر رسانه‌های بین‌المللی \"},{\"_key\":\"80f13cf3859a\",\"_type\":\"span\",\"marks\":[\"7a136dfab523\"],\"text\":\"به نقل از داده‌های کشتی‌رانی گزارش دادند\"},{\"_key\":\"49ce5fc83f53\",\"_type\":\"span\",\"marks\":[],\"text\":\" که جمهوری اسلامی نهاد جدیدی را برای کنترل کشتی‌رانی در تنگه هرمز ایجاد کرده است.\"}],\"markDefs\":[{\"_key\":\"7a136dfab523\",\"_type\":\"link\",\"href\":\"https://www.iranintl.com/fa/202605071065\"}],\"style\":\"normal\"},{\"_key\":\"8043f13c00dd\",\"_type\":\"block\",\"children\":[{\"_key\":\"313fdfe9bd5b\",\"_type\":\"span\",\"marks\":[],\"text\":\"آسوشیتدپرس پنج‌شنبه ۱۷ اردیبهشت به‌نقل از شرکت داده‌های کشتی‌رانی«لوییدز لیست اینتلیجنس» گزارش داد که این نهاد که «سازمان تنگه خلیج فارس» نام دارد و «خود را به‌عنوان تنها مرجع معتبر برای صدور مجوز عبور کشتی‌ها در تنگه هرمز» معرفی می‌کند.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"b8d56b12bf39\",\"_type\":\"block\",\"children\":[{\"_key\":\"86236984c581\",\"_type\":\"span\",\"marks\":[\"strong\"],\"text\":\"هشدار درباره حمله به نیروی دریایی این کشور\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"5e1cc4a9f0c9\",\"_type\":\"block\",\"children\":[{\"_key\":\"313fdfe9bd5b\",\"_type\":\"span\",\"marks\":[],\"text\":\"روبیو همچنین به تهران درباره حمله به دارایی‌های دریایی آمریکا در منطقه هشدار داد.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"5106902fa131\",\"_type\":\"block\",\"children\":[{\"_key\":\"313fdfe9bd5b\",\"_type\":\"span\",\"marks\":[],\"text\":\" ایالات متحده اعلام کرد که سه حمله علیه کشتی‌های نیروی دریایی در تنگه هرمز را خنثی کرده است.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"5e969fa355d4\",\"_type\":\"block\",\"children\":[{\"_key\":\"ad357a5257fb\",\"_type\":\"span\",\"marks\":[],\"text\":\"او گفت: «خط قرمز روشن است. اگر آمریکایی‌ها را تهدید کنند، منفجر خواهند شد.»\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"00ee738b9561\",\"_type\":\"block\",\"children\":[{\"_key\":\"ba7c707d44b6\",\"_type\":\"span\",\"marks\":[],\"text\":\"وزیر امور خارجه آمریکا در ادامه تاکید کرد که حملات ۱۷ اردیبهشت ارتباطی با عملیات «خشم حماسی» نداشته است.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"28a0cadbe11b\",\"_type\":\"block\",\"children\":[{\"_key\":\"edd154bcbf26\",\"_type\":\"span\",\"marks\":[],\"text\":\"روبیو گفت که قرار است جمعه ۱۸ اردیبهشت پاسخ جمهوری اسلامی به طرح پیشنهادی صلح به واشینگتن ارائه شود.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"22ec9e1b6f9c\",\"_type\":\"block\",\"children\":[{\"_key\":\"5aff5c1ab8bc\",\"_type\":\"span\",\"marks\":[],\"text\":\"او ابراز امیدواری کرد این پاسخ «جدی» باشد و بتواند مسیر ورود به یک فرآیند مذاکراتی واقعی را باز کند.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"6bfbafd112ef\",\"_type\":\"block\",\"children\":[{\"_key\":\"74da19bf994e\",\"_type\":\"span\",\"marks\":[\"strong\"],\"text\":\"دیدار با پاپ و انتقاد از حزب‌الله\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"cb8b7578ef52\",\"_type\":\"block\",\"children\":[{\"_key\":\"8f838969f1df\",\"_type\":\"span\",\"marks\":[],\"text\":\"روبیو همچنین به دیدار خود با پاپ لئو در ۱۷ اردیبهشت اشاره کرد و گفت این دیدار «بسیار مثبت» بوده است.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"00dbca47365a\",\"_type\":\"block\",\"children\":[{\"_key\":\"36e027c26196\",\"_type\":\"span\",\"marks\":[],\"text\":\"واتیکان پنج‌شنبه ۱۷اردیبهشت در بیانیه‌ای پس از نخستین دیدار میان پاپ لئو و یکی از اعضای کابینه ترامپ در نزدیک به یک سال گذشته، اعلام کرد که لئو و روبیو «تعهد مشترک خود را برای تقویت روابط دوجانبه خوب» تجدید کردند.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"ed072d82e004\",\"_type\":\"inlinecontent\",\"stories\":[{\"headline\":\"پاپ لئو و روبیو بر تقویت روابط واتیکان و واشینگتن تاکید کردند\",\"id\":\"87e382fd-cd96-41ba-9c35-2c61d73b3b87\",\"image\":{\"_type\":\"image\",\"asset\":{\"_ref\":\"image-f19a95da3bd0db9d3ef7af3232c96fb7c3fb0e43-7087x4725-jpg\",\"_type\":\"reference\"}},\"language\":\"farsi\",\"publishedAt\":\"2026-05-07T19:23:19.724Z\",\"slug\":\"202605072756\",\"type\":\"story\",\"updatedAt\":null}]},{\"_key\":\"5abb82838109\",\"_type\":\"block\",\"children\":[{\"_key\":\"cc6ec55acc36\",\"_type\":\"span\",\"marks\":[],\"text\":\"لئو، نخستین پاپ آمریکایی، پس از آنکه به \"},{\"_key\":\"035658b923ba\",\"_type\":\"span\",\"marks\":[\"159e96a7e7c5\"],\"text\":\"منتقدی جدی\"},{\"_key\":\"c3946ec68e90\",\"_type\":\"span\",\"marks\":[],\"text\":\" در زمینه جنگ آمریکا و اسرائیل علیه جمهوری اسلامی و نیز سیاست‌های سخت‌گیرانه ضدمهاجرتی دولت ترامپ تبدیل شد، انتقادهای ترامپ را برانگیخت و این انتقادها واکنش منفی رهبران مسیحی از طیف‌های مختلف سیاسی را در پی داشت.\"}],\"markDefs\":[{\"_key\":\"159e96a7e7c5\",\"_type\":\"link\",\"href\":\"https://www.iranintl.com/202604101687\"}],\"style\":\"normal\"},{\"_key\":\"1eea2b14515c\",\"_type\":\"block\",\"children\":[{\"_key\":\"5b785776c9c9\",\"_type\":\"span\",\"marks\":[],\"text\":\"وزیر امور خارجه آمریکا در خصوص مذاکرات با دولت لبنان نیز گفت: «ما می‌خواهیم دولت مشروع لبنان قوی باشد و حزب‌الله مانعی برای این امر است.»\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"bda893ef0e8d\",\"_type\":\"block\",\"children\":[{\"_key\":\"930bee962aec\",\"_type\":\"span\",\"marks\":[],\"text\":\"روبیو ادامه داد: «حزب‌الله کاملا یک نیروی نیابتی جمهوری اسلامی است و بدون آنها وجود نخواهد داشت.»\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"554b33c413e3\",\"_type\":\"block\",\"children\":[{\"_key\":\"7c8844ce876f\",\"_type\":\"span\",\"marks\":[],\"text\":\"روبیو افزود: «ما در تلاشیم تا تامین مالی حزب‌الله را متوقف کنیم.»\"}],\"markDefs\":[],\"style\":\"normal\"}],\"categories\":[{\"id\":\"c4f6cf29-2688-4b26-8595-a02c0ffd0cf1\",\"slug\":\"hmlh-aamryka-w-asraeyl-bh-jmhwry-aslamy\",\"title\":\"جنگ علیه جمهوری اسلامی\",\"type\":\"supernews\"},{\"id\":\"67bd595d-41c2-41e8-8ba7-42f76fd9e49e\",\"slug\":\"iran\",\"title\":\"ایران\",\"type\":\"category\"}],\"hasTextToSpeech\":true,\"headline\":\"وزیر امور خارجه آمریکا: کنترل جمهوری اسلامی بر تنگه هرمز را نخواهیم پذیرفت\",\"id\":\"d8aa11b1-8522-4d0d-b594-b7483b57329d\",\"image\":{\"alt\":null,\"asset\":{\"_ref\":\"image-3471750a5494d00163a7a2ef27d816642bea735f-8207x5469-jpg\",\"_type\":\"reference\"},\"caption\":null,\"crop\":null,\"hotspot\":null,\"metadata\":{\"dimensions\":{\"height\":5469,\"width\":8207},\"lqip\":\"data:image/jpeg;base64,\"}},\"language\":\"farsi\",\"lead\":\"مارکو روبیو، وزیر امور خارجه ایالات متحده، اعلام کرد که این کشور کنترل جمهوری اسلامی بر تنگه هرمز را نخواهد پذیرفت. او همچنین گفت که همه کشورها موافقند که داشتن سلاح هسته‌ای از سوی جمهوری اسلامی «غیرقابل قبول است.»\",\"publishedAt\":\"2026-05-08T14:16:33.883Z\",\"revision\":null,\"shorthandUrl\":null,\"slug\":\"202605082560\",\"tags\":null,\"type\":\"story\",\"updatedAt\":\"2026-05-08T14:16:37Z\"},{\"authors\":[{\"id\":\"f4a1d106-2f27-4e2d-97ea-488818f500e6\",\"image\":{\"_type\":\"image\",\"asset\":{\"_ref\":\"image-64611dc695f5e7d06337cd40f5bf52d73ee1c282-539x756-jpg\",\"_type\":\"reference\"},\"crop\":{\"_type\":\"sanity.imageCrop\",\"bottom\":0.05438398878644528,\"left\":0,\"right\":0,\"top\":0.03783244920598844},\"hotspot\":{\"_type\":\"sanity.imageHotspot\",\"height\":0.8628576205789644,\"width\":1,\"x\":0.5,\"y\":0.46926125949547065}},\"language\":\"farsi\",\"name\":\"علی رشید\",\"position\":\"ایران‌اینترنشنال\",\"slug\":\"ali_rashid\"}],\"body\":[{\"_key\":\"0388aa23a592\",\"_type\":\"block\",\"children\":[{\"_key\":\"8b35069fe38d\",\"_type\":\"span\",\"marks\":[],\"text\":\"کی‌یر استارمر، نخست‌وزیر و رهبر حزب کارگر، شکست را پذیرفت و گفت پیام رأی‌دهندگان را شنیده است، در حالی که نایجل فاراژ، رهبر حزب اصلاحات پادشاهی بریتانیا، نتایج را «تغییر تاریخی» در سیاست بریتانیا توصیف کرد. حزب کارگر چندین شورا را از دست داد و حزب اصلاحات پادشاهی بریتانیا بیش از ۴۰۰ کرسی تازه به دست آورد.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"593fd6ca7319\",\"_type\":\"block\",\"children\":[{\"_key\":\"a3a4ca4d25d2\",\"_type\":\"span\",\"marks\":[\"strong\"],\"text\":\"نایجل فاراژ؛ از حزب استقلال پادشاهی متحد تا اصلاح پادشاهی بریتانیا\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"5ec53b8c5ef2\",\"_type\":\"block\",\"children\":[{\"_key\":\"7772f6ca60e1\",\"_type\":\"span\",\"marks\":[],\"text\":\"نایجل فاراژ، متولد ۱۹۶۴ در فارنبرو، پس از تحصیل در کالج دالیچ به‌جای دانشگاه وارد بازار بورس سیتی لندن شد. مخالفت با پیمان ماستریخت او را در ۱۹۹۲ از حزب محافظه‌کار جدا کرد و در ۱۹۹۳ با حزب استقلال پادشاهی متحد (یوکیپ) وارد سیاست شد.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"9548b252fc03\",\"_type\":\"block\",\"children\":[{\"_key\":\"f60449186d6b\",\"_type\":\"span\",\"marks\":[],\"text\":\"او از ۱۹۹۹ نماینده پارلمان اروپا از حوزه جنوب شرق انگلستان بود و از ۲۰۰۶ تا ۲۰۱۶ (با وقفه‌ای کوتاه) رهبری یوکیپ را برعهده داشت، حزبی که بر نگرانی‌های بخشی از طبقه کارگر سفیدپوست درباره مهاجرت سوار شد و در انتخابات محلی ۲۰۱۳ و انتخابات پارلمان اروپا ۲۰۱۴ به موفقیت‌های تاریخی رسید.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"7a36232fb08f\",\"_type\":\"inlinecontent\",\"stories\":[{\"headline\":\"ضربه سنگین به حزب کارگر در انتخابات محلی و پیروزی گسترده حزب اصلاح بریتانیا\",\"id\":\"eYS8cALT8WYoU8YjHhr4nf6\",\"image\":{\"_type\":\"figure\",\"alt\":\"نیگل فراج، رهبر Reform UK، پس از اعلام نتایج انتخابات محلی در تالار شهر هاورینگ، لندن‌بورو آف هاورینگ، بریتانیا، ۸ مهٔ ۲۰۲۶.\\n\\nرویترز/جک تیلور\",\"asset\":{\"_ref\":\"image-4a54c91b1b22d90d62aa35b1394fac49e762197f-800x534-jpg\",\"_type\":\"reference\"},\"caption\":\"انتخابات محلی بریتانیا در سال ۲۰۲۶\",\"credit\":\"جک تیلور / رویترز\"},\"language\":\"farsi\",\"publishedAt\":\"2026-05-08T09:32:56.255Z\",\"slug\":\"2026050866620\",\"type\":\"article\",\"updatedAt\":null}]},{\"_key\":\"acfcf4aadb3a\",\"_type\":\"block\",\"children\":[{\"_key\":\"004b93c50002\",\"_type\":\"span\",\"marks\":[],\"text\":\"فشار ناشی از اوج‌گیری یوکیپ، دیوید کامرون را به وعده همه‌پرسی خروج از اتحادیه اروپا در مانیفست ۲۰۱۵ کشاند. همه‌پرسی ۲۰۱۶ با ۵۱.۹ درصد رأی به خروج، تاریخ سیاسی بریتانیا را عوض کرد. فاراژ پس از رأی خروج از یوکیپ استعفا کرد و در ۲۰۱۹ حزب برگزیت را راه انداخت.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"251907cd2d44\",\"_type\":\"block\",\"children\":[{\"_key\":\"0605dd00c60e\",\"_type\":\"span\",\"marks\":[],\"text\":\"کاترین آن بلیکلاک از بنیان‌گذاران و نخستین رهبر حزب برگزیت بود اما پس از افشای اظهارات ضداسلامی و نژادپرستانه استعفا کرد و فاراژ برای یک سال رهبری را به دست گرفت. در دوره رهبری ریچارد تایس، نام حزب از «برگزیت» به «حزب اصلاح پادشاهی بریتانیا» تغییر کرد و فاراژ از ۲۰۲۴ دوباره در رأس حزب قرار گرفت.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"f4b7180cba6a\",\"_type\":\"block\",\"children\":[{\"_key\":\"d203f146aa0e\",\"_type\":\"span\",\"marks\":[],\"text\":\"در انتخابات عمومی ۲۰۲۴، فاراژ کرسی کلکتون را گرفت و حزب اصلاح پادشاهی بریتانیا با حدود پنج کرسی پارلمانی اما بیش از چهار میلیون رأی، به سومین حزب پرآرای بریتانیا تبدیل شد. این شکاف میان آرا و کرسی‌ها، محور اصلی حمله فاراژ به نظام اکثریتی فعلی است.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"7f94e168419b\",\"_type\":\"block\",\"children\":[{\"_key\":\"3d615060cd51\",\"_type\":\"span\",\"marks\":[\"strong\"],\"text\":\"حزب اصلاح پادشاهی بریتانیا چه می‌خواهد؟\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"5f56fd210f52\",\"_type\":\"block\",\"children\":[{\"_key\":\"6d64afa13c30\",\"_type\":\"span\",\"marks\":[],\"text\":\"حزب اصلاحات پادشاهی بریتانیا خود را حزبی ضداستقرار معرفی می‌کند که بر کنترل مهاجرت، کاهش مالیات، کوچک‌سازی دولت تمرکز دارد. هدف فاراژ تبدیل این حزب به نیروی اصلی راست سیاسی و در نهایت تصاحب نخست‌وزیری است.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"32f5054ba1bc\",\"_type\":\"block\",\"children\":[{\"_key\":\"5191d7990555\",\"_type\":\"span\",\"marks\":[\"strong\"],\"text\":\"سیاست‌های اقتصادی و مالیاتی\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"d41c698f2705\",\"_type\":\"block\",\"children\":[{\"_key\":\"b7a008d40933\",\"_type\":\"span\",\"marks\":[],\"text\":\"در مانیفست «قرارداد ما با شما»، مهم‌ترین وعده‌های اقتصادی عبارت‌اند از:\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"487926059ded\",\"_type\":\"block\",\"children\":[{\"_key\":\"260fdcc9b94a\",\"_type\":\"span\",\"marks\":[],\"text\":\"  افزایش سقف معافیت مالیاتی درآمد به ۲۰ هزار پوند در سال\"}],\"level\":1,\"listItem\":\"bullet\",\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"e7fb0c5c72ba\",\"_type\":\"block\",\"children\":[{\"_key\":\"fbf522f7c2cd\",\"_type\":\"span\",\"marks\":[],\"text\":\"  حذف مالیات بر ارث برای دارایی‌های زیر دو میلیون پوند\"}],\"level\":1,\"listItem\":\"bullet\",\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"027c1fd555b6\",\"_type\":\"block\",\"children\":[{\"_key\":\"b1197c26ad4e\",\"_type\":\"span\",\"marks\":[],\"text\":\"  حذف مالیات شرکت برای بیش از ۱.۲ میلیون کسب‌وکار کوچک و متوسط\"}],\"level\":1,\"listItem\":\"bullet\",\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"544b8346c19d\",\"_type\":\"block\",\"children\":[{\"_key\":\"54f876aa9a6a\",\"_type\":\"span\",\"marks\":[],\"text\":\"  افزایش سقف معافیت مالیات بر ارزش‌افزوده (VAT) به ۱۵۰ هزار پوند\"}],\"level\":1,\"listItem\":\"bullet\",\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"7d7a9ebae490\",\"_type\":\"block\",\"children\":[{\"_key\":\"fb08697d6390\",\"_type\":\"span\",\"marks\":[],\"text\":\"  کاهش هزینه‌های دولت از طریق «حذف ولخرجی» و بازتوزیع منابع به خدمات عمومی کلیدی\"}],\"level\":1,\"listItem\":\"bullet\",\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"9a4c6db579fd\",\"_type\":\"inlinecontent\",\"stories\":[{\"headline\":\"رهبر حزب اصلاح بریتانیا: جمهوری اسلامی شرور باید برود\",\"id\":\"8e219f2b-a7e5-4849-922b-274abca5bbbc\",\"image\":{\"_type\":\"figure\",\"asset\":{\"_ref\":\"image-7efddca63238866f95ffe3cbf266ae53cd6f369d-4681x3121-jpg\",\"_type\":\"reference\"}},\"language\":\"farsi\",\"publishedAt\":\"2026-01-01T23:36:56.791Z\",\"slug\":\"202601010207\",\"type\":\"story\",\"updatedAt\":null}]},{\"_key\":\"8b0d022548a3\",\"_type\":\"block\",\"children\":[{\"_key\":\"5bc571f30535\",\"_type\":\"span\",\"marks\":[\"strong\"],\"text\":\"مهاجرت و هویت\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"648593169da6\",\"_type\":\"block\",\"children\":[{\"_key\":\"df792b92d621\",\"_type\":\"span\",\"marks\":[],\"text\":\"مهاجرت محور اصلی گفتمان حزب اصلاح پادشاهی بریتانیاست. این حزب می‌خواهد مهاجرت «غیرضروری»، که آن را شامل مهاجرت کاری و خانوادگی می‌داند متوقف کند، اقامت دائم (ILR) برای متقاضیان جدید را لغو کند و به‌جای آن ویزاهای پنج‌ساله با شرایط سخت‌تر، حقوق بالاتر و کنترل‌های شدیدتر قرار دهد.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"cceaaa2f0752\",\"_type\":\"block\",\"children\":[{\"_key\":\"399ad7d69c9e\",\"_type\":\"span\",\"marks\":[],\"text\":\"به‌موازات این، حزب خروج از کنوانسیون اروپایی حقوق بشر را برای تسهیل اخراج مهاجران غیرقانونی و توقف قایق‌ها ضروری می‌داند. منتقدان حقوقی هشدار می‌دهند که این طرح‌ها می‌تواند با تعهدات بین‌المللی بریتانیا در تضاد باشد و وضعیت هزاران مهاجر را مبهم کند.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"c751e4ca32c0\",\"_type\":\"block\",\"children\":[{\"_key\":\"10aabd165b95\",\"_type\":\"span\",\"marks\":[],\"text\":\"کی‌یر استارمر در مصاحبه‌ای سیاست مهاجرتی حزب اصلاحات پادشاهی بریتانیا را «نژادپرستانه» توصیف کرده، با این حال دولت کارگر تحت فشار این حزب به سمت سیاست‌های سخت‌گیرانه‌تر حرکت کرده است. این تاثیرگذاری بر گفتمان، یکی از مهم‌ترین دستاوردهای حزب اصلاحات پادشاهی بریتانیا حتی بدون داشتن قدرت ملی مستقیم است.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"e3bcc8d48da2\",\"_type\":\"block\",\"children\":[{\"_key\":\"72738b582ff7\",\"_type\":\"span\",\"marks\":[\"strong\"],\"text\":\"هدف بلندمدت؛ جانشینی محافظه‌کاران\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"7440659efbef\",\"_type\":\"block\",\"children\":[{\"_key\":\"2a1e5b384d0d\",\"_type\":\"span\",\"marks\":[],\"text\":\"هدف بلندمدت فاراژ فراتر از انتخابات محلی است، او می‌خواهد حزب اصلاحات پادشاهی بریتانیا جای محافظه‌کاران را به‌عنوان نیروی اصلی جناح راست بگیرد و اپوزیسیون واقعی در برابر دولت کارگر باشد.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"193271e1bd20\",\"_type\":\"block\",\"children\":[{\"_key\":\"8020fbbc7585\",\"_type\":\"span\",\"marks\":[],\"text\":\"در انتخابات محلی ۲۰۲۵، این حزب با جهشی از صفر به صدها کرسی شورا و تصاحب چندین شورای کلیدی، از جمله کنت و استافوردشایر از محافظه‌کاران و دانکستر و دورهام از حزب کارگر، وارد مرحله جدیدی شد. در ۲۰۲۶، با اضافه شدن شوراهای تازه و عبور تعداد کرسی‌های محلی از ۸۰۰، این حزب دیگر فقط نیروی اعتراضی نیست، بلکه برای نخستین بار مسئولیت مستقیم اداره چندین شهرستان انگلستان را برعهده دارد.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"23f77e3cc1ea\",\"_type\":\"block\",\"children\":[{\"_key\":\"31336a94d60e\",\"_type\":\"span\",\"marks\":[],\"text\":\"برخی تحلیل‌گران معتقدند اگر روند نظرسنجی‌ها ادامه یابد، حزب اصلاحات پادشاهی بریتانیا می‌تواند در انتخابات عمومی بعدی صدها حوزه را هدف بگیرد، هرچند نظام اکثریتی همچنان بزرگ‌ترین مانع برای تبدیل آرا به کرسی است و در ۲۰۲۴ بیش از چهار میلیون رأی این حزب را تنها به چند کرسی تبدیل کرد.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"7b764e489915\",\"_type\":\"figure\",\"asset\":{\"_ref\":\"image-8b68dffaea953a0032ae306f390c9c7eab6f5d4d-800x533-jpg\",\"_type\":\"reference\"},\"sources\":{\"mobile\":{\"url\":\"https://i.iranintl.com/images/rdk9umy0/production/8b68dffaea953a0032ae306f390c9c7eab6f5d4d-800x533.jpg?w=576\u0026h=384\u0026q=80\u0026fit=max\u0026auto=format\",\"aspectRatio\":\"3x2\",\"orientation\":\"landscape\"},\"tablet\":{\"url\":\"https://i.iranintl.com/images/rdk9umy0/production/8b68dffaea953a0032ae306f390c9c7eab6f5d4d-800x533.jpg?w=768\u0026h=512\u0026q=80\u0026fit=max\u0026auto=format\",\"aspectRatio\":\"3x2\",\"orientation\":\"landscape\"},\"desktop\":{\"url\":\"https://i.iranintl.com/images/rdk9umy0/production/8b68dffaea953a0032ae306f390c9c7eab6f5d4d-800x533.jpg?w=992\u0026h=661\u0026q=80\u0026fit=max\u0026auto=format\",\"aspectRatio\":\"3x2\",\"orientation\":\"landscape\"}}},{\"_key\":\"6f12ecd16d8f\",\"_type\":\"block\",\"children\":[{\"_key\":\"d515c5347a06\",\"_type\":\"span\",\"marks\":[\"strong\"],\"text\":\"آزمایشگاه‌های قدرت محلی؛ برنامه ریفرم در شوراها\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"daf4cccca2e3\",\"_type\":\"block\",\"children\":[{\"_key\":\"c61faba8728b\",\"_type\":\"span\",\"marks\":[],\"text\":\"پیروزی در انتخابات محلی، حزب اصلاحات پادشاهی بریتانیا را برای اولین بار در جایگاه تصمیم‌گیر در سطح محلی قرار داده است. هاورینگ، نیوکاسل-آندر-لایم و شماری دیگر از شوراها اکنون به آزمایشگاه‌های اصلی این حزب تبدیل شده‌اند.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"02ff1ff1aff1\",\"_type\":\"block\",\"children\":[{\"_key\":\"0da6237a90a5\",\"_type\":\"span\",\"marks\":[],\"text\":\"اقداماتی که حزب اصلاحات پادشاهی بریتانیا در شوراهای تحت کنترل خود وعده داده یا آغاز کرده شامل موارد زیر است:\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"377216146e2e\",\"_type\":\"block\",\"children\":[{\"_key\":\"d4352864aceb\",\"_type\":\"span\",\"marks\":[],\"text\":\"  لغو برنامه‌های تنوع، برابری و شمول و کاهش واحدهای مرتبط\"}],\"level\":1,\"listItem\":\"bullet\",\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"53408a27b812\",\"_type\":\"block\",\"children\":[{\"_key\":\"b588b8bc13ff\",\"_type\":\"span\",\"marks\":[],\"text\":\"  توقف یا تعلیق پروژه‌های انرژی تجدیدپذیر و دستور کار خالص صفر کربن\"}],\"level\":1,\"listItem\":\"bullet\",\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"39756d0bea2d\",\"_type\":\"block\",\"children\":[{\"_key\":\"b0155fc5cdae\",\"_type\":\"span\",\"marks\":[],\"text\":\"  ممانعت از اسکان پناه‌جویان در محدوده شورای تحت کنترل\"}],\"level\":1,\"listItem\":\"bullet\",\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"9a092ca12e08\",\"_type\":\"block\",\"children\":[{\"_key\":\"4e47eb4ca73f\",\"_type\":\"span\",\"marks\":[],\"text\":\"  بازگشت کارمندان دولت محلی به کار حضوری و محدود کردن دورکاری\"}],\"level\":1,\"listItem\":\"bullet\",\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"c19e02263769\",\"_type\":\"block\",\"children\":[{\"_key\":\"d5d974590235\",\"_type\":\"span\",\"marks\":[],\"text\":\"  کاهش هزینه‌های اداری از طریق الگوهای ممیزی و «حذف ولخرجی» با الهام از مدل‌های آمریکایی\"}],\"level\":1,\"listItem\":\"bullet\",\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"892e505c4fd4\",\"_type\":\"block\",\"children\":[{\"_key\":\"579b6e7bf65c\",\"_type\":\"span\",\"marks\":[],\"text\":\"متخصصان حقوق اداری هشدار می‌دهند که شوراهای محلی در بریتانیا اختیارات محدود دارند و بسیاری از این تصمیمات با چارچوب قانون‌گذاری ملی در وستمینستر در تعارض قرار می‌گیرد، بنابراین این وعده‌ها با چالش‌های حقوقی جدی روبه‌رو خواهند شد.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"02de0710ba0c\",\"_type\":\"block\",\"children\":[{\"_key\":\"f86f9e9d200a\",\"_type\":\"span\",\"marks\":[\"strong\"],\"text\":\"هاورینگ؛ پرچم لندن برای ریفرم\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"d1f0d2d746bc\",\"_type\":\"block\",\"children\":[{\"_key\":\"c97cdfff9646\",\"_type\":\"span\",\"marks\":[],\"text\":\"هاورینگ در شرق لندن اکنون نماد اصلی پیشروی حزب اصلاحات پادشاهی بریتانیا در پایتخت است. فاراژ پیش از انتخابات گفته بود «هیچ شکی ندارد» که هاورینگ را می‌برد و صبح هشتم مه در بازار رامفورد جشن پیروزی گرفت، این نخستین شورای لندنی است که به کنترل کامل این حزب درآمده است.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"15ca91e028f5\",\"_type\":\"block\",\"children\":[{\"_key\":\"2a48b5ae65a8\",\"_type\":\"span\",\"marks\":[\"strong\"],\"text\":\"طرح «هاورینگ به اسکس»\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"6bd6255ab4b9\",\"_type\":\"block\",\"children\":[{\"_key\":\"2a1138524cfc\",\"_type\":\"span\",\"marks\":[],\"text\":\"جنجالی‌ترین طرح حزب اصلاحات پادشاهی بریتانیا در هاورینگ، انتقال این شهرستان از مرزهای لندن بزرگ به استان اسکس است. اندرو روزیندل، نماینده رامفورد که از محافظه‌کاران به حزب اصلاحات پادشاهی بریتانیا پیوسته، می‌گوید ساکنان هاورینگ «هیچ‌وقت خود را از نظر فرهنگی لندنی احساس نکرده‌اند» و باید در همه‌پرسی درباره الحاق به اسکس رأی بدهند.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"8c97ac1a4c82\",\"_type\":\"block\",\"children\":[{\"_key\":\"e91131c751e4\",\"_type\":\"span\",\"marks\":[],\"text\":\"رفرم استدلال می‌کند این اقدام به هاورینگ خودمختاری بیشتری می‌دهد و آن را از سیاست‌های مرکزی شهر لندن جدا می‌کند، هرچند منتقدان می‌گویند چنین تغییری نیازمند طی یک فرایند پیچیده حقوقی و سیاسی است.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"ab9a804b9af6\",\"_type\":\"block\",\"children\":[{\"_key\":\"984e4e2a5bbd\",\"_type\":\"span\",\"marks\":[],\"text\":\"علاوه بر هاورینگ، فاراژ شوراهای بکسلی، بروملی و بارکینگ-اند-دگنهام را نیز در فهرست اهداف لندنی حزب اصلاحات پادشاهی بریتانیا قرار داده است؛ مناطق حاشیه‌ای با ترکیب جمعیتی نزدیک به پایگاه رأی سنتی این حزب.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"e85ddfc5724a\",\"_type\":\"block\",\"children\":[{\"_key\":\"eb465e0452ee\",\"_type\":\"span\",\"marks\":[\"strong\"],\"text\":\"استارمر در تنگنا و صعود عضویت ریفرم\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"81859f6fdc47\",\"_type\":\"block\",\"children\":[{\"_key\":\"c8782ab07839\",\"_type\":\"span\",\"marks\":[],\"text\":\"۱۸ ماه پس از پیروزی بزرگ حزب کارگر در انتخابات عمومی ژوئیه ۲۰۲۴ با ۴۱۲ کرسی، کی‌یر استارمر با جدی‌ترین بحران دوران نخست‌وزیری‌اش روبه‌رو است. گزارش‌ها حاکی است او در کارزار انتخابات محلی ۲۰۲۶ به «نقطه ضعف انتخاباتی» تبدیل شده و بسیاری از نمایندگان کارگر حضورش را در خط مقدم کمپین محدود کرده‌اند.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"3707f22fc0bc\",\"_type\":\"block\",\"children\":[{\"_key\":\"f897794f08c9\",\"_type\":\"span\",\"marks\":[],\"text\":\"در همین حال، عضویت حزب کارگر از اوج بیش از نیم میلیون نفر در دوران کوربین به حدود نصف کاهش یافته، در حالی که حزب اصلاحات پادشاهی بریتانیا ادعا می‌کند با بیش از ۲۰۰ هزار عضو، اکنون از نظر تعداد عضو از حزب کارگر پیشی گرفته و بزرگ‌ترین حزب بریتانیاست.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"17d1d472c3aa\",\"_type\":\"block\",\"children\":[{\"_key\":\"0b5e60e1d7eb\",\"_type\":\"span\",\"marks\":[],\"text\":\"با وجود فشارهای داخلی برای تغییر رهبری، دفتر نخست‌وزیر تاکید می‌کند استارمر از اختیار پنج‌ساله برخوردار است و قصد کناره‌گیری ندارد؛ موضعی که یادآور ایستادگی تونی بلر در برابر فشارهای مشابه برای اعلام تاریخ خروج است.\"}],\"markDefs\":[],\"style\":\"normal\"}],\"categories\":[{\"id\":\"aaab5f90-9af2-487e-a259-d2b2ec9a09dd\",\"slug\":\"world\",\"title\":\"جهان\",\"type\":\"category\"}],\"hasTextToSpeech\":true,\"headline\":\"زنگ خطر برای احزاب؛ حزب اصلاح پادشاهی بریتانیا در کمین قدرت\",\"id\":\"d0fc9b15-2bcd-429c-a70c-bbe3c9469696\",\"image\":{\"alt\":null,\"asset\":{\"_ref\":\"image-7536d3f2534ff7b48a9231eb622baaac352e78be-800x533-jpg\",\"_type\":\"reference\"},\"caption\":null,\"crop\":null,\"hotspot\":null,\"metadata\":{\"dimensions\":{\"height\":533,\"width\":800},\"lqip\":\"data:image/jpeg;base64,\"}},\"language\":\"farsi\",\"lead\":\"انتخابات محلی هفتم مه ۲۰۲۶ در ۱۳۶ شورای انگلستان برگزار شد و بیش از پنج هزار کرسی را به رقابت گذاشت. مشارکت حدود ۴۳ درصد گزارش شد که به نوبه خود رکوردی تاریخی برای انتخابات‌های محلی در انگلستان به شمار می‌آید.\",\"publishedAt\":\"2026-05-08T13:47:28.784Z\",\"revision\":null,\"shorthandUrl\":null,\"slug\":\"202605088781\",\"tags\":[{\"color\":\"#0084bc\",\"id\":\"01eb8e6c-cbd7-4635-9101-554fa3be4b3a\",\"slug\":\"opinion\",\"title\":\"تحلیل\"}],\"type\":\"story\",\"updatedAt\":\"2026-05-08T14:22:31Z\"},{\"authors\":null,\"body\":[{\"_key\":\"4157a6cbbdcb\",\"_type\":\"block\",\"children\":[{\"_key\":\"4867ffa0255e\",\"_type\":\"span\",\"marks\":[],\"text\":\"روزنامه نیویورک‌تایمز جمعه ۱۸ اردیبهشت گزارش داد امارات، این کشور ثروتمند حاشیه خلیج فارس، دست به اخراج گسترده کارگران پاکستانی زده است؛ اقدامی که می‌تواند یکی از منابع مهم اشتغال پاکستان را با تهدید روبه‌رو کند.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"119e1bd86c95\",\"_type\":\"block\",\"children\":[{\"_key\":\"22437a677b3a\",\"_type\":\"span\",\"marks\":[],\"text\":\"بر اساس این گزارش، امارات از موضع نه‌چندان قاطع پاکستان در محکوم کردن حملات جمهوری اسلامی به این کشور ناراضی است؛ آن هم در شرایطی که اسلام‌آباد هم‌زمان می‌کوشد میان تهران و واشینگتن برای دستیابی به توافق صلح میانجی‌گری کند.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"be7d0bd06a94\",\"_type\":\"block\",\"children\":[{\"_key\":\"adf68bcdc5a5\",\"_type\":\"span\",\"marks\":[],\"text\":\"امارات در جریان جنگ اخیر هدف هزاران حمله موشکی و پهپادی حکومت ایران قرار گرفته و خساراتی را متحمل شده است.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"6284d61e126f\",\"_type\":\"block\",\"children\":[{\"_key\":\"3b684965e08b\",\"_type\":\"span\",\"marks\":[],\"text\":\"جمهوری اسلامی از ۱۴ اردیبهشت حملات خود را به امارات \"},{\"_key\":\"525ac38ede88\",\"_type\":\"span\",\"marks\":[\"b45c80c4edd5\"],\"text\":\"از سر گرفته است\"},{\"_key\":\"b07db818d537\",\"_type\":\"span\",\"marks\":[],\"text\":\".\"}],\"markDefs\":[{\"_key\":\"b45c80c4edd5\",\"_type\":\"link\",\"href\":\"https://www.iranintl.com/video/ott_b2b78bfef3fc44cab0bf84a15bf7a632\"}],\"style\":\"normal\"},{\"_key\":\"eda78eea7b38\",\"_type\":\"block\",\"children\":[{\"_key\":\"11c61b4b8752\",\"_type\":\"span\",\"marks\":[],\"text\":\"در آخرین مورد، سامانه‌های پدافند هوایی امارات ظهر ۱۸ اردیبهشت برای دفع حملات موشکی و پهپادی حکومت ایران وارد عمل شدند.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"fa68dff98acd\",\"_type\":\"block\",\"children\":[{\"_key\":\"d4640539284d\",\"_type\":\"span\",\"marks\":[],\"text\":\"به گفته منابع رسمی اماراتی، این حملات سه مجروح بر جای گذاشت.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"66f84b7b8418\",\"_type\":\"inlinecontent\",\"stories\":[{\"headline\":\" مشاور رییس امارات متحده عربی: جمهوری اسلامی یک تهدید بلندمدت است\",\"id\":\"89a958b1-5934-4d49-a32f-193911f21c8c\",\"image\":{\"_type\":\"figure\",\"asset\":{\"_ref\":\"image-d1e925c4c58c2f5a4afa51d5c48541f4eff65f6f-1000x666-jpg\",\"_type\":\"reference\"},\"crop\":{\"_type\":\"sanity.imageCrop\",\"bottom\":0.1518911455236733,\"left\":0.0007437643279682003,\"right\":0,\"top\":0.06067087397300302},\"hotspot\":{\"_type\":\"sanity.imageHotspot\",\"height\":0.7874379805033237,\"width\":0.9992562356720318,\"x\":0.5003718821639841,\"y\":0.4543898642246648}},\"language\":\"farsi\",\"publishedAt\":\"2026-04-24T16:14:10.115Z\",\"slug\":\"202604244525\",\"type\":\"story\",\"updatedAt\":null}]},{\"_key\":\"c4d518195acc\",\"_type\":\"block\",\"children\":[{\"_key\":\"4ab86581b9aa\",\"_type\":\"span\",\"marks\":[\"strong\"],\"text\":\"شکاف میان روایت‌های مردمی و رسمی\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"469ad89d63ec\",\"_type\":\"block\",\"children\":[{\"_key\":\"66d6737b9201\",\"_type\":\"span\",\"marks\":[],\"text\":\"نیویورک‌تایمز در ادامه گزارش، از گفت‌وگو با بیش از ۲۰ شهروند شیعه پاکستانی که به‌عنوان کارمند شرکت‌های اماراتی در این کشور مشغول به کار بودند، خبر داد.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"1727cf81cf47\",\"_type\":\"block\",\"children\":[{\"_key\":\"1a452b140b6c\",\"_type\":\"span\",\"marks\":[],\"text\":\"آنها تایید کردند که همگی ماه گذشته به‌طور ناگهانی بازداشت، زندانی و سپس از امارات اخراج شده‌اند.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"36c02f6cdb8e\",\"_type\":\"block\",\"children\":[{\"_key\":\"8db612b21052\",\"_type\":\"span\",\"marks\":[],\"text\":\"رهبران مذهبی شیعه در پاکستان برآورد می‌کنند که از اواخر فروردین‌ماه، احتمالا هزاران شیعه پاکستانی از امارات اخراج شده‌اند.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"2934c73a7e18\",\"_type\":\"block\",\"children\":[{\"_key\":\"e7d7d7375db3\",\"_type\":\"span\",\"marks\":[],\"text\":\"بر اساس این گزارش، شیعیان پاکستان که جمعیتی حدود ۳۵ میلیون نفر دارند و دارای «پیوندهای معنوی عمیق» با ایران هستند، بارها در این کشورِ عمدتا سنی‌مذهب هدف خشونت‌های فرقه‌ای قرار گرفته‌اند.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"61b1c71f3ece\",\"_type\":\"block\",\"children\":[{\"_key\":\"5ce05ea987ef\",\"_type\":\"span\",\"marks\":[],\"text\":\"دلایل اخراج شهروندان پاکستانی از امارات هنوز به‌طور رسمی مشخص نشده و مقام‌های دو کشور همچنان بر استحکام روابط دوجانبه تاکید دارند.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"5129241b2a54\",\"_type\":\"block\",\"children\":[{\"_key\":\"bc464823f9f9\",\"_type\":\"span\",\"marks\":[],\"text\":\"وزارت امور خارجه پاکستان گزارش‌ها درباره اخراج گسترده شهروندان این کشور از امارات را رد کرده و به پرسش‌ها درباره اینکه آیا شیعیان به‌طور خاص هدف قرار گرفته‌اند یا نه، پاسخی نداده است.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"b30c72b66ed4\",\"_type\":\"block\",\"children\":[{\"_key\":\"807000f02fb1\",\"_type\":\"span\",\"marks\":[],\"text\":\"طاهر اندرابی، سخنگوی این وزارتخانه، گفت پاکستانی‌های اخراج‌شده افرادی بوده‌اند که در امارات «مرتکب جرم» شده‌اند.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"b2dbdc9db8c5\",\"_type\":\"block\",\"children\":[{\"_key\":\"faec933aac83\",\"_type\":\"span\",\"marks\":[],\"text\":\"دولت امارات نیز تاکنون به درخواست‌ها برای اظهارنظر درباره این موضوع واکنشی نشان نداده است.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"70df0d0894c1\",\"_type\":\"block\",\"children\":[{\"_key\":\"4de120c9a3b6\",\"_type\":\"span\",\"marks\":[],\"text\":\"در روزهای اخیر، مقام‌های جمهوری اسلامی مواضع امارات در قبال \"},{\"_key\":\"8c7b35c80b42\",\"_type\":\"span\",\"marks\":[\"6f5599e4a6d0\"],\"text\":\"جنگ ایران\"},{\"_key\":\"6051cc697775\",\"_type\":\"span\",\"marks\":[],\"text\":\" را مورد انتقاد قرار داده و بارها از ادبیات تهدیدآمیز علیه این کشور استفاده کرده‌اند.\"}],\"markDefs\":[{\"_key\":\"6f5599e4a6d0\",\"_type\":\"link\",\"href\":\"https://www.iranintl.com/202605070462\"}],\"style\":\"normal\"},{\"_key\":\"c28167dfeb92\",\"_type\":\"block\",\"children\":[{\"_key\":\"33c9239282e9\",\"_type\":\"span\",\"marks\":[],\"text\":\"علی خضریان، عضو کمیسیون امنیت ملی مجلس، پیش‌تر گفت جمهوری اسلامی «امارات متحده عربی را مانند اقلیم کردستان عراق، پایگاه دشمن می‌داند».\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"eb267ab99e67\",\"_type\":\"block\",\"children\":[{\"_key\":\"7610cd17f9af\",\"_type\":\"span\",\"marks\":[],\"text\":\"او افزود: «ما دیگر امارات را همسایه نمی‌بینیم، آنها در حکم پایگاه متخاصم هستند.»\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"2b6b9cd3a88f\",\"_type\":\"inlinevideo\",\"video\":{\"id\":\"ott_f2c16a121ffc49a0a9b524edf6508243\",\"youtubeId\":\"UqqJecirBSc\",\"outlet\":\"iitv\"}},{\"_key\":\"22b3ef8c6700\",\"_type\":\"block\",\"children\":[{\"_key\":\"33606a3c4047\",\"_type\":\"span\",\"marks\":[\"strong\"],\"text\":\"آیا امارات از میانجی‌گری پاکستان خشمگین است؟\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"46030ca134b9\",\"_type\":\"block\",\"children\":[{\"_key\":\"99e32e8d2836\",\"_type\":\"span\",\"marks\":[],\"text\":\"به گزارش نیویورک‌تایمز، بیش از دو میلیون شهروند پاکستانی در امارات متحده عربی ساکن هستند و سال گذشته میلادی بیش از هشت میلیارد دلار حواله مالی به پاکستان ارسال کردند.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"000bb4238f69\",\"_type\":\"block\",\"children\":[{\"_key\":\"d8f258178838\",\"_type\":\"span\",\"marks\":[],\"text\":\"مفتاح اسماعیل، وزیر پیشین دارایی پاکستان، گفت: «حفظ روابط خوب با امارات برای اسلام‌آباد اهمیت دارد، اما در عین حال، نمی‌دانم پاکستان در این جنگ چه مسیر دیگری می‌توانست انتخاب کند.»\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"b3d506b3999b\",\"_type\":\"block\",\"children\":[{\"_key\":\"ab89ff45581e\",\"_type\":\"span\",\"marks\":[],\"text\":\"در سوی دیگر، ندیم قطیش، تحلیل‌گر اماراتی-لبنانی نزدیک به دولت امارات، گفت اسلام‌آباد ابتکار میانجی‌گری میان آمریکا و جمهوری اسلامی را «بدون هماهنگی کافی» با ابوظبی آغاز کرد.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"8e2ac1789b7b\",\"_type\":\"block\",\"children\":[{\"_key\":\"25bd83e954e1\",\"_type\":\"span\",\"marks\":[],\"text\":\"ماه گذشته، امارات وام ۳.۵ میلیارد دلاری خود به پاکستان را بازپس گرفت؛ رقمی نزدیک به یک‌پنجم ذخایر ارزی این کشور. پس از آن، عربستان سعودی با ارائه سپرده‌ای سه میلیارد دلاری برای تقویت ذخایر ارزی پاکستان وارد عمل شد.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"d7d35733b367\",\"_type\":\"block\",\"children\":[{\"_key\":\"fc7834101827\",\"_type\":\"span\",\"marks\":[],\"text\":\"محمدامین شهیدی، روحانی ساکن اسلام‌آباد و رهبر یک سازمان سیاسی شیعه، اعلام کرد این سازمان پنج هزار خانواده اخراج‌شده از امارات را ثبت کرده است.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"88404786f55d\",\"_type\":\"block\",\"children\":[{\"_key\":\"15a3a34ba97e\",\"_type\":\"span\",\"marks\":[],\"text\":\"او گفت: «در کشورهای خلیج فارس این تصور وجود دارد که هر شیعه‌ای از ایران حمایت می‌کند. با توجه به وخامت روابط، درخواست از دولت پاکستان برای گفت‌وگو با امارات بی‌فایده است.»\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"02ab3c0f937c\",\"_type\":\"block\",\"children\":[{\"_key\":\"dc454cb3e820\",\"_type\":\"span\",\"marks\":[],\"text\":\"به گفته شهیدی و شماری دیگر از منابع، روند اخراج شهروندان پاکستانی از ۱۹ فروردین آغاز شد؛ زمانی که تهران و واشینگتن با میانجی‌گری اسلام‌آباد بر سر برقراری آتش‌بس موقت به توافق رسیدند.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"b3076ae24c6a\",\"_type\":\"block\",\"children\":[{\"_key\":\"fac01a47b1bb\",\"_type\":\"span\",\"marks\":[],\"text\":\"به گزارش نیویورک‌تایمز، شمار نامشخصی از کارگران پاکستانی نیز در پی از دست دادن شغل خود به‌دلیل پیامدهای جنگ، امارات را ترک کرده‌اند.\"}],\"markDefs\":[],\"style\":\"normal\"}],\"categories\":[{\"id\":\"c4f6cf29-2688-4b26-8595-a02c0ffd0cf1\",\"slug\":\"hmlh-aamryka-w-asraeyl-bh-jmhwry-aslamy\",\"title\":\"جنگ علیه جمهوری اسلامی\",\"type\":\"supernews\"},{\"id\":\"aaab5f90-9af2-487e-a259-d2b2ec9a09dd\",\"slug\":\"world\",\"title\":\"جهان\",\"type\":\"category\"}],\"hasTextToSpeech\":true,\"headline\":\"اخراج گسترده کارگران پاکستانی‌ از امارات در پی نارضایتی ابوظبی از مواضع اسلام‌آباد\",\"id\":\"61bb1b6f-4e80-4c19-9252-4d254ba247d6\",\"image\":{\"alt\":null,\"asset\":{\"_ref\":\"image-f73d8e90c4afc981b0078fd7519965f37ae82558-4764x3176-jpg\",\"_type\":\"reference\"},\"caption\":null,\"crop\":null,\"hotspot\":null,\"metadata\":{\"dimensions\":{\"height\":3176,\"width\":4764},\"lqip\":\"data:image/jpeg;base64,\"}},\"language\":\"farsi\",\"lead\":\"هرچند پاکستان کوشیده در مسیر پایان دادن به جنگ ایران نقش‌آفرینی کند، تحولات اخیر به روابط اسلام‌آباد با یکی از شرکای دیرینه‌اش، امارات متحده عربی، آسیب زده است.\",\"publishedAt\":\"2026-05-08T12:50:52.146Z\",\"revision\":null,\"shorthandUrl\":null,\"slug\":\"202605081933\",\"tags\":null,\"type\":\"story\",\"updatedAt\":\"2026-05-08T13:35:12Z\"},{\"authors\":null,\"body\":[{\"_key\":\"51fcc931a653\",\"_type\":\"block\",\"children\":[{\"_key\":\"38c9b2150cec\",\"_type\":\"span\",\"marks\":[],\"text\":\"بر اساس گزارشی که ارم‌نیوز جمعه ۱۸ اردیبهشت منتشر کرد، در فرمول مطرح‌شده برای تفاهم میان تهران و واشینگتن، اولویت با توقف درگیری‌ها، رسیدگی به بحران تنگه هرمز و آغاز یک مسیر مذاکراتی کوتاه‌مدت است و موضوعاتی مانند برنامه هسته‌ای حکومت ایران، توان موشکی و نفوذ منطقه‌ای جمهوری اسلامی، به مراحل بعدی منتقل شده‌اند.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"fd90768e8d86\",\"_type\":\"block\",\"children\":[{\"_key\":\"bac4ab280d73\",\"_type\":\"span\",\"marks\":[],\"text\":\"منابع دیپلماتیک منطقه‌ای به ارم‌نیوز گفته‌اند این طرح پس از دو تحول همزمان در ساعات اخیر شکل گرفته است. از جمله این تحولات، توقف موقت عملیات «پروژه آزادی» از سوی دونالد ترامپ، رییس‌جمهوری آمریکا، برای اسکورت کشتی‌ها در تنگه هرمز بوده است.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"150f5e70bf48\",\"_type\":\"inlinevideo\",\"video\":{\"id\":\"ott_4b245868cc8045c48494c822f4ecfdbb\",\"youtubeId\":null,\"outlet\":\"iitv\"}},{\"_key\":\"aac9e9e23202\",\"_type\":\"block\",\"children\":[{\"_key\":\"d93348295b8a\",\"_type\":\"span\",\"marks\":[],\"text\":\"به گفته این منابع، تمرکز واشینگتن بر موضوعات فوری و قابل سنجش در کوتاه‌مدت، از جمله امنیت کشتیرانی و توقف درگیری‌ها، باعث شده است اسرائیل در ساز و کار اجرایی مرحله نخست نقشی نداشته باشد. \"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"3f1e2838ee42\",\"_type\":\"block\",\"children\":[{\"_key\":\"d93348295b8a\",\"_type\":\"span\",\"marks\":[],\"text\":\"با این حال، هماهنگی‌های سیاسی و امنیتی میان آمریکا و اسرائیل همچنان ادامه دارد.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"f98d3200afe7\",\"_type\":\"block\",\"children\":[{\"_key\":\"2c63664a7756\",\"_type\":\"span\",\"marks\":[],\"text\":\"گیلا گاملیل، وزیر علوم و فناوری اسرائیل، ۱۷ اردیبهشت \"},{\"_key\":\"2ac9aa3193b7\",\"_type\":\"span\",\"marks\":[\"949b88fde575\"],\"text\":\"گفت\"},{\"_key\":\"7a56ebf1317d\",\"_type\":\"span\",\"marks\":[],\"text\":\" که بنیامین نتانیاهو، نخست‌وزیر اسرائیل، و ترامپ درباره مذاکرات با جمهوری اسلامی به طور مداوم گفت‌وگو می‌کنند و موضوع هسته‌ای از اهداف مشترک دو طرف است.\"}],\"markDefs\":[{\"_key\":\"949b88fde575\",\"_type\":\"link\",\"href\":\"https://www.iranintl.com/fa/202605077471\"}],\"style\":\"normal\"},{\"_key\":\"75e6411b7048\",\"_type\":\"block\",\"children\":[{\"_key\":\"aa94a97bb34a\",\"_type\":\"span\",\"marks\":[],\"text\":\"رسانه‌های اسرائیلی نیز تایید کردند نتانیاهو در جریان این روند قرار دارد و گفته است این تحولات برای او غافلگیرکننده نبوده و هماهنگی‌ها با واشینگتن به‌صورت مستمر ادامه دارد.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"2bdfac0433a8\",\"_type\":\"inlinecontent\",\"stories\":[{\"headline\":\"نتانیاهو: برای تهدیدکنندگان اسرائیل هیچ مصونیتی وجود ندارد\",\"id\":\"c23fd02d-7f54-42a8-9077-dd433a844dfe\",\"image\":{\"_type\":\"image\",\"asset\":{\"_ref\":\"image-06bb6466cc08a7eb98a9db8732f4006ae1050662-960x640-jpg\",\"_type\":\"reference\"},\"crop\":{\"_type\":\"sanity.imageCrop\",\"bottom\":0.011160853170884,\"left\":0.05540560380789945,\"right\":0,\"top\":0},\"hotspot\":{\"_type\":\"sanity.imageHotspot\",\"height\":0.988839146829116,\"width\":0.9445943961921005,\"x\":0.5277028019039497,\"y\":0.494419573414558}},\"language\":\"farsi\",\"publishedAt\":\"2026-05-07T14:10:45.083Z\",\"slug\":\"202605071913\",\"type\":\"story\",\"updatedAt\":null}]},{\"_key\":\"93164338e4a5\",\"_type\":\"block\",\"children\":[{\"_key\":\"24cae7739f42\",\"_type\":\"span\",\"marks\":[],\"text\":\"در این چارچوب، واشینگتن تلاش دارد مرحله نخست را بر پایه اقداماتی تنظیم کند که در کوتاه‌مدت قابل اجرا و ارزیابی باشند و سپس موضوعات پیچیده‌تر را به مذاکرات بعدی منتقل کند. رویکردی که جایگاه اسرائیل را در سطح هماهنگی‌های راهبردی حفظ کرده اما آن را از متن اجرای اولیه کنار گذاشته است.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"0291caef1a95\",\"_type\":\"block\",\"children\":[{\"_key\":\"e0e974627e23\",\"_type\":\"span\",\"marks\":[],\"text\":\"در این میان، برخی تحلیلگران معتقدند اسرائیل همچنان بر لزوم اعمال شروط سخت‌گیرانه‌تر در موضوعاتی مانند غنی‌سازی، برنامه موشکی و ساز و کار اجرای توافق تاکید دارد.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"935849186fd3\",\"_type\":\"block\",\"children\":[{\"_key\":\"42eed1c776be\",\"_type\":\"span\",\"marks\":[],\"text\":\"واکنش بازارهای جهانی به احتمال کاهش تنش سریع بوده است. \"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"a519d0d4c8c6\",\"_type\":\"block\",\"children\":[{\"_key\":\"42eed1c776be\",\"_type\":\"span\",\"marks\":[],\"text\":\"گزارش‌ها حاکی از کاهش قیمت نفت و افزایش شاخص‌های سهام در پی کاهش نگرانی‌ها از اختلال در تردد از تنگه هرمز است.\"}],\"markDefs\":[],\"style\":\"normal\"}],\"categories\":[{\"id\":\"c4f6cf29-2688-4b26-8595-a02c0ffd0cf1\",\"slug\":\"hmlh-aamryka-w-asraeyl-bh-jmhwry-aslamy\",\"title\":\"جنگ علیه جمهوری اسلامی\",\"type\":\"supernews\"},{\"id\":\"67bd595d-41c2-41e8-8ba7-42f76fd9e49e\",\"slug\":\"iran\",\"title\":\"ایران\",\"type\":\"category\"},{\"id\":\"aaab5f90-9af2-487e-a259-d2b2ec9a09dd\",\"slug\":\"world\",\"title\":\"جهان\",\"type\":\"category\"}],\"hasTextToSpeech\":true,\"headline\":\"ارم‌نیوز: یادداشت تفاهم تهران و واشینگتن توافقی جامع نیست و بر کاهش تنش‌ها تمرکز دارد\",\"id\":\"71689f6d-40c1-4093-ab35-2d3a465ee5f4\",\"image\":{\"alt\":null,\"asset\":{\"_ref\":\"image-07c8375bf238eb643e8246660086bf9cb4bbb75a-1920x1080-png\",\"_type\":\"reference\"},\"caption\":null,\"crop\":{\"_type\":\"sanity.imageCrop\",\"bottom\":0,\"left\":0.0317845943384412,\"right\":0.01869698029744349,\"top\":0},\"hotspot\":{\"_type\":\"sanity.imageHotspot\",\"height\":0.7872716797365119,\"width\":0.869122045141938,\"x\":0.5,\"y\":0.39363583986825595},\"metadata\":{\"dimensions\":{\"height\":1080,\"width\":1920},\"lqip\":\"$67\"}},\"language\":\"farsi\",\"lead\":\"رسانه مستقر در امارات متحده عربی نوشت که چارچوب تفاهم‌نامه مطرح‌شده میان آمریکا و جمهوری اسلامی، بیشتر یک توافق محدود برای مهار تنش است که بر توقف درگیری‌ها، بازگشایی تنگه هرمز و آغاز مذاکرات کوتاه‌مدت تمرکز دارد و مسائل کلیدی، به مراحل بعدی موکول شده‌اند.\",\"publishedAt\":\"2026-05-08T11:46:36.631Z\",\"revision\":null,\"shorthandUrl\":null,\"slug\":\"202605088965\",\"tags\":null,\"type\":\"story\",\"updatedAt\":\"2026-05-08T11:46:46Z\"}],\"allowSlugTitleChange\":true,\"translations\":{\"sectionTitle\":\"مطالب بیشتر\",\"loadMore\":\"بارگذاری بیشتر\",\"loading\":\"در حال بارگذاری...\",\"currentArticle\":\"این مقاله\",\"share\":\"common.share\"}}]\n"])</script><script>(function(){function c(){var b=a.contentDocument||a.contentWindow.document;if(b){var d=b.createElement('script');d.innerHTML="window.__CF$cv$params={r:'9f8b12ceff55aefe',t:'MTc3ODI3MDY2Ng=='};var a=document.createElement('script');a.src='/cdn-cgi/challenge-platform/scripts/jsd/main.js';document.getElementsByTagName('head')[0].appendChild(a);";b.getElementsByTagName('head')[0].appendChild(d)}}if(document.body){var a=document.createElement('iframe');a.height=1;a.width=1;a.style.position='absolute';a.style.top=0;a.style.left=0;a.style.border='none';a.style.visibility='hidden';document.body.appendChild(a);if('loading'!==document.readyState)c();else if(window.addEventListener)document.addEventListener('DOMContentLoaded',c);else{var e=document.onreadystatechange||function(){};document.onreadystatechange=function(b){e(b);'loading'!==document.readyState&&(document.onreadystatechange=e,c())}}}})();</script></body></html>