anguage\":\"farsi\",\"leadRaw\":[{\"_key\":\"48a484676875\",\"_type\":\"block\",\"children\":[{\"_key\":\"495f8f4e1951\",\"_type\":\"span\",\"marks\":[],\"text\":\"روایت‌های رسیده به ایران‌اینترنشنال حاکی از فشارهای اقتصادی چند جانبه به مردم است؛ از افزایش قیمت روزانه کالاهای اساسی گرفته تا کمبود دارو، تعطیلی مشاغل و تعدیل نیروها.\"}],\"markDefs\":[],\"style\":\"normal\"}],\"publishedAt\":\"2026-05-06T13:58:23.121Z\",\"shorthandUrl\":null,\"slug\":\"202605064842\",\"type\":\"story\"},\"layout\":{\"showAuthor\":false},\"dictionary\":\"$35:props:children:props:dictionary\"}]}],[\"$\",\"div\",\"01731c78-5ef4-4b6d-999e-ab5b985ba02b\",{\"className\":\"HotTakeHorizontalCluster-module-scss-module__fgOhha__additionalChunkItem\",\"children\":[\"$\",\"$L62\",null,{\"variant\":\"card\",\"item\":{\"firstTag\":{\"color\":\"#2300bc\",\"slug\":\"rwayt-shma\",\"title\":\"روایت شما\"},\"headline\":\"گرانی مواد خوراکی و شوینده‌ها؛ هزینه خرید سوپرمارکتی ۲.۵ برابر شده است\",\"id\":\"01731c78-5ef4-4b6d-999e-ab5b985ba02b\",\"image\":{\"alt\":null,\"asset\":{\"_ref\":\"image-912265d99f4f9db02ba58b0bf89682346e429595-1532x1027-png\",\"_type\":\"reference\"},\"caption\":null,\"crop\":null,\"hotspot\":null,\"metadata\":{\"dimensions\":{\"height\":1027,\"width\":1532},\"lqip\":\"$7c\"}},\"language\":\"farsi\",\"leadRaw\":[{\"_key\":\"5e560a3cb559\",\"_type\":\"block\",\"children\":[{\"_key\":\"1b70de4165a6\",\"_type\":\"span\",\"marks\":[],\"text\":\"افزایش شدید قیمت کالاهای اساسی و مصرفی در ایران، به گفته شهروندان، فشار اقتصادی بی‌سابقه‌ای بر زندگی روزمره وارد کرده و توان خرید بسیاری از خانواده‌ها را به شدت کاهش داده است.\"}],\"markDefs\":[],\"style\":\"normal\"}],\"publishedAt\":\"2026-05-05T12:48:07.534Z\",\"shorthandUrl\":null,\"slug\":\"202605054877\",\"type\":\"story\"},\"layout\":{\"showAuthor\":false},\"dictionary\":\"$35:props:children:props:dictionary\"}]}]]}]}]]}]\n"])</script><script>self.__next_f.push([1,"7d:T4aa,data:image/png;base64,:[\"$\",\"$L62\",null,{\"variant\":\"featured\",\"item\":{\"authors\":null,\"firstTag\":null,\"headline\":\"عربستان و کویت محدودیت‌های دسترسی نظامی آمریکا به پایگاه‌ها و حریم هوایی خود را لغو کردند\",\"id\":\"87142558-cd91-4067-a4f3-51fb2a31156b\",\"image\":{\"alt\":null,\"asset\":{\"_ref\":\"image-5a70aec6d083c30617511ee39060a5ce198c4d9a-800x531-png\",\"_type\":\"reference\"},\"caption\":null,\"crop\":null,\"hotspot\":null,\"metadata\":{\"dimensions\":{\"height\":531,\"width\":800},\"lqip\":\"$7d\"}},\"language\":\"farsi\",\"leadRaw\":[{\"_key\":\"f8b0987e07ba\",\"_type\":\"block\",\"children\":[{\"_key\":\"552283b9902b\",\"_type\":\"span\",\"marks\":[],\"text\":\"روزنامه وال‌استریت ژورنال گزارش داد که عربستان سعودی و کویت محدودیت‌های دسترسی نظامی آمریکا به پایگاه‌ها و حریم هوایی خود را لغو کردند. این اقدام راه را برای ازسرگیری «پروژه آزادی» آمریکا برای باز کردن تنگه هرمز را هموار می‌کند.\"}],\"markDefs\":[],\"style\":\"normal\"}],\"publishedAt\":\"2026-05-07T17:59:52.597Z\",\"shorthandUrl\":null,\"slug\":\"202605072414\",\"type\":\"story\"},\"layout\":{\"showLead\":false,\"showAuthor\":true},\"dictionary\":\"$35:props:children:props:dictionary\"}]\n7e:[[\"$\",\"source\",null,{\"media\":\"(min-width: 1024px)\",\"srcSet\":\"https://i.iranintl.com/images/rdk9umy0/production/4ae00dc5ebf58ab4094b574210fb2940aeafff6b-1192x1018.jpg?rect=31,0,1130,753\u0026w=600\u0026h=400\u0026q=85\u0026fit=max\u0026auto=format\",\"sizes\":\"100vw\"}],[\"$\",\"source\",null,{\"media\":\"(max-width: 600px)\",\"srcSet\":\"https://i.iranintl.com/images/rdk9umy0/production/4ae00dc5ebf58ab4094b574210fb2940aeafff6b-1192x1018.jpg?rect=31,0,1130,753\u0026w=600\u0026h=400\u0026q=70\u0026fit=max\u0026auto=format\",\"sizes\":\"100vw\"}],[\"$\",\"img\",null,{\"src\":\"https://i.iranintl.com/images/rdk9umy0/production/4ae00dc5ebf58ab4094b574210fb2940aeafff6b-1192x1018.jpg?rect=31,0,1130,753\u0026w=600\u0026h=400\u0026q=70\u0026fit=max\u0026auto=format\",\"alt\":\"مقتدی صدر: گروه‌های مسلح نباید در دولت آینده عراق حضور داشته باشند\",\"style\":{\"w