"$L29\",null,{\"moduleIds\":[\"7178822870767757824\"]}],[\"$\",\"$L2a\",null,{\"language\":\"farsi\",\"locale\":\"fa\",\"translations\":\"$17:props:dictionary:latestNews\"}]]}]\n23:[\"$\",\"$L2b\",null,{\"lang\":\"fa\",\"dictionary\":\"$17:props:dictionary:cookieBanner\"}]\n3d:T53e,data:image/png;base64,:T40e,data:image/png;base64,"])</script><script>self.__next_f.push([1,"kJggg==3f:T4aa,data:image/png;base64,:T40e,data:image/png;base64,:T442,data:image/png;base64,"])</script><script>self.__next_f.push([1,"e:[\"$\",\"div\",null,{\"className\":\"page\",\"children\":[[[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"dangerouslySetInnerHTML\":{\"__html\":\"{\\\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":\\\"WebSite\\\",\\\"@id\\\":\\\"https://www.iranintl.com#website\\\",\\\"url\\\":\\\"https://www.iranintl.com\\\",\\\"name\\\":\\\"Iran International\\\",\\\"inLanguage\\\":\\\"fa\\\",\\\"dateModified\\\":\\\"2026-05-08T18:10:57.000Z\\\",\\\"publisher\\\":{\\\"@type\\\":\\\"Organization\\\",\\\"@id\\\":\\\"https://www.iranintl.com#organization\\\",\\\"name\\\":\\\"Iran International\\\",\\\"url\\\":\\\"https://www.iranintl.com\\\",\\\"logo\\\":{\\\"@type\\\":\\\"ImageObject\\\",\\\"url\\\":\\\"https://www.iranintl.com/images/ii/logo.svg\\\"}},\\\"potentialAction\\\":{\\\"@type\\\":\\\"SearchAction\\\",\\\"target\\\":{\\\"@type\\\":\\\"EntryPoint\\\",\\\"urlTemplate\\\":\\\"https://www.iranintl.com/search?q={search_term_string}\\\"},\\\"query-input\\\":\\\"required name=search_term_string\\\"}}\"}}],false,[\"$\",\"section\",null,{\"className\":\"page__container\",\"children\":[[\"$\",\"main\",null,{\"className\":\"page__main home__clusters home__clusters--hot-takes\",\"children\":[\"$L2c\",\"$L2d\",\"$L2e\",\"$L2f\",\"$L30\",\"$L31\",\"$L32\",\"$L33\",\"$L34\",\"$L35\",\"$L36\",\"$L37\",\"$L38\",\"$L39\",\"$L3a\",\"$L3b\"]}],[\"$\",\"$L3c\",null,{\"widgets\":[{\"data\":{\"id\":\"b11421c3-691a-4281-85a5-8d206d3a5a67\",\"title\":\"پخش زنده\",\"type\":\"livestream\"},\"key\":\"b0bbbbc783df\",\"type\":\"livestream\"},{\"data\":{\"items\":[{\"authors\":null,\"headline\":\"جمهوری اسلامی نهاد جدیدی برای کنترل تنگه هرمز ایجاد کرد\",\"id\":\"aff7c282-d795-4de9-8b4e-fae7b369f734\",\"image\":{\"alt\":null,\"asset\":{\"_ref\":\"image-60e181abdace2d3998267bca30ead36acaee883b-5500x3667-jpg\",\"_type\":\"reference\"},\"caption\":null,\"crop\":null,\"hotspot\":null,\"metadata\":{\"dimensions\":{\"height\":3667,\"width\":5500},\"lqip\":\"data:image/jpeg;base64,\"}},\"language\":\"farsi\",\"lead\":[{\"_key\":\"6f01caea7c78\",\"_type\":\"block\",\"children\":[{\"_key\":\"96776de60f01\",\"_type\":\"span\",\"marks\":[],\"text\":\"رسانه‌های بین‌المللی به نقل از داده‌های کشتی‌رانی گزارش دادند که جمهوری اسلامی نهاد جدیدی را برای کنترل کشتیرانی در تنگه هرمز ایجاد کرده است؛ هر چند که مقامات تهران می‌گویند که در حال بررسی توافق صلح با آمریکا هستند.\"}],\"markDefs\":[],\"style\":\"normal\"}],\"publishedAt\":\"2026-05-07T19:37:19.905Z\",\"shorthandUrl\":null,\"slug\":\"202605071065\",\"tag\":null,\"tags\":null,\"type\":\"story\"},{\"authors\":null,\"headline\":\"چین ۲ وزیر دفاع پیشین خود را به اعدام تعلیقی محکوم کرد\",\"id\":\"3f456983-02eb-45da-af89-61a01e2da666\",\"image\":{\"alt\":null,\"asset\":{\"_ref\":\"image-981034b2e3edc000c0f0e789f7f6344136fea262-840x560-jpg\",\"_type\":\"reference\"},\"caption\":null,\"crop\":null,\"hotspot\":null,\"metadata\":{\"dimensions\":{\"height\":560,\"width\":840},\"lqip\":\"data:image/jpeg;base64,\"}},\"language\":\"farsi\",\"lead\":[{\"_key\":\"f1cbfe171881\",\"_type\":\"block\",\"children\":[{\"_key\":\"b495f34f59f4\",\"_type\":\"span\",\"marks\":[],\"text\":\"دادگاه نظامی چین در حکمی کم‌سابقه دو وزیر دفاع پیشین این کشور، وی فنگه و لی شانگفو، را به اتهام فساد و رشوه‌خواری به اعدام با دو سال تعلیق محکوم کرد.\"}],\"markDefs\":[],\"style\":\"normal\"}],\"publishedAt\":\"2026-05-07T13:38:55.280Z\",\"shorthandUrl\":null,\"slug\":\"202605072769\",\"tag\":null,\"tags\":null,\"type\":\"story\"},{\"authors\":null,\"headline\":\"ضربه سنگین به حزب کارگر در انتخابات محلی و پیروزی گسترده حزب اصلاح بریتانیا\",\"id\":\"eYS8cALT8WYoU8YjHhr4nf6\",\"image\":{\"alt\":\"نیگل فراج، رهبر Reform UK، پس از اعلام نتایج انتخابات محلی در تالار شهر هاورینگ، لندن‌بورو آف هاورینگ، بریتانیا، ۸ مهٔ ۲۰۲۶.\\n\\nرویترز/جک تیلور\",\"asset\":{\"_ref\":\"image-4a54c91b1b22d90d62aa35b1394fac49e762197f-800x534-jpg\",\"_type\":\"reference\"},\"caption\":\"انتخابات محلی بریتانیا در سال ۲۰۲۶\",\"crop\":null,\"hotspot\":null,\"metadata\":{\"dimensions\":{\"height\":534,\"width\":800},\"lqip\":\"data:image/jpeg;base64,\"}},\"language\":\"farsi\",\"lead\":[{\"_key\":\"bbd72643e589\",\"_type\":\"block\",\"children\":[{\"_key\":\"9d3fdc011b63\",\"_type\":\"span\",\"marks\":[],\"text\":\"حزب کارگر بریتانیا به رهبری کی‌یر استارمر در انتخابات محلی این کشور با شکست‌های سنگین روبه‌رو شد. خبرگزاری رویترز نوشت این نتایج عمق نارضایتی از نخست‌وزیر بریتانیا را نشان داد و تنها دو سال پس از پیروزی قاطع او در انتخابات سراسری، تردیدها را درباره آینده سیاسی‌اش افزایش داد.\"}],\"markDefs\":[],\"style\":\"normal\"}],\"publishedAt\":\"2026-05-08T09:32:56.255Z\",\"shorthandUrl\":null,\"slug\":\"2026050866620\",\"tag\":null,\"tags\":null,\"type\":\"article\"},{\"authors\":null,\"headline\":\"مجری محافظه‌کار توافق احتمالی با ایران را «توافقی وحشتناک» خواند\",\"id\":\"da9eb966-b98b-4db3-bbb7-93f0724e48de\",\"image\":{\"alt\":null,\"asset\":{\"_ref\":\"image-7158af2d9ccb14baa32d4022c155ef510dda4142-992x661-png\",\"_type\":\"reference\"},\"caption\":null,\"crop\":{\"_type\":\"sanity.imageCrop\",\"bottom\":0,\"left\":0,\"right\":0,\"top\":0},\"hotspot\":{\"_type\":\"sanity.imageHotspot\",\"height\":1,\"width\":0.8644584083937823,\"x\":0.5,\"y\":0.5},\"metadata\":{\"dimensions\":{\"height\":661,\"width\":992},\"lqip\":\"$3d\"}},\"language\":\"farsi\",\"lead\":[{\"_key\":\"82ec8635a7ec\",\"_type\":\"block\",\"children\":[{\"_key\":\"54a367f7107f\",\"_type\":\"span\",\"marks\":[],\"text\":\"هیو هیوئیت، مجری محافظه‌کار رادیویی آمریکا، از چارچوب احتمالی توافق میان ایالات متحده و حکومت ایران به شدت انتقاد کرده و آن را «توافقی وحشتناک» توصیف کرد. این انتقاد در حالی است که دولت ترامپ نشانه‌هایی از آمادگی برای مذاکره با تهران به منظور پایان دادن درگیری نشان داده است.\\n\"}],\"markDefs\":[],\"style\":\"normal\"}],\"publishedAt\":\"2026-05-06T22:31:51.005Z\",\"shorthandUrl\":null,\"slug\":\"202605068830\",\"tag\":null,\"tags\":null,\"type\":\"story\"},{\"authors\":null,\"headline\":\"آیا ترامپ پیروزی در جنگ ایران را با شکست عوض می‌کند؟\",\"id\":\"a1645ada-5c78-4809-a3b1-ae804e14fb1b\",\"image\":{\"alt\":null,\"asset\":{\"_ref\":\"image-b09750565edb034804897f4c221b84b40864deb2-1920x1080-png\",\"_type\":\"reference\"},\"caption\":null,\"crop\":null,\"hotspot\":null,\"metadata\":{\"dimensions\":{\"height\":1080,\"width\":1920},\"lqip\":\"$3e\"}},\"language\":\"farsi\",\"lead\":[{\"_key\":\"7c76c10ebb02\",\"_type\":\"block\",\"children\":[{\"_key\":\"088ac6132f06\",\"_type\":\"span\",\"marks\":[],\"text\":\"مارک ای. تیسن، ستون‌نویس روزنامه واشینگتن‌پست در تحلیلی به تصمیمات و اقدامات اخیر دونالد ترامپ، رییس‌جمهوری آمریکا، پرداخته و هشدار داده که او در آستانه آن است که پیروزی در جنگ ایران را با شکست معاوضه کند زیرا نحوه پایان دادن به جنگ، به اندازه نحوه آغاز آن اهمیت دارد.\"}],\"markDefs\":[],\"style\":\"normal\"}],\"publishedAt\":\"2026-05-07T18:48:34.607Z\",\"shorthandUrl\":null,\"slug\":\"202605077265\",\"tag\":{\"color\":\"#0084bc\",\"id\":\"01eb8e6c-cbd7-4635-9101-554fa3be4b3a\",\"slug\":\"opinion\",\"title\":\"تحلیل\"},\"tags\":[{\"color\":\"#0084bc\",\"id\":\"01eb8e6c-cbd7-4635-9101-554fa3be4b3a\",\"slug\":\"opinion\",\"title\":\"تحلیل\"}],\"type\":\"story\"},{\"authors\":null,\"headline\":\"عربستان و کویت محدودیت‌های دسترسی نظامی آمریکا به پایگاه‌ها و حریم هوایی خود را لغو کردند\",\"id\":\"87142558-cd91-4067-a4f3-51fb2a31156b\",\"image\":{\"alt\":null,\"asset\":{\"_ref\":\"image-5a70aec6d083c30617511ee39060a5ce198c4d9a-800x531-png\",\"_type\":\"reference\"},\"caption\":null,\"crop\":null,\"hotspot\":null,\"metadata\":{\"dimensions\":{\"height\":531,\"width\":800},\"lqip\":\"$3f\"}},\"language\":\"farsi\",\"lead\":[{\"_key\":\"f8b0987e07ba\",\"_type\":\"block\",\"children\":[{\"_key\":\"552283b9902b\",\"_type\":\"span\",\"marks\":[],\"text\":\"روزنامه وال‌استریت ژورنال گزارش داد که عربستان سعودی و کویت محدودیت‌های دسترسی نظامی آمریکا به پایگاه‌ها و حریم هوایی خود را لغو کردند. این اقدام راه را برای ازسرگیری «پروژه آزادی» آمریکا برای باز کردن تنگه هرمز را هموار می‌کند.\"}],\"markDefs\":[],\"style\":\"normal\"}],\"publishedAt\":\"2026-05-07T17:59:52.597Z\",\"shorthandUrl\":null,\"slug\":\"202605072414\",\"tag\":null,\"tags\":null,\"type\":\"story\"},{\"authors\":null,\"headline\":\"جمهوری اسلامی و طالبان روی اپلیکیشن نظارتی برای رصد کاربران در افغانستان همکاری کرده‌اند\",\"id\":\"1538642f-cf0f-4b30-953d-5ce0c91ff8c6\",\"image\":{\"alt\":null,\"asset\":{\"_ref\":\"image-e4cb413fef06bb1660cf4387ce831ac1bc39317b-576x384-jpg\",\"_type\":\"reference\"},\"caption\":null,\"crop\":null,\"hotspot\":null,\"metadata\":{\"dimensions\":{\"height\":384,\"width\":576},\"lqip\":\"data:image/jpeg;base64,\"}},\"language\":\"farsi\",\"lead\":[{\"_key\":\"31760ac960ff\",\"_type\":\"block\",\"children\":[{\"_key\":\"aaaba5108750\",\"_type\":\"span\",\"marks\":[],\"text\":\"بر اساس اطلاعات رسیده به افغانستان‌اینترنشنال، طالبان و جمهوری اسلامی در توسعه یک اپلیکیشن موبایل همکاری کرده‌اند که گفته می‌شود توانایی رصد و نظارت بر کاربران داخل افغانستان را دارد.\"}],\"markDefs\":[],\"style\":\"normal\"}],\"publishedAt\":\"2026-05-07T11:38:57.163Z\",\"shorthandUrl\":null,\"slug\":\"202605073040\",\"tag\":{\"color\":\"#cf2023\",\"id\":\"14f01857-0b08-48f3-bde7-b49d815d7b19\",\"slug\":\"exclusive\",\"title\":\"اختصاصی\"},\"tags\":[{\"color\":\"#cf2023\",\"id\":\"14f01857-0b08-48f3-bde7-b49d815d7b19\",\"slug\":\"exclusive\",\"title\":\"اختصاصی\"}],\"type\":\"story\"},{\"authors\":null,\"headline\":\"کشورها مسافران کشتی تفریحی آلوده به هانتاویروس را ردیابی می‌کنند\",\"id\":\"eG9XmAK6OZ4x1zCqhr4AWa7\",\"image\":{\"alt\":\"نمای پهپادی از کشتی کروز «ام‌وی هونجیوس» حامل مسافرانی با موارد مشکوک هانتاویروس، هنگام ترک پرایا، کیپ ورد، ۶ مهٔ ۲۰۲۶.\\n\\nرویترز/عکاس آزاد\",\"asset\":{\"_ref\":\"image-5c5c2230c87d60a8fae5cc27fdf779cc9c8c6f99-800x523-jpg\",\"_type\":\"reference\"},\"caption\":\"نمای پهپادی از کشتی کروز حامل مسافرانی با موارد مشکوک هانتاویروس در حال ترک پرایا\",\"crop\":null,\"hotspot\":null,\"metadata\":{\"dimensions\":{\"height\":523,\"width\":800},\"lqip\":\"data:image/jpeg;base64,\"}},\"language\":\"farsi\",\"lead\":[{\"_key\":\"c0724ca5c6a1\",\"_type\":\"block\",\"children\":[{\"_key\":\"72d5e8180461\",\"_type\":\"span\",\"marks\":[],\"text\":\"پس از شیوع هانتاویروس در یک کشتی تفریحی، کشورهای مختلف جهان از روز پنج‌شنبه تلاش کردند مانع گسترش بیشتر این ویروس شوند؛ از جمله با ردیابی افرادی که پیش از شناسایی ویروس از این کشتی پیاده شده‌اند و همچنین کسانی که از آن زمان با آن‌ها تماس نزدیک داشته‌اند.\"}],\"markDefs\":[],\"style\":\"normal\"}],\"publishedAt\":\"2026-05-08T07:24:58.532Z\",\"shorthandUrl\":null,\"slug\":\"2026050871360\",\"tag\":null,\"tags\":null,\"type\":\"article\"},{\"authors\":null,\"headline\":\"یادداشت خودکشی منتسب به جفری اپستین با حکم قاضی فدرال آمریکا منتشر شد\",\"id\":\"8b60f60b-2373-4c66-848d-7e5a95942e9a\",\"image\":{\"alt\":null,\"asset\":{\"_ref\":\"image-6e0b7af8b0e99156cf925384e714ff85e4649e0c-5500x4125-jpg\",\"_type\":\"reference\"},\"caption\":null,\"crop\":null,\"hotspot\":null,\"metadata\":{\"dimensions\":{\"height\":4125,\"width\":5500},\"lqip\":\"data:image/jpeg;base64,\"}},\"language\":\"farsi\",\"lead\":[{\"_key\":\"c4ae3d69b8be\",\"_type\":\"block\",\"children\":[{\"_key\":\"6813681f70d8\",\"_type\":\"span\",\"marks\":[],\"text\":\"یک قاضی فدرال ایالات متحده، سندی را منتشر کرد که گفته می‌شود یادداشت خودکشی منتسب به جفری اپستین، سرمایه‌دار و مجرم جنسی آمریکایی، است.\"}],\"markDefs\":[],\"style\":\"normal\"}],\"publishedAt\":\"2026-05-07T08:16:54.262Z\",\"shorthandUrl\":null,\"slug\":\"202605078874\",\"tag\":null,\"tags\":null,\"type\":\"story\"},{\"authors\":null,\"headline\":\"رویترز: ترامپ از «پایان سریع جنگ» گفت، تهران در حال بررسی «پیشنهاد صلح» آمریکاست\",\"id\":\"eYS8cALT8WYoU8YjHhjYb6W\",\"image\":{\"alt\":\"یک زن ایرانی در کنار دیواری نقاشی‌شده در خیابانی در تهران، ایران، ۱۶ اردیبهشت ۱۴۰۵. ماجد عسگری‌پور/وانا (West Asia News Agency) از طریق رویترز.\",\"asset\":{\"_ref\":\"image-a3ee0075e6a9076b9363578721148f00fc3213dc-800x533-jpg\",\"_type\":\"reference\"},\"caption\":\"زن ایرانی در کنار یک نقاشی دیواری در خیابانی در تهران قدم می‌زند\",\"crop\":null,\"hotspot\":null,\"metadata\":{\"dimensions\":{\"height\":533,\"width\":800},\"lqip\":\"data:image/jpeg;base64,\"}},\"language\":\"farsi\",\"lead\":[{\"_key\":\"a9ef92b41f99\",\"_type\":\"block\",\"children\":[{\"_key\":\"bac5b6f1bb87\",\"_type\":\"span\",\"marks\":[],\"text\":\"دونالد ترامپ ابراز امیدواری کرد جنگ با ایران به‌زودی پایان یابد. هم‌زمان تهران در حال بررسی پیشنهاد صلح ارائه شده از سوی واشینگتن است که به گفته منابع آگاه، پایان رسمی جنگ را رقم می‌زند.\"}],\"markDefs\":[],\"style\":\"normal\"}],\"publishedAt\":\"2026-05-07T07:44:45.695Z\",\"shorthandUrl\":null,\"slug\":\"2026050787490\",\"tag\":null,\"tags\":null,\"type\":\"article\"}]},\"key\":\"9210a01dc335\",\"type\":\"mostview\"},{\"items\":[{\"authors\":[{\"id\":\"04b9c6cb-de1c-419b-91ee-f0b2c8b61fa9\",\"image\":{\"_type\":\"figure\",\"asset\":{\"_ref\":\"image-53b677c00f1fb12cf539f0c0ce75e3d919f1598c-399x399-png\",\"_type\":\"reference\"}},\"name\":\"کامیار بهرنگ\",\"slug\":\"kamyar-behrang\"}],\"headline\":\"جنگ نمادها: چرا شکوفایی امارات برای جمهوری اسلامی غیرقابل تحمل است؟\",\"id\":\"1b094a1d-ffb4-4778-a021-530b7e1fdf4f\",\"image\":{\"alt\":null,\"asset\":{\"_ref\":\"image-f12ea08867d143a4f574494cd5cb24a3cfb433ad-5500x3787-jpg\",\"_type\":\"reference\"},\"caption\":null,\"crop\":null,\"hotspot\":null,\"metadata\":{\"dimensions\":{\"height\":3787,\"width\":5500},\"lqip\":\"data:image/jpeg;base64,\"}},\"language\":\"farsi\",\"lead\":[{\"_key\":\"010771f78e55\",\"_type\":\"block\",\"children\":[{\"_key\":\"066effd7767d\",\"_type\":\"span\",\"marks\":[],\"text\":\"دشمنی جمهوری اسلامی با امارات متحده عربی بیش از آنکه بر سر مرزها باشد، ریشه در یک تضاد عمیق وجودی دارد.\"}],\"markDefs\":[],\"style\":\"normal\"}],\"publishedAt\":\"2026-05-08T17:53:23.557Z\",\"shorthandUrl\":null,\"slug\":\"202605082923\",\"tag\":{\"color\":\"#0084bc\",\"id\":\"01eb8e6c-cbd7-4635-9101-554fa3be4b3a\",\"slug\":\"opinion\",\"title\":\"تحلیل\"},\"tags\":[{\"color\":\"#0084bc\",\"id\":\"01eb8e6c-cbd7-4635-9101-554fa3be4b3a\",\"slug\":\"opinion\",\"title\":\"تحلیل\"}],\"type\":\"story\"},{\"authors\":[{\"id\":\"beea35bb-a1f1-4955-88c3-6c13c8363428\",\"image\":{\"_type\":\"figure\",\"asset\":{\"_ref\":\"image-17abdf05c2214ae71ad850402bb514f7033006bb-586x833-jpg\",\"_type\":\"reference\"}},\"name\":\"محمد عبدی\",\"slug\":\"MohammadAbdi\"}],\"headline\":\"«رویا»؛ زن، دیوار و زندان\",\"id\":\"e8084e4e-dd24-4c2b-9a43-24de8887bd58\",\"image\":{\"alt\":null,\"asset\":{\"_ref\":\"image-fdc1370896c100646a5df2a4f7b930752923fe3c-1920x1282-jpg\",\"_type\":\"reference\"},\"caption\":null,\"crop\":null,\"hotspot\":null,\"metadata\":{\"dimensions\":{\"height\":1282,\"width\":1920},\"lqip\":\"data:image/jpeg;base64,\"}},\"language\":\"farsi\",\"lead\":[{\"_key\":\"f691554849b6\",\"_type\":\"block\",\"children\":[{\"_key\":\"abc6c439cacc\",\"_type\":\"span\",\"marks\":[],\"text\":\"«رویا»، ساخته مهناز محمدی، که به تازگی در سینماهای آلمان به اکران عمومی درآمده، تصویر روشنی است از احوال یک زن زندانی گرفتار در اوین.\"}],\"markDefs\":[],\"style\":\"normal\"}],\"publishedAt\":\"2026-05-08T10:48:41.687Z\",\"shorthandUrl\":null,\"slug\":\"202605085397\",\"tag\":{\"color\":\"#0084bc\",\"id\":\"01eb8e6c-cbd7-4635-9101-554fa3be4b3a\",\"slug\":\"opinion\",\"title\":\"تحلیل\"},\"tags\":[{\"color\":\"#0084bc\",\"id\":\"01eb8e6c-cbd7-4635-9101-554fa3be4b3a\",\"slug\":\"opinion\",\"title\":\"تحلیل\"}],\"type\":\"story\"},{\"authors\":null,\"headline\":\"ضربه سنگین به حزب کارگر در انتخابات محلی و پیروزی گسترده حزب اصلاح بریتانیا\",\"id\":\"eYS8cALT8WYoU8YjHhr4nf6\",\"image\":{\"alt\":\"نیگل فراج، رهبر Reform UK، پس از اعلام نتایج انتخابات محلی در تالار شهر هاورینگ، لندن‌بورو آف هاورینگ، بریتانیا، ۸ مهٔ ۲۰۲۶.\\n\\nرویترز/جک تیلور\",\"asset\":{\"_ref\":\"image-4a54c91b1b22d90d62aa35b1394fac49e762197f-800x534-jpg\",\"_type\":\"reference\"},\"caption\":\"انتخابات محلی بریتانیا در سال ۲۰۲۶\",\"crop\":null,\"hotspot\":null,\"metadata\":{\"dimensions\":{\"height\":534,\"width\":800},\"lqip\":\"data:image/jpeg;base64,\"}},\"language\":\"farsi\",\"lead\":[{\"_key\":\"bbd72643e589\",\"_type\":\"block\",\"children\":[{\"_key\":\"9d3fdc011b63\",\"_type\":\"span\",\"marks\":[],\"text\":\"حزب کارگر بریتانیا به رهبری کی‌یر استارمر در انتخابات محلی این کشور با شکست‌های سنگین روبه‌رو شد. خبرگزاری رویترز نوشت این نتایج عمق نارضایتی از نخست‌وزیر بریتانیا را نشان داد و تنها دو سال پس از پیروزی قاطع او در انتخابات سراسری، تردیدها را درباره آینده سیاسی‌اش افزایش داد.\"}],\"markDefs\":[],\"style\":\"normal\"}],\"publishedAt\":\"2026-05-08T09:32:56.255Z\",\"shorthandUrl\":null,\"slug\":\"2026050866620\",\"tag\":null,\"tags\":null,\"type\":\"article\"},{\"authors\":null,\"headline\":\"آیا ترامپ پیروزی در جنگ ایران را با شکست عوض می‌کند؟\",\"id\":\"a1645ada-5c78-4809-a3b1-ae804e14fb1b\",\"image\":{\"alt\":null,\"asset\":{\"_ref\":\"image-b09750565edb034804897f4c221b84b40864deb2-1920x1080-png\",\"_type\":\"reference\"},\"caption\":null,\"crop\":null,\"hotspot\":null,\"metadata\":{\"dimensions\":{\"height\":1080,\"width\":1920},\"lqip\":\"$40\"}},\"language\":\"farsi\",\"lead\":[{\"_key\":\"7c76c10ebb02\",\"_type\":\"block\",\"children\":[{\"_key\":\"088ac6132f06\",\"_type\":\"span\",\"marks\":[],\"text\":\"مارک ای. تیسن، ستون‌نویس روزنامه واشینگتن‌پست در تحلیلی به تصمیمات و اقدامات اخیر دونالد ترامپ، رییس‌جمهوری آمریکا، پرداخته و هشدار داده که او در آستانه آن است که پیروزی در جنگ ایران را با شکست معاوضه کند زیرا نحوه پایان دادن به جنگ، به اندازه نحوه آغاز آن اهمیت دارد.\"}],\"markDefs\":[],\"style\":\"normal\"}],\"publishedAt\":\"2026-05-07T18:48:34.607Z\",\"shorthandUrl\":null,\"slug\":\"202605077265\",\"tag\":{\"color\":\"#0084bc\",\"id\":\"01eb8e6c-cbd7-4635-9101-554fa3be4b3a\",\"slug\":\"opinion\",\"title\":\"تحلیل\"},\"tags\":[{\"color\":\"#0084bc\",\"id\":\"01eb8e6c-cbd7-4635-9101-554fa3be4b3a\",\"slug\":\"opinion\",\"title\":\"تحلیل\"}],\"type\":\"story\"},{\"authors\":[{\"id\":\"40fe8a47-07c8-4e63-84f0-d3dc5eca6416\",\"image\":{\"_type\":\"image\",\"asset\":{\"_ref\":\"image-6482bd2dd2b6986e63eb47db4fcd9cda1c50f5ca-576x1198-jpg\",\"_type\":\"reference\"},\"crop\":{\"_type\":\"sanity.imageCrop\",\"bottom\":0.12984270032518827,\"left\":0,\"right\":0,\"top\":0},\"hotspot\":{\"_type\":\"sanity.imageHotspot\",\"height\":0.8701572996748117,\"width\":1,\"x\":0.5,\"y\":0.43507864983740585}},\"name\":\"سبا حیدرخانی\",\"slug\":\"saba-heidarkhani\"}],\"headline\":\"سانسور و رصد کاربران در روبیکا و دیگر پیام‌رسان‌های داخلی\",\"id\":\"29da327f-b332-41d0-bafc-d898c3f816a8\",\"image\":{\"alt\":null,\"asset\":{\"_ref\":\"image-68d75f2adcc0ddfe03f994e2b8c1d01bbefdd7ed-1536x1024-png\",\"_type\":\"reference\"},\"caption\":\"این تصویر با استفاده از هوش مصنوعی تولید شده است\",\"crop\":null,\"hotspot\":null,\"metadata\":{\"dimensions\":{\"height\":1024,\"width\":1536},\"lqip\":\"$41\"}},\"language\":\"farsi\",\"lead\":[{\"_key\":\"a675900341ac\",\"_type\":\"block\",\"children\":[{\"_key\":\"860977b27be1\",\"_type\":\"span\",\"marks\":[],\"text\":\"با قطع اینترنت بین‌المللی، میلیون‌ها کاربر ناخواسته به سمت اپ‌ها و پیام‌رسان‌های ایرانی سوق داده شده‌اند. با وجود تلاش حکومت برای معرفی این فضا به‌عنوان جایگزین نمونه خارجی، شهروندان از کندی و سانسور محتوا در برنامه‌های داخلی و البته تلاش برای دور زدن این محدودیت‌ها خبر می‌دهند.\"}],\"markDefs\":[],\"style\":\"normal\"}],\"publishedAt\":\"2026-05-07T12:26:48.773Z\",\"shorthandUrl\":null,\"slug\":\"202605075146\",\"tag\":{\"color\":\"#2300bc\",\"id\":\"705e189f-3134-48c9-aa90-7785892fbe87\",\"slug\":\"rwayt-shma\",\"title\":\"روایت شما\"},\"tags\":[{\"color\":\"#2300bc\",\"id\":\"705e189f-3134-48c9-aa90-7785892fbe87\",\"slug\":\"rwayt-shma\",\"title\":\"روایت شما\"}],\"type\":\"story\"}],\"key\":\"6c5b6d673581\",\"style\":\"normal\",\"title\":\"انتخاب سردبیر\",\"type\":\"customlist\"}],\"language\":\"farsi\",\"className\":\"page__sidebar home__widgets\"}]]}]],\"$L42\",\"$L43\"]}]\n"])</script><script>self.__next_f.push([1,"42:[\"$\",\"section\",null,{\"className\":\"home__clusters home__clusters--core\",\"children\":[\"$L44\"]}]\n"])</script><script>self.__next_f.push([1,"43:[\"$\",\"section\",null,{\"className\":\"home__topics\",\"children\":[\"$\",\"div\",null,{\"className\":\"home__topics__container\",\"children\":[[\"$\",\"div\",\"topic-9461802a-b5bb-45bd-9de9-f94e7f2bb0f7\",{\"className\":\"LastTopicUpdates-module-scss-module__saWW_q__topic\",\"children\":[[\"$\",\"h4\",null,{\"className\":\"LastTopicUpdates-module-scss-module__saWW_q__topic__title\",\"children\":[\"$\",\"$L26\",null,{\"href\":\"https://www.iranintl.com/eatrazat-sarasry-1404\",\"prefetch\":false,\"children\":\"انقلاب ملی ایرانیان\"}]}],[\"$\",\"ul\",null,{\"children\":[[\"$\",\"li\",\"28d0be7a-ed83-4836-adea-d92952cae53d\",{\"className\":\"LastTopicUpdates-module-scss-module__saWW_q__topic__items--item\",\"children\":[\"$\",\"$L45\",null,{\"variant\":\"featured\",\"content\":{\"headline\":\"پوریا غلامعلی؛ ورزشکاری که در رویای آزادی کشته شد\",\"id\":\"28d0be7a-ed83-4836-adea-d92952cae53d\",\"image\":{\"alt\":null,\"asset\":{\"_ref\":\"image-0f7884c74e8e023ff5b1aa4091b5fd9bc1ddbfa3-1672x941-png\",\"_type\":\"reference\"},\"caption\":null,\"crop\":{\"_type\":\"sanity.imageCrop\",\"bottom\":0.3836325761129826,\"left\":0.18328345504712296,\"right\":0.20192244276287424,\"top\":0},\"hotspot\":{\"_type\":\"sanity.imageHotspot\",\"height\":0.6163674238870174,\"width\":0.6147941021900027,\"x\":0.49068050614212433,\"y\":0.3081837119435087},\"metadata\":{\"dimensions\":{\"height\":941,\"width\":1672},\"lqip