51.jpg?rect=27,0,677,451\u0026w=600\u0026h=400\u0026q=70\u0026fit=max\u0026auto=format\",\"alt\":\"ماموران حکومت از نصب سنگ مزار جاویدنام محسن رشیدخانی‌آبادی در بهارستان جلوگیری کردند\",\"style\":{\"width\":\"100%\",\"height\":\"auto\",\"display\":\"block\"},\"loading\":\"lazy\"}]]\n96:[\"$\",\"div\",null,{\"className\":\"HotTakeHorizontalCluster-module-scss-module__fgOhha__cover\",\"children\":[\"$\",\"figure\",null,{\"className\":\"cover horizontal\",\"children\":[\"$\",\"$L26\",null,{\"className\":\"cover__link\",\"href\":\"https://www.iranintl.com/202605073178\",\"target\":\"_self\",\"prefetch\":false,\"children\":[\"$\",\"picture\",null,{\"style\":{\"display\":\"block\",\"width\":\"100%\"},\"children\":\"$98\"}]}]}]}]\n"])</script><script>self.__next_f.push([1,"5a:[\"$\",\"section\",null,{\"className\":\"cluster\",\"children\":[\"$\",\"div\",null,{\"className\":\"LivePulseCluster-module-scss-module__AK0esa__container\",\"children\":[[\"$\",\"div\",null,{\"className\":\"LivePulseCluster-module-scss-module__AK0esa__pointsContainer\",\"children\":[\"$\",\"div\",null,{\"className\":\"LivePulseCluster-module-scss-module__AK0esa__summary \",\"children\":[\"$\",\"div\",null,{\"className\":\"LivePulseCluster-module-scss-module__AK0esa__points \",\"children\":[[\"$\",\"strong\",null,{\"className\":\"LivePulseCluster-module-scss-module__AK0esa__pointsTitle \",\"children\":\"خلاصه\"}],[\"$\",\"$L99\",null,{\"items\":[\"رویترز به نقل از یک منبع اعلام کرد که دیدار معاون رییس‌جمهور آمریکا با نخست‌وزیر قطر درباره روابط دوجانبه دو کشور و همچنین مذاکرات ایران برگزار می‌شود\",\"وزیر خارجه آمریکا، اعلام کرد واشینگتن جمعه منتظر دریافت پاسخ جمهوری اسلامی به طرح پیشنهادی صلح است و گفت این پاسخ در صورت «جدی» بودن می‌تواند مسیر آغاز مذاکرات واقعی را باز کند\",\"نت‌بلاکس در هفتادمین روز قطع اینترنت در ایران هشدار داد خاموشی دیجیتال بیش از همه به افراد دارای معلولیت، دانشجویان و کسب‌وکارهای کوچک آسیب می‌زند\",\"علی خضریان، عضو کمیسیون امنیت ملی مجلس، اعلام کرد جمهوری اسلامی امارات را مانند اقلیم کردستان عراق «پایگاه دشمن» می‌داند\",\"استارمر پس از شکست حزب کارگر در انتخابات محلی بریتانیا، از برخی سیاست‌های خود از جمله عدم ورود به جنگ ایران دفاع کرد و گفت از سمتش کناره‌گیری نمی‌کند\",\"ارتش جمهوری اسلامی نفتکش «اوشن کوی» را به‌ اتهام «تلاش برای اخلال در صادرات نفت ایران» توقیف کرد\"],\"interval\":8000,\"showControls\":true}]]}]}]}],[\"$\",\"div\",null,{\"className\":\"LivePulseCluster-module-scss-module__AK0esa__featured\",\"children\":[[\"$\",\"article\",null,{\"className\":\"cluster-item cluster-item--urgent\",\"children\":[[\"$\",\"div\",null,{\"className\":\"LivePulseCluster-module-scss-module__AK0esa__liveblogBadge__live \",\"children\":[[\"$\",\"$L9a\",null,{}],[\"$\",\"strong\",null,{\"children\":\"زنده\"}]]}],[\"$\",\"$L26\",null,{\"href\":\"https://www.iranintl.com/fa/liveblog/iran-war-may8\",\"className\":\"cluster-item__link\",\"prefetch\":false,\"children\":[\"$\",\"h4\",null,{\"className\":\"cluster-item__headline cluster-item__headline--urgent \",\"children\":\"معاون رییس‌جمهور آمریکا درباره تحولات منطقه با نخست‌وزیر قطر دیدار کرد\"}]}]]}],[\"$\",\"div\",null,{\"children\":[\"$\",\"div\",null,{\"className\":\"LivePulseCluster-module-scss-module__AK0esa__updates \",\"children\":[[\"$\",\"div\",\"05578477-7c5e-4d86-b532-12430dbfa4d3\",{\"className\":\"LivePulseCluster-module-scss-module__AK0esa__updateItem \",\"children\":[\"$\",\"$L62\",null,{\"variant\":\"minimal\",\"item\":{\"headline\":\"حزب‌الله مسئولیت حمله‌ای جدید به یک پایگاه نظامی در شمال اسرائیل را بر عهده گرفت\",\"id\":\"05578477-7c5e-4d86-b532-12430dbfa4d3\",\"language\":\"farsi\",\"publishedAt\":\"2026-05-08T19:53:48.568Z\",\"slug\":\"liveblog/iran-war-may8#202605089749\",\"type\":\"liveblogstory\"}}]}],[\"$\",\"div\",\"f1a41ddb-3180-4f27-897d-a899acb5d247\",{\"className\":\"LivePulseCluster-module-scss-module__AK0esa__updateItem \",\"children\":[\"$\",\"$L62\",null,{\"variant\":\"minimal\",\"item\":{\"headline\":\"مسئول دیدارهای دفتر رهبر پیشین جمهوری اسلامی: مجتبی خامنه‌ا