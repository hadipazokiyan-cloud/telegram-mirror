ernational","inLanguage":"fa","dateModified":"2026-05-08T18:10:57.000Z","publisher":{"@type":"Organization","@id":"https://www.iranintl.com#organization","name":"Iran International","url":"https://www.iranintl.com","logo":{"@type":"ImageObject","url":"https://www.iranintl.com/images/ii/logo.svg"}},"potentialAction":{"@type":"SearchAction","target":{"@type":"EntryPoint","urlTemplate":"https://www.iranintl.com/search?q={search_term_string}"},"query-input":"required name=search_term_string"}}</script><section class="page__container"><main class="page__main home__clusters home__clusters--hot-takes"><section class="cluster"><div class="LivePulseCluster-module-scss-module__AK0esa__container"><div class="LivePulseCluster-module-scss-module__AK0esa__pointsContainer"><div class="LivePulseCluster-module-scss-module__AK0esa__summary "><div class="LivePulseCluster-module-scss-module__AK0esa__points "><strong class="LivePulseCluster-module-scss-module__AK0esa__pointsTitle ">خلاصه</strong><div><div style="opacity:0;transform:translateY(20px)">رویترز به نقل از یک منبع اعلام کرد که دیدار معاون رییس‌جمهور آمریکا با نخست‌وزیر قطر درباره روابط دوجانبه دو کشور و همچنین مذاکرات ایران برگزار می‌شود</div><div class="RotatingTicker-module-scss-module__QRoAkG__navigation"><button class="RotatingTicker-module-scss-module__QRoAkG__btn__prev" type="button"></button><button class="RotatingTicker-module-scss-module__QRoAkG__btn__next" type="button"></button></div></div></div></div></div><div class="LivePulseCluster-module-scss-module__AK0esa__featured"><article class="cluster-item cluster-item--urgent"><div class="LivePulseCluster-module-scss-module__AK0esa__liveblogBadge__live "><div style="width:10px;height:10px;background-color:var(--color-red-600);border-radius:50%"></div><strong>زنده</strong></div><a class="cluster-item__link" href="https://www.iranintl.com/fa/liveblog/iran-war-may8"><h4 class="cluster-item__headline cluster-item__headline--urgent ">معاون رییس‌جمهور آمریکا درباره تحولات منطقه با نخست‌وزیر قطر دیدار کرد</h4></a></article><div><div class="LivePulseCluster-module-scss-module__AK0esa__updates "><div class="LivePulseCluster-module-scss-module__AK0esa__updateItem "><article class="cluster-item cluster-item--minimal"><div class="cluster-item__main"><a class="cluster-item__link" href="https://www.iranintl.com/fa/liveblog/iran-war-may8#202605089749"><h4 class="cluster-item__headline cluster-item__headline--minimal">حزب‌الله مسئولیت حمله‌ای جدید به یک پایگاه نظامی در شمال اسرائیل را بر عهده گرفت</h4></a></div></article></div><div class="LivePulseCluster-module-scss-module__AK0esa__updateItem "><article class="cluster-item cluster-item--minimal"><div class="cluster-item__main"><a class="cluster-item__link" href="https://www.iranintl.com/fa/liveblog/iran-war-may8#202605081931"><h4 class="cluster-item__headline cluster-item__headline--minimal">مسئول دیدارهای دفتر رهبر پیشین جمهوری اسلامی: مجتبی خامنه‌ای بر اثر موج انفجار مجروح شد</h4></a></div></article></div><div class="LivePulseCluster-module-scss-module__AK0esa__updateItem "><article class="cluster-item cluster-item--minimal"><div class="cluster-item__main"><a class="cluster-item__link" href="https://www.iranintl.com/fa/liveblog/iran-war-may8#202605086211"><h4 class="cluster-item__headline cluster-item__headline--minimal">نخست‌وزیر و وزیر خارجه قطر در واشینگتن با معاون رییس‌جمهور آمریکا دیدار کرد</h4></a></div></article></div><div class="LivePulseCluster-module-scss-module__AK0esa__updateItem "><article class="cluster-item cluster-item--minimal"><div class="cluster-item__main"><a class="cluster-item__link" href="https://www.iranintl.com/fa/liveblog/iran-war-may8#202605089858"><h4 class="cluster-item__headline cluster-item__headline--minimal">فاکس‌نیوز: سه ناو جنگی آمریکا پنجشنبه با آتش «بی‌وقفه» مواجه شدند</h4></a></div></article></div><div class="LivePulseCluster-module-scss-module__AK0esa__updateItem "><article class="cluster-item cluster-item--minimal"><div class="cluster-item__main"><a clas