\"}},\"language\":\"farsi\",\"leadRaw\":[{\"_key\":\"a49e0c7aeda8\",\"_type\":\"block\",\"children\":[{\"_key\":\"bbeaa30e2ad9\",\"_type\":\"span\",\"marks\":[],\"text\":\"پاپ لئو، رهبر کاتولیک‌های جهان و مارکو روبیو، وزیر امور خارجه ایالات متحده، در جریان دیدار خود در واتیکان بر ضرورت تقویت روابط دوجانبه تاکید کردند. این دیدار پس از انتقادهای متعدد دونالد ترامپ، رییس‌جمهوری آمریکا، از پاپ انجام شده است.\"}],\"markDefs\":[],\"style\":\"normal\"}],\"publishedAt\":\"2026-05-07T19:23:19.724Z\",\"shorthandUrl\":null,\"slug\":\"202605072756\",\"type\":\"story\"},\"layout\":{\"showAuthor\":false},\"dictionary\":\"$35:props:children:props:dictionary\"}]}],[\"$\",\"div\",\"3f456983-02eb-45da-af89-61a01e2da666\",{\"className\":\"HotTakeHorizontalCluster-module-scss-module__fgOhha__additionalChunkItem\",\"children\":[\"$\",\"$L62\",null,{\"variant\":\"card\",\"item\":{\"firstTag\":null,\"headline\":\"چین ۲ وزیر دفاع پیشین خود را به اعدام تعلیقی محکوم کرد\",\"id\":\"3f456983-02eb-45da-af89-61a01e2da666\",\"image\":{\"alt\":null,\"asset\":{\"_ref\":\"image-981034b2e3edc000c0f0e789f7f6344136fea262-840x560-jpg\",\"_type\":\"reference\"},\"caption\":null,\"crop\":null,\"hotspot\":null,\"metadata\":{\"dimensions\":{\"height\":560,\"width\":840},\"lqip\":\"data:image/jpeg;base64,\"}},\"language\":\"farsi\",\"leadRaw\":[{\"_key\":\"f1cbfe171881\",\"_type\":\"block\",\"children\":[{\"_key\":\"b495f34f59f4\",\"_type\":\"span\",\"marks\":[],\"text\":\"دادگاه نظامی چین در حکمی کم‌سابقه دو وزیر دفاع پیشین این کشور، وی فنگه و لی شانگفو، را به اتهام فساد و رشوه‌خواری به اعدام با دو سال تعلیق محکوم کرد.\"}],\"markDefs\":[],\"style\":\"normal\"}],\"publishedAt\":\"2026-05-07T13:38:55.280Z\",\"shorthandUrl\":null,\"slug\":\"202605072769\",\"type\":\"story\"},\"layout\":{\"showAuthor\":false},\"dictionary\":\"$35:props:children:props:dictionary\"}]}]]}]}]]}]\n"])</script><script>self.__next_f.push([1,"11:null\n"])</script><script>self.__next_f.push([1,"16:[[\"$\",\"title\",\"0\",{\"children\":\"صفحه اصلی | ایران اینترنشنال\"}],[\"$\",\"meta\",\"1\",{\"name\":\"description\",\"content\":\"ایران اینترنشنال تازه ترین خبرهای سیاسی، اقتصادی، اجتماعی، ورزشی، فرهنگی و هنری از ایران و جهان را در تلویزیون و وبسایت خود پوشش می‌دهد. خبرهای فوری، گزارش‌های خبری و تحلیل‌های کارشناسی ایران اینترنشنال را از ماهواره، اینترنت و صفحه‌های ما در شبکه‌های اجتماعی دنبال کنید. ایران اینترنشنال خبرها را از استرالیا تا کانادا و از خاورمیانه تا خاور دور را بدون پیشداوری‌ و جانبداری برای شما عرضه می‌کند. اخبار اقتصادی، قیمت ارز، قیمت دلار، قیمت سکه و آخرین اطلاعات شاخص بورس و سهام را شبانه روز عرضه می کند\"}],[\"$\",\"link\",\"2\",{\"rel\":\"manifest\",\"href\":\"/manifest.webmanifest\",\"crossOrigin\":\"$undefined\"}],[\"$\",\"meta\",\"3\",{\"name\":\"keywords\",\"content\":\"خبر, تحلیل, ایران, خلیج فارس, حقوق بشر, زنان, ارتباط مستقیم, چشم انداز, خبرهای جهان, خبرهای منطقه, خاورمیانه, سوریه, عراق, بریتانیا, تلویزیون, شبکه‌های اجتماعی, گالری تصاویر, مرور نشریات, خبرهای ورزشی, خامنه ای, روحانی, انتخابات, ایالات متحده, بیروت, سینما, مستند, یمن, اقلیتها, سیاسی, زندانیان, تلگرام، توئیتر، فیس بوک، مهاجران، خبرنگار, فن آوری، جشنواره, گزارش, رپورتاژ,ادبیات, شعر, پوشش زنده, نظرسنجی, کم آبی, بحران, خبر فوری, محیط زیست، اخبار اقتصادی، قیمت ارز، قیمت دلار، قیمت سکه، شاخص بورس، شاخص سهام، رئیسی\"}],[\"$\",\"link\",\"4\",{\"rel\":\"canonical\",\"href\":\"https://www.iranintl.com\"}],[\"$\",\"link\",\"5\",{\"rel\":\"alternate\",\"hrefLang\":\"fa\",\"href\":\"https://www.iranintl.com/fa\"}],[\"$\",\"link\",\"6\",{\"rel\":\"alternate\",\"hrefLang\":\"ar\",\"href\":\"https://www.iranintl.com/ar\"}],[\"$\",\"link\",\"7\",{\"rel\":\"alternate\",\"hrefLang\":\"en\",\"href\":\"https://www.iranintl.com/en\"}],[\"$\",\"meta\",\"8\",{\"name\":\"google-adsense-account\",\"content\":\"ca-pub-7753790121110564\"}],[\"$\",\"meta\",\"9\",{\"property\":\"og:title\",\"content\":\"صفحه اصلی | ایران اینترنشنال\"}],[\"$\",\"meta\",\"10\",{\"property\":\"og:description\",\"content\":\"ایران اینترنشنال تازه ترین خبرهای