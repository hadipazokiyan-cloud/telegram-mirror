,"width":2120,"height":351},{"url":"https://yt3.googleusercontent.com/2tL1Y8xF2Twm-ODsKZOiWYMJuOWU1NRrdI-j7v83nIYJTUOUE8oUpiHisfhbnnjOVmuszTngRg=w2276-fcrop64=1,00005a57ffffa5a8-k-c0xffffffff-no-nd-rj","width":2276,"height":377},{"url":"https://yt3.googleusercontent.com/2tL1Y8xF2Twm-ODsKZOiWYMJuOWU1NRrdI-j7v83nIYJTUOUE8oUpiHisfhbnnjOVmuszTngRg=w2560-fcrop64=1,00005a57ffffa5a8-k-c0xffffffff-no-nd-rj","width":2560,"height":424}]},"style":"IMAGE_BANNER_STYLE_INSET","rendererContext":{"loggingContext":{"loggingDirectives":{"trackingParams":"CBMQnfILIhMI6OP8lb6qlAMVZrz_BB0VuA5L","visibility":{"types":"12"}}}}}},"rendererContext":{"loggingContext":{"loggingDirectives":{"trackingParams":"CBIQot8KIhMI6OP8lb6qlAMVZrz_BB0VuA5L","visibility":{"types":"12"}}}}}}}},"metadata":{"channelMetadataRenderer":{"title":" مازیار در اروپا","description":"به کانال من خوش اومدین! من مازیارم و پنج ساله که فنلاند زندگی می‌کنم. تو ایران لیسانس و ارشد عمران خوندم و اینجا ارشد مجدد گرفتم و الان به عنوان  منتور دانشگاه LUT  و کارافرین مشغول به کار هستم.\n\nتوی این کانال قراره از تجربه‌هام براتون بگم؛ از تحصیل و کار توی فنلاند گرفته تا سفرهام و چیزایی که درباره این قاره دوست‌ داشتنی دیدم و می‌دونم. \n\nلایک و سابسکرایب شما شاید ساده باشه،\nاما برای من تبدیل میشه به انگیزه‌ای بزرگ برای ساختن و ادامه دادن.\nحمایت‌تون دنیایی ارزش داره. 💙\n \nبرای تماس با من به ایدی تلگرام زیر پیام بدید:\nhttps://t.me/applyfinlandstudy\n","rssUrl":"https://www.youtube.com/feeds/videos.xml?channel_id=UCFDmWINtm5zeBm2tyBT2ZCw","externalId":"UCFDmWINtm5zeBm2tyBT2ZCw","keywords":"\"زندگی در فنلاند\" \"تحصیل در فنلاند\" \"تجربه زندگی در فنلاند\" \"مهاجرت به فنلاند\" \"فنلاند برای دانشجویان\" \"کار در فنلاند\" \"فرهنگ فنلاند\" \"آب و هوای فنلاند\" \"دانشگاه های فنلاند\" \"بورسیه تحصیلی فنلاند\" \"تحصیل رایگان در فنلاند\" \"رشته های تحصیلی در فنلاند\" \"ویزای دانشجویی فنلاند\" \"خوابگاه دانشجویی در فنلاند\"","ownerUrls":["http://www.youtube.com/@MaziarEurope"],"avatar":{"thumbnails":[{"url":"https://yt3.googleusercontent.com